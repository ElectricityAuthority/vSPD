 689    SharedReserveLimitByClearedReserve(ca,dt,isl,resC)                               '6.5.2.2 : Shared offered reserve is limited by cleared reserved'
 690    BothClearedAndFreeReserveCanBeShared(ca,dt,isl,resC,rd)                          '6.5.2.4 : Shared reserve is covered by cleared reserved and shareable free reserve'
 691    ReserveShareSentLimitByHVDCControlBand(ca,dt,isl,resC,rd)                        '6.5.2.5 : Reserve share sent from an island is limited by HVDC control band'
 692    FwdReserveShareSentLimitByHVDCCapacity(ca,dt,isl,resC,rd)                        '6.5.2.6 : Forward reserve share sent from an island is limited by HVDC capacity'
 693    ReverseReserveOnlyToEnergySendingIsland(ca,dt,isl,resC,rd)                       '6.5.2.7 : Shared reserve sent in reverse direction is possible only if the island is not sending energy through HVDC'
 694    ReverseReserveShareLimitByHVDCControlBand(ca,dt,isl,resC,rd)                     '6.5.2.8 : Reverse reserve share recieved at an island is limited by HVDC control band'
 695    ForwardReserveOnlyToEnergyReceivingIsland(ca,dt,isl,resC,rd)                     '6.5.2.9 : Forward received reserve is possible if in the same direction of HVDC '
 696    ReverseReserveLimitInReserveZone(ca,dt,isl,resC,rd,z)                            '6.5.2.10: Reverse reserve constraint if HVDC sent flow in reverse zone'
 697    ZeroReserveInNoReserveZone(ca,dt,isl,resC,z)                                     '6.5.2.11 & 6.5.2.18: No reverse reserve if HVDC sent flow in no reverse zone and no forward reserve if round power disabled'
 698    OnlyOneActiveHVDCZoneForEachReserveClass(ca,dt,resC)                             '6.5.2.12: Across both island, one and only one zone is active for each reserve class'
 699    ZeroSentHVDCFlowForNonSendingIsland(ca,dt,isl)                                   '6.5.2.13: Directed HVDC sent from an island, if non-zero, must fall in a zone for each reserve class'
 700    RoundPowerZoneSentHVDCUpperLimit(ca,dt,isl,resC,z)                               '6.5.2.14: Directed HVDC sent from an island <= RoundPowerZoneExit level if in round power zone of that island'
 701    HVDCSendingIslandDefinition(ca,dt,isl,resC)                                      '6.5.2.15: An island is HVDC sending island if HVDC flow sent is in one of the three zones for each reserve class '
 702    OnlyOneSendingIslandExists(ca,dt)                                                '6.5.2.19: One and only one island is HVDC sending island'
 703    HVDCSentCalculation(ca,dt,isl)                                                   '6.5.2.20: Total HVDC sent from each island'
 704   
 705  * Lamda loss model
 706    HVDCFlowAccountedForForwardReserve(ca,dt,isl,resC,rd)                            '6.5.2.21: HVDC flow sent from an island taking into account forward sent reserve'
 707    ForwardReserveReceivedAtHVDCReceivingIsland(ca,dt,isl,resC,rd)                   '6.5.2.22: Forward reserve RECEIVED at an HVDC receiving island'
 708    HVDCFlowAccountedForReverseReserve(ca,dt,isl,resC,rd)                            '6.5.2.23: HVDC flow sent from an island taking into account reverse received reserve'
 709    ReverseReserveReceivedAtHVDCSendingIsland(ca,dt,isl,resC,rd)                     '6.5.2.24: Reverse reserve RECEIVED at an HVDC sending island'
 710    HVDCSentEnergyLambdaDefinition(ca,dt,isl)                                        '6.5.2.25: Definition of weight factor for total HVDC energy sent from an island'
 711    HVDCSentEnergyFlowDefinition(ca,dt,isl)                                          '6.5.2.26: Lambda definition of total HVDC energy flow sent from an island'
 712    HVDCSentEnergyLossesDefinition(ca,dt,isl)                                        '6.5.2.27: Lambda definition of total loss of HVDC energy sent from an island'
 713    HVDCSentReserveLambdaDefinition(ca,dt,isl,resC,rd)                               '6.5.2.28: Definition of weight factor for total HVDC+reserve sent from an island'
 714    HVDCSentReserveFlowDefinition(ca,dt,isl,resC,rd)                                 '6.5.2.29: Lambda definition of Reserse + Energy flow on HVDC sent from an island'
 715    HVDCSentReserveLossesDefinition(ca,dt,isl,resC,rd)                               '6.5.2.30: Lambda definition of Reserse + Energy loss on HVDC sent from an island'
 716   
 717  * Reserve share penalty
 718  * Tuong Nguyen added on 24 Feb 2021 to correct the calculation
 719    ReserveShareEffective_CE_Calculation(ca,dt,isl,resC,riskC)                       '6.5.2.31: Calculate max effective shared reserve for CE risk received at island'
 720    ReserveShareEffective_ECE_Calculation(ca,dt,isl,resC,riskC)                      '6.5.2.31: Calculate max effective shared reserve for ECE risk received at island'
 721    ExcessReserveSharePenalty(ca,dt)                                                 '6.5.2.31: Constraint to avoid excessive reserve share'
 722   
 723  * Reserve
 724    PLSRReserveProportionMaximum(ca,dt,o,blk,resC,resT)                              '6.5.3.1: Maximum PLSR as a proportion of the block MW'
 725    ReserveInterruptibleOfferLimit(ca,dt,o,bd,resC,resT)                             '6.5.3.3: Cleared IL reserve is constrained by cleared dispatchable demand'
 726    ReserveOfferDefinition(ca,dt,o,resC,resT)                                        '6.5.3.4: Definition of the reserve offers of different classes and types'
 727    EnergyAndReserveMaximum(ca,dt,o,resC)                                            '6.5.3.5: Definition of maximum energy and reserves from each generator'
 728   
 729  * Reserve scarcity/shortfall
 730    HVDCRiskReserveShortFallCalculation(ca,dt,isl,resC,RiskC)                        '6.5.4.2: Total Reserve Shortfall for DCCE risk'
 731    ManualRiskReserveShortFallCalculation(ca,dt,isl,resC,RiskC)                      '6.5.4.2: Total Reserve Shortfall for Manual risk'
 732    GenRiskReserveShortFallCalculation(ca,dt,isl,o,resC,RiskC)                       '6.5.4.2: Total Reserve Shortfall for generation risk unit'
 733    HVDCsecRiskReserveShortFallCalculation(ca,dt,isl,o,resC,RiskC)                   '6.5.4.2: Total Reserve Shortfall for generation unit + HVDC risk'
 734    HVDCsecManualRiskReserveShortFallCalculation(ca,dt,isl,resC,RiskC)                '6.5.4.2: Total Reserve Shortfall for Manual risk + HVDC risk'
 735    RiskGroupReserveShortFallCalculation(ca,dt,isl,rg,resC,RiskC)                     '6.5.4.2: Total Reserve Shortfall for Risk Group'
 736   
 737  * Matching of reserve requirement and availability
 738    IslandReserveCalculation(ca,dt,isl,resC)                                         '6.5.5.1: Calculate total island cleared reserve'
 739    SupplyDemandReserveRequirement(ca,dt,isl,resC,riskC)                             '6.5.5.2&3: Matching of reserve supply and demand'
 740   
 741  * Branch security constraints
 742    BranchSecurityConstraintLE(ca,dt,brCstr)                                         '6.6.1.5: Branch security constraint with LE sense'
 743    BranchSecurityConstraintGE(ca,dt,brCstr)                                         '6.6.1.5: Branch security constraint with GE sense'
 744    BranchSecurityConstraintEQ(ca,dt,brCstr)                                         '6.6.1.5: Branch security constraint with EQ sense'
 745   
 746  * Market node security constraints
 747    MNodeSecurityConstraintLE(ca,dt,MnodeCstr)                                       '6.6.1.7: Market node security constraint with LE sense'
 748    MNodeSecurityConstraintGE(ca,dt,MnodeCstr)                                       '6.6.1.7: Market node security constraint with GE sense'
 749    MNodeSecurityConstraintEQ(ca,dt,MnodeCstr)                                       '6.6.1.7: Market node security constraint with EQ sense'
 750   
 751    ;
 752   
 753  * OBJECTIVE FUNCTION (5.1.1.1)
 754  ObjectiveFunction..
 755    NETBENEFIT
 756  =e=
 757    sum[ t, SYSTEMBENEFIT(t) - SYSTEMCOST(t) - SCARCITYCOST(t)
 758          - SYSTEMPENALTYCOST(t) - RESERVESHAREPENALTY(t) ]
 759    + sum[(t,n,blk), scarcityEnrgLimit(t,n,blk) * scarcityEnrgPrice(t,n,blk)]
 760    ;
 761   
 762  * Defined as the net sum of generation cost + reserve cost
 763  SystemCostDefinition(t)..
 764    SYSTEMCOST(t)
 765  =e=
 766    sum[ genOfrBlk(t,o,blk)
 767       , GENERATIONBLOCK(genOfrBlk)
 768       * enrgOfrPrice(genOfrBlk) ]
 769  + sum[ resOfrBlk(t,o,blk,resC,resT)
 770       , RESERVEBLOCK(resOfrBlk)
 771       * resrvOfrPrice(resOfrBlk) ]
 772    ;
 773   
 774  * Defined as the net sum of dispatchable load benefit
 775  SystemBenefitDefinition(t)..
 776    SYSTEMBENEFIT(t)
 777  =e=
 778    sum[ demBidBlk(t,bd,blk)
 779       , PURCHASEBLOCK(demBidBlk)
 780       * demBidPrice(demBidBlk) ]
 781    ;
 782   
 783  * Defined as the sum of the individual violation costs
 784  SystemPenaltyCostDefinition(t)..
 785    SYSTEMPENALTYCOST(t)
 786  =e=
 787    sum[ bus(t,b), deficitBusGenerationPenalty * DEFICITBUSGENERATION(bus)
 788                      + surplusBusGenerationPenalty * SURPLUSBUSGENERATION(bus) ]
 789   
 790  + sum[ branch(t,br), surplusBranchFlowPenalty * SURPLUSBRANCHFLOW(branch) ]
 791   
 792  + sum[ offer(t,o), deficitRampRatePenalty * DEFICITRAMPRATE(offer)
 793                        + surplusRampRatePenalty * SURPLUSRAMPRATE(Offer) ]
 794   
 795  + sum[ BranchConstraint(t,brCstr)
 796       , deficitBrCstrPenalty * DEFICITBRANCHSECURITYCONSTRAINT(t,brCstr)
 797       + surplusBrCstrPenalty * SURPLUSBRANCHSECURITYCONSTRAINT(t,brCstr) ]
 798   
 799  + sum[ MNodeConstraint(t,MnodeCstr)
 800       , deficitMnodeCstrPenalty * DEFICITMNODECONSTRAINT(MNodeConstraint)
 801       + surplusMnodeCstrPenalty * SURPLUSMNODECONSTRAINT(MNodeConstraint) ]
 802   
 803  + sum[ (isl,resC)
 804         , [DeficitReservePenalty_CE  * DEFICITRESERVE_CE(t,isl,resC) ]
 805         + [DeficitReservePenalty_ECE * DEFICITRESERVE_ECE(t,isl,resC)]
 806       ]
 807   
 808  + sum[ o $ { (StudyMode(t) = 101) or (StudyMode(t) = 201) }
 809           , 0.0005 * ( GENERATIONUPDELTA(t,o) + GENERATIONDNDELTA(t,o) )
 810       ]
 811    ;
 812   
 813  * Defined as the sum of the individual violation costs (for reporting)
 814  TotalViolationCostDefinition..
 815    TOTALPENALTYCOST =e= sum[ t, SYSTEMPENALTYCOST(t) ] ;
 816   
 817  * Deined as the sume of scarcity cost
 818  TotalScarcityCostDefinition(t)..
 819    SCARCITYCOST(t)
 820  =e=
 821    sum[ (n,blk), scarcityEnrgPrice(t,n,blk) * ENERGYSCARCITYBLK(t,n,blk) ]
 822   
 823  + sum[ (isl,resC,riskC,blk) $ HVDCrisk(riskC)
 824       , ScarcityResrvIslandPrice(t,isl,resC,blk)
 825        * RESERVESHORTFALLBLK(t,isl,resC,riskC,blk) ]
 826   
 827  + sum[ (isl,resC,riskC,blk) $ ManualRisk(riskC)
 828       , ScarcityResrvIslandPrice(t,isl,resC,blk)
 829       * RESERVESHORTFALLBLK(t,isl,resC,riskC,blk) ]
 830   
 831  +  sum[ (isl,o,resC,riskC,blk) $ { GenRisk(riskC)
 832                                 and islandRiskGenerator(t,isl,o) }
 833       , ScarcityResrvIslandPrice(t,isl,resC,blk)
 834       * RESERVESHORTFALLUNITBLK(t,isl,o,resC,riskC,blk) ]
 835   
 836  +  sum[ (isl,o,resC,riskC,blk) $ { HVDCsecRisk(riskC)
 837                                 and islandRiskGenerator(t,isl,o) }
 838       , ScarcityResrvIslandPrice(t,isl,resC,blk)
 839       * RESERVESHORTFALLUNITBLK(t,isl,o,resC,riskC,blk) ]
 840   
 841  +  sum[ (isl, resC,riskC,blk) $ HVDCsecRisk(riskC)
 842       , ScarcityResrvIslandPrice(t,isl,resC,blk)
 843       * RESERVESHORTFALLBLK(t,isl,resC,riskC,blk) ]
 844   
 845  +  sum[ (isl,rg,resC,riskC,blk) $ GenRisk(riskC)
 846       , ScarcityResrvIslandPrice(t,isl,resC,blk)
 847       * RESERVESHORTFALLGROUPBLK(t,isl,rg,resC,riskC,blk) ]
 848  ;
 849   
 850   
 851  *======= GENERATION AND LOAD CONSTRAINTS =======================================
 852   
 853  * Calculate the MW of generation increase/decrease for RTD and RTDP (6.1.1.2)'
 854  GenerationChangeUpDown(t,o) $ { (StudyMode(t) = 101) or (StudyMode(t) = 201) }..
 855    GENERATIONUPDELTA(t,o) - GENERATIONDNDELTA(t,o)
 856  =e=
 857    GENERATION(t,o) - generationStart(t,o);
 858   
 859  * Definition of generation provided by an offer (6.1.1.3)
 860  GenerationOfferDefintion(offer(t,o))..
 861    GENERATION(offer)
 862  =e=
 863    sum[ genOfrBlk(offer,blk), GENERATIONBLOCK(offer,blk) ]
 864    ;
 865   
 866  * Definition of discrete purchase mode (6.1.1.7)
 867  DemBidDiscrete(bid(t,bd),blk) $ { bidParameter(bid,'discrete') = 1 }..
 868    PURCHASEBLOCK(bid,blk)
 869  =e=
 870    PURCHASEBLOCKBINARY(bid,blk) * demBidMW(bid,blk)
 871    ;
 872   
 873  * Definition of purchase provided by a bid (6.1.1.8)
 874  DemBidDefintion(bid(t,bd))..
 875    PURCHASE(bid)
 876  =e=
 877    sum[ demBidBlk(bid,blk), PURCHASEBLOCK(bid,blk) ]
 878    ;
 879   
 880  * Definition of bus energy scarcity (6.1.1.10)
 881  EnergyScarcityDefinition(t,n)..
 882    ENERGYSCARCITYNODE(t,n)
 883  =e=
 884    sum[ blk, ENERGYSCARCITYBLK(t,n,blk) ]
 885    ;
 886   
 887  *======= GENERATION AND LOAD CONSTRAINTS END ===================================
 888   
 889   
 890   
 891  *======= RAMPING CONSTRAINTS ===================================================
 892  * Note: The CoefficientForRampRate in SPD formulation  = intervalDuration / 60
 893   
 894  * Maximum movement of the generator downwards due to up ramp rate (6.2.1.1)
 895  GenerationRampUp(t,o) $ { posEnrgOfr(t,o) and primaryOffer(t,o) }..
 896    sum[ o1 $ PrimarySecondaryOffer(t,o,o1), GENERATION(t,o1) ]
 897  + GENERATION(t,o) - DEFICITRAMPRATE(t,o)
 898  =l=
 899    generationStart(t,o) + (rampRateUp(t,o) * intervalDuration(t) / 60)
 900    ;
 901   
 902  * Maximum movement of the generator downwards due to down ramp rate (6.2.1.2)
 903  GenerationRampDown(t,o) $ { posEnrgOfr(t,o) and primaryOffer(t,o) }..
 904    sum[ o1 $ PrimarySecondaryOffer(t,o,o1), GENERATION(t,o1) ]
 905  + GENERATION(t,o) + SURPLUSRAMPRATE(t,o)
 906  =g=
 907    generationStart(t,o) - (rampRateDn(t,o) * intervalDuration(t) / 60)
 908    ;
 909   
 910  *======= RAMPING CONSTRAINTS END================================================
 911   
 912   
 913  *======= HVDC TRANSMISSION EQUATIONS ===========================================
 914   
 915  * Maximum flow on each HVDC link (6.3.1.1)
 916  HVDClinkMaximumFlow(HVDClink(t,br)) $ useHVDCbranchLimits ..
 917    HVDCLINKFLOW(HVDClink)
 918  =l=
 919    sum[ fd $ ( ord(fd)=1 ), branchCapacity(HVDClink,fd) ]
 920    ;
 921   
 922  * Definition of losses on the HVDC link (6.3.1.2)
 923  HVDClinkLossDefinition(HVDClink(t,br))..
 924    HVDCLINKLOSSES(HVDClink)
 925  =e=
 926    sum[ validLossSegment(HVDClink,bp,fd)
 927       , HVDCBreakPointMWLoss(HVDClink,bp,fd) * LAMBDA(HVDClink,bp) ]
 928    ;
 929   
 930  * Definition of MW flow on the HVDC link (6.3.1.3)
 931  HVDClinkFlowDefinition(HVDClink(t,br))..
 932    HVDCLINKFLOW(HVDClink)
 933  =e=
 934    sum[ validLossSegment(HVDClink,bp,fd)
 935    , HVDCBreakPointMWFlow(HVDClink,bp,fd) * LAMBDA(HVDClink,bp) ]
 936    ;
 937   
 938  * Definition of weighting factor (6.3.1.4)
 939  LambdaDefinition(HVDClink(t,br))..
 940    sum(validLossSegment(HVDClink,bp,fd), LAMBDA(HVDClink,bp))
 941  =e=
 942    1
 943    ;
 944   
 945   
 946  *======= HVDC TRANSMISSION EQUATIONS END =======================================
 947   
 948   
 949   
 950  *======= HVDC TRANSMISSION EQUATIONS FOR SOS1 VARIABLES ========================
 951  * HVDC transmission constraints to resolve non-physical loss and circular flow
 952  * These constraints are not explicitly formulated in SPD formulation
 953  * But you can find the description in "Post-Solve Checks
 954   
 955  * Definition 1 of the integer HVDC link flow variable
 956  * HVDC_North_Flow + HVDC_South_Flow
 957  * = BEN_HAY_1_Flow + BEN_HAY_2_Flow + HAY_BEN_1_Flow + HAY_BEN_2_Flow
 958  HVDClinkFlowIntegerDefinition1(t) $ { UseBranchFlowMIP(t) and
 959                                        resolveCircularBranchFlows }..
 960    sum[ fd, HVDCLINKFLOWDIRECTED_INTEGER(t,fd) ]
 961  =e=
 962    sum[ HVDCpoleDirection(HVDClink(t,br),fd), HVDCLINKFLOW(HVDClink) ]
 963    ;
 964   
 965  * Definition 2 of the integer HVDC link flow variable
 966  * HVDC_North_Flow = BEN_HAY_1_Flow + BEN_HAY_2_Flow
 967  * HVDC_South_Flow = HAY_BEN_1_Flow + HAY_BEN_2_Flow
 968  HVDClinkFlowIntegerDefinition2(t,fd) $ { UseBranchFlowMIP(t) and
 969                                           resolveCircularBranchFlows }..
 970    HVDCLINKFLOWDIRECTED_INTEGER(t,fd)
 971  =e=
 972    sum[ HVDCpoleDirection(HVDClink(t,br),fd), HVDCLINKFLOW(HVDClink) ]
 973    ;
 974   
 975  * Definition of the integer HVDC pole flow variable for intra-pole circulating branch flows
 976  * Pole1_North_Flow + Pole1_South_Flow = BEN_HAY_1_Flow + HAY_BEN_1_Flow
 977  * Pole2_North_Flow + Pole2_South_Flow = BEN_HAY_2_Flow + HAY_BEN_2_Flow
 978  HVDClinkFlowIntegerDefinition3(t,pole) $ { UseBranchFlowMIP(t) and
 979                                             resolveCircularBranchFlows }..
 980    sum[ br $ { HVDClink(t,br)
 981            and HVDCpoleBranchMap(pole,br) } , HVDCLINKFLOW(t,br) ]
 982  =e=
 983    sum[ fd, HVDCPOLEFLOW_INTEGER(t,pole,fd) ]
 984    ;
 985   
 986  * Definition of the integer HVDC pole flow variable for intra-pole circulating branch flows
 987  * Pole1_North_Flow = BEN_HAY_1_Flow + HAY_BEN_1_Flow
 988  * Pole1_South_Flow = BEN_HAY_1_Flow + HAY_BEN_1_Flow
 989  * Pole2_North_Flow = BEN_HAY_2_Flow + HAY_BEN_2_Flow
 990  * Pole2_South_Flow = BEN_HAY_2_Flow + HAY_BEN_2_Flow
 991   
 992  HVDClinkFlowIntegerDefinition4(t,pole,fd) $ { UseBranchFlowMIP(t) and
 993                                                resolveCircularBranchFlows }..
 994    sum[ HVDCpoleDirection(HVDClink(t,br),fd) $ HVDCpoleBranchMap(pole,br)
 995       , HVDCLINKFLOW(HVDClink) ]
 996  =e=
 997    HVDCPOLEFLOW_INTEGER(t,pole,fd)
 998    ;
 999   
1000  *======= HVDC TRANSMISSION EQUATIONS FOR SOS1 VARIABLES END ====================
1001   
1002   
1003  *======= HVDC TRANSMISSION EQUATIONS FOR SOS2 VARIABLES ========================
1004  * Definition 1 of weighting factor when branch integer constraints are needed
1005  LambdaIntegerDefinition1(HVDClink(t,br)) $ { UseBranchFlowMIP(t) and
1006                                               resolveHVDCnonPhysicalLosses }..
1007    sum[ validLossSegment(HVDClink,bp,fd), LAMBDAINTEGER(HVDClink,bp) ]
1008  =e=
1009    1
1010    ;
1011   
1012  * Definition 2 of weighting factor when branch integer constraints are needed
1013  LambdaIntegerDefinition2(HVDClink(t,br),bp)
1014    $ { UseBranchFlowMIP(t) and resolveHVDCnonPhysicalLosses
1015    and sum[ fd $ validLossSegment(HVDClink,bp,fd), 1] }..
1016    LAMBDAINTEGER(HVDClink,bp)
1017  =e=
1018    LAMBDA(HVDClink,bp)
1019    ;
1020   
1021  *======= HVDC TRANSMISSION EQUATIONS END =======================================
1022   
1023   
1024   
1025   
1026  *======= AC TRANSMISSION EQUATIONS =============================================
1027   
1028  * 1st definition of the net injection at buses corresponding to AC nodes (6.4.1.1)
1029  ACnodeNetInjectionDefinition1(bus(t,b))..
1030    ACNODENETINJECTION(t,b)
1031  =e=
1032    sum[ ACBranchSendingBus(ACBranch(t,br),b,fd)
1033       , ACBRANCHFLOWDIRECTED(ACBranch,fd)
1034       ]
1035  - sum[ ACBranchReceivingBus(ACBranch(t,br),b,fd)
1036       , ACBRANCHFLOWDIRECTED(ACBranch,fd)
1037       ]
1038    ;
1039   
1040  * 2nd definition of the net injection at buses corresponding to AC nodes (6.4.1.2)
1041  ACnodeNetInjectionDefinition2(bus(t,b))..
1042    ACNODENETINJECTION(t,b)
1043  =e=
1044    sum[ offerNode(t,o,n) $ NodeBus(t,n,b)
1045       , nodeBusAllocationFactor(t,n,b) * GENERATION(t,o) ]
1046  - sum[ BidNode(t,bd,n) $ NodeBus(t,n,b)
1047       , NodeBusAllocationFactor(t,n,b) * PURCHASE(t,bd) ]
1048  - sum[ NodeBus(t,n,b)
1049       , NodeBusAllocationFactor(t,n,b) * requiredLoad(t,n) ]
1050  + sum[ HVDClinkReceivingBus(HVDClink(t,br),b), HVDCLINKFLOW(HVDClink)   ]
1051  - sum[ HVDClinkReceivingBus(HVDClink(t,br),b), HVDCLINKLOSSES(HVDClink) ]
1052  - sum[ HVDClinkSendingBus(HVDClink(t,br),b)  , HVDCLINKFLOW(HVDClink)   ]
1053  - sum[ HVDClinkBus(HVDClink(t,br),b),   0.5 * branchFixedLoss(HVDClink) ]
1054  - sum[ ACBranchReceivingBus(ACBranch(t,br),b,fd)
1055       , branchReceivingEndLossProportion
1056       * ACBRANCHLOSSESDIRECTED(ACBranch,fd) ]
1057  - sum[ ACBranchSendingBus(ACBranch(t,br),b,fd)
1058       , (1 - branchReceivingEndLossProportion)
1059       * ACBRANCHLOSSESDIRECTED(ACBranch,fd) ]
1060  - sum[ BranchBusConnect(ACBranch(t,br),b), 0.5*branchFixedLoss(ACBranch) ]
1061  + DEFICITBUSGENERATION(t,b) - SURPLUSBUSGENERATION(t,b)
1062  * Note that we model energy scarcity as penalty instead of benefit like SPD
1063  * The reason for this is to avoid numerical issues.
1064  + sum[ NodeBus(t,n,b)
1065       , NodeBusAllocationFactor(t,n,b) * ENERGYSCARCITYNODE(t,n)]
1066    ;
1067   
1068  * Maximum flow on the AC branch (6.4.1.3)
1069  ACBranchMaximumFlow(ACbranch(t,br),fd) $ useACbranchLimits..
1070    ACBRANCHFLOWDIRECTED(ACBranch,fd) - SURPLUSBRANCHFLOW(ACBranch)
1071  =l=
1072    branchCapacity(ACBranch,fd)
1073    ;
1074   
1075  * Relationship between directed and undirected branch flow variables (6.4.1.4)
1076  ACBranchFlowDefinition(ACBranch(t,br))..
1077    ACBRANCHFLOW(ACBranch)
1078  =e=
1079    sum[ fd $ (ord(fd) = 1), ACBRANCHFLOWDIRECTED(ACBranch,fd) ]
1080  - sum[ fd $ (ord(fd) = 2), ACBRANCHFLOWDIRECTED(ACBranch,fd) ]
1081    ;
1082   
1083  * Equation that describes the linear load flow (6.4.1.5)
1084  LinearLoadFlow(ACBranch(t,br))..
1085    ACBRANCHFLOW(ACBranch)
1086  =e=
1087    branchSusceptance(ACBranch)
1088    * sum[ BranchBusDefn(ACBranch,frB,toB)
1089         , ACNODEANGLE(t,frB) - ACNODEANGLE(t,toB) ]
1090    ;
1091   
1092  * Limit on each AC branch flow block (6.4.1.6)
1093  ACBranchBlockLimit(validLossSegment(ACBranch(t,br),los,fd))..
1094    ACBRANCHFLOWBLOCKDIRECTED(ACBranch,los,fd)
1095  =l=
1096    ACBranchLossMW(ACBranch,los,fd)
1097    ;
1098   
1099  * Composition of the directed branch flow from the block branch flow (6.4.1.7)
1100  ACDirectedBranchFlowDefinition(ACBranch(t,br),fd)..
1101    ACBRANCHFLOWDIRECTED(ACBranch,fd)
1102  =e=
1103    sum[ validLossSegment(ACBranch,los,fd)
1104       , ACBRANCHFLOWBLOCKDIRECTED(ACBranch,los,fd) ]
1105    ;
1106   
1107  * Calculation of the losses in each loss segment (6.4.1.8) - Modified for BranchcReverseRatings
1108  ACBranchLossCalculation(validLossSegment(ACBranch(t,br),los,fd))..
1109    ACBRANCHLOSSESBLOCKDIRECTED(ACBranch,los,fd)
1110  =e=
1111    ACBRANCHFLOWBLOCKDIRECTED(ACBranch,los,fd)
1112    * ACBranchLossFactor(ACBranch,los,fd)
1113    ;
1114   
1115  * Composition of the directed branch losses from the block branch losses (6.4.1.9)
1116  ACDirectedBranchLossDefinition(ACBranch(t,br),fd)..
1117    ACBRANCHLOSSESDIRECTED(ACBranch,fd)
1118  =e=
1119    sum[ validLossSegment(ACBranch,los,fd)
1120       , ACBRANCHLOSSESBLOCKDIRECTED(ACBranch,los,fd) ]
1121    ;
1122   
1123  *======= AC TRANSMISSION EQUATIONS END =========================================
1124   
1125   
1126   
1127  *======= AC TRANSMISSION EQUATIONS FOR SOS1 VARIABLES ==========================
1128  * AC transmission constraints to resolve circular flow
1129  * These constraints are not explicitly formulated in SPD formulation
1130  * But you can find the description in "Post-Solve Checks"
1131   
1132  * Integer constraint to enforce a flow direction on loss AC branches in the
1133  * presence of circular branch flows or non-physical losses
1134  ACDirectedBranchFlowIntegerDefinition1(ACBranch(lossBranch(t,br)))
1135    $ { UseBranchFlowMIP(t) and resolveCircularBranchFlows }..
1136    sum[ fd, ACBRANCHFLOWDIRECTED_INTEGER(ACBranch,fd) ]
1137  =e=
1138    sum[ fd, ACBRANCHFLOWDIRECTED(ACBranch,fd) ]
1139    ;
1140   
1141  * Integer constraint to enforce a flow direction on loss AC branches in the
1142  * presence of circular branch flows or non-physical losses
1143  ACDirectedBranchFlowIntegerDefinition2(ACBranch(lossBranch(t,br)),fd)
1144    $ { UseBranchFlowMIP(t) and resolveCircularBranchFlows }..
1145    ACBRANCHFLOWDIRECTED_INTEGER(ACBranch,fd)
1146  =e=
1147    ACBRANCHFLOWDIRECTED(ACBranch,fd)
1148    ;
1149   
1150  *======= AC TRANSMISSION EQUATIONS FOR SOS1 VARIABLES END ======================
1151   
1152   
1153   
1154  *======= RISK EQUATIONS ========================================================
1155   
1156  * 6.5.1.1 : Calculation of the risk offset variable for the DCCE risk class.
1157  RiskOffsetCalculation_DCCE(t,isl,resC,riskC)
1158    $ { HVDCrisk(riskC) and ContingentEvents(riskC)  }..
1159    RISKOFFSET(t,isl,resC,riskC)
1160  =e=
1161    FreeReserve(t,isl,resC,riskC) + HVDCPoleRampUp(t,isl,resC,riskC)
1162    ;
1163   
1164  * 6.5.1.3 : Calculation of the risk offset variable for the DCECE risk class.
1165  RiskOffsetCalculation_DCECE(t,isl,resC,riskC)
1166    $ { HVDCrisk(riskC) and ExtendedContingentEvent(riskC) }..
1167    RISKOFFSET(t,isl,resC,riskC)
1168  =e=
1169    FreeReserve(t,isl,resC,riskC)
1170    ;
1171   
1172  * 6.5.1.4 : Calculation of the net received HVDC MW flow into an island.
1173  HVDCRecCalculation(t,isl)..
1174    HVDCREC(t,isl)
1175  =e=
1176    sum[ (b,br) $ { BusIsland(t,b,isl)
1177                and HVDClinkSendingBus(t,br,b)
1178                and HVDCLink(t,br)
1179                  }, -HVDCLINKFLOW(t,br)
1180       ]
1181  + sum[ (b,br) $ { BusIsland(t,b,isl)
1182                and HVDClinkReceivingBus(t,br,b)
1183                and HVDCLink(t,br)
1184                  }, HVDCLINKFLOW(t,br) - HVDCLINKLOSSES(t,br)
1185       ]
1186    ;
1187   
1188  * 6.5.1.5 : Calculation of the island risk for a DCCE and DCECE.
1189  HVDCIslandRiskCalculation(t,isl,resC,HVDCrisk)..
1190    ISLANDRISK(t,isl,resC,HVDCrisk)
1191  =e=
1192    riskAdjFactor(t,isl,resC,HVDCrisk)
1193    * [ HVDCREC(t,isl)
1194      - RISKOFFSET(t,isl,resC,HVDCrisk)
1195      + modulationRiskClass(t,HVDCrisk)
1196      ]
1197  * Scarcity reserve (only applied for CE risk)
1198    - RESERVESHORTFALL(t,isl,resC,HVDCrisk) $ ContingentEvents(HVDCrisk)
1199    ;
1200   
1201  * 6.5.1.6 : Calculation of the risk of risk setting generators
1202  GenIslandRiskCalculation_1(t,isl,o,resC,GenRisk)
1203    $ islandRiskGenerator(t,isl,o) ..
1204    GENISLANDRISK(t,isl,o,resC,GenRisk)
1205  =e=
1206    riskAdjFactor(t,isl,resC,GenRisk)
1207    * [ GENERATION(t,o)
1208      - FreeReserve(t,isl,resC,GenRisk)
1209      + FKBand(t,o)
1210      + sum[ resT, RESERVE(t,o,resC,resT) ]
1211      + sum[ o1 $ PrimarySecondaryOffer(t,o,o1)
1212           , sum[ resT, RESERVE(t,o1,resC,resT) ] + GENERATION(t,o1) ]
1213      ]
1214  * NMIR update
1215  - RESERVESHAREEFFECTIVE(t,isl,resC,GenRisk)$reserveShareEnabled(t,resC)
1216  * Scarcity reserve (only applied for CE risk)
1217  - RESERVESHORTFALLUNIT(t,isl,o,resC,GenRisk) $ ContingentEvents(GenRisk)
1218    ;
1219   
1220  * 6.5.1.6 : Calculation of the island risk for risk setting generators
1221  GenIslandRiskCalculation(t,isl,o,resC,GenRisk)
1222    $ islandRiskGenerator(t,isl,o) ..
1223    ISLANDRISK(t,isl,resC,GenRisk)
1224  =g=
1225    GENISLANDRISK(t,isl,o,resC,GenRisk) ;
1226   
1227  * 6.5.1.7 : Calculation of the island risk based on manual specifications
1228  ManualIslandRiskCalculation(t,isl,resC,ManualRisk)..
1229    ISLANDRISK(t,isl,resC,ManualRisk)
1230  =e=
1231    riskAdjFactor(t,isl,resC,ManualRisk)
1232    * [ riskParameter(t,isl,resC,ManualRisk,'minRisk')
1233      - FreeReserve(t,isl,resC,ManualRisk)
1234      ]
1235  * NMIR update
1236  - RESERVESHAREEFFECTIVE(t,isl,resC,ManualRisk)$reserveShareEnabled(t,resC)
1237  * Scarcity reserve (only applied for CE risk)
1238  - RESERVESHORTFALL(t,isl,resC,ManualRisk) $ ContingentEvents(ManualRisk)
1239    ;
1240   
1241  * 6.5.1.8: Define a flag to show if HVDC sending zero MW flow from an island
1242  HVDCSendMustZeroBinaryDefinition(t,isl).. HVDCSENT(t,isl) =l= BigM * [ 1 - HVDCSENDZERO(t,isl) ] ;
1243   
1244   
1245  * 6.5.1.9 : Calculation of the island risk for an HVDC secondary generation risk
1246  * HVDC secondary risk includes HVDC risk and Generation of both primary and secondary generation unit + cleared reserve + the FKBand for generator primary risk
1247  HVDCIslandSecRiskCalculation_GEN_1(t,isl,o,resC,HVDCSecRisk)
1248    $ { islandRiskGenerator(t,isl,o)  and
1249        HVDCSecRiskEnabled(t,isl,HVDCSecRisk) }..
1250    HVDCGENISLANDRISK(t,isl,o,resC,HVDCSecRisk)
1251  =e=
1252    riskAdjFactor(t,isl,resC,HVDCSecRisk)
1253    * [ GENERATION(t,o)
1254      - FreeReserve(t,isl,resC,HVDCSecRisk)
1255      + HVDCREC(t,isl)
1256      - islandParameter(t,isl,'HVDCSecSubtractor')
1257      + FKBand(t,o)
1258      + sum[ resT, RESERVE(t,o,resC,resT) ]
1259      + sum[ o1 $ PrimarySecondaryOffer(t,o,o1)
1260           , sum[ resT, RESERVE(t,o1,resC,resT) ] + GENERATION(t,o1) ]
1261      + modulationRiskClass(t,HVDCSecRisk)
1262      ]
1263  * Scarcity reserve (only applied for CE risk)
1264    - RESERVESHORTFALLUNIT(t,isl,o,resC,HVDCSecRisk) $ ContingentEvents(HVDCSecRisk)
1265  * HVDC secondary risk not applied if HVDC sent is zero
1266    - BigM * sum[ isl1 $ (not sameas(isl1,isl)), HVDCSENDZERO(t,isl) ]
1267    ;
1268   
1269  * 6.5.1.9 : Calculation of the island risk for an HVDC secondary generation risk
1270  HVDCIslandSecRiskCalculation_GEN(t,isl,o,resC,HVDCSecRisk)
1271    $ { islandRiskGenerator(t,isl,o)  and
1272        HVDCSecRiskEnabled(t,isl,HVDCSecRisk) }..
1273    ISLANDRISK(t,isl,resC,HVDCSecRisk)
1274  =g=
1275    HVDCGENISLANDRISK(t,isl,o,resC,HVDCSecRisk)
1276    ;
1277   
1278  * 6.5.1.10: Calculation of the island risk for an HVDC secondary manual risk
1279  HVDCIslandSecRiskCalculation_Manu_1(t,isl,resC,HVDCSecRisk)
1280    $ HVDCSecRiskEnabled(t,isl,HVDCSecRisk)..
1281    HVDCMANISLANDRISK(t,isl,resC,HVDCSecRisk)
1282  =e=
1283    riskAdjFactor(t,isl,resC,HVDCSecRisk)
1284    * [ riskParameter(t,isl,resC,HVDCSecRisk,'minRisk')
1285      - FreeReserve(t,isl,resC,HVDCSecRisk)
1286      + HVDCREC(t,isl)
1287      - islandParameter(t,isl,'HVDCSecSubtractor')
1288      + modulationRiskClass(t,HVDCSecRisk)
1289      ]
1290  * Scarcity reserve (only applied for CE risk)
1291    - RESERVESHORTFALL(t,isl,resC,HVDCSecRisk) $ ContingentEvents(HVDCSecRisk)
1292  * HVDC secondary risk not applied if HVDC sent is zero
1293    - BigM * sum[ isl1 $ (not sameas(isl1,isl)), HVDCSENDZERO(t,isl) ]
1294    ;
1295   
1296  * 6.5.1.10: Calculation of the island risk for an HVDC secondary manual risk
1297  HVDCIslandSecRiskCalculation_Manual(t,isl,resC,HVDCSecRisk)
1298    $ HVDCSecRiskEnabled(t,isl,HVDCSecRisk)..
1299    ISLANDRISK(t,isl,resC,HVDCSecRisk)
1300  =g=
1301    HVDCMANISLANDRISK(t,isl,resC,HVDCSecRisk)
1302    ;
1303   
1304  * 6.5.1.11: Calculation of the risk of risk group
1305  GenIslandRiskGroupCalculation_1(t,isl,rg,resC,GenRisk)
1306    $ islandRiskGroup(t,isl,rg,GenRisk)..
1307    GENISLANDRISKGROUP(t,isl,rg,resC,GenRisk)
1308  =e=
1309    riskAdjFactor(t,isl,resC,GenRisk)
1310    * [ sum[ o $ { offerIsland(t,o,isl)
1311               and riskGroupOffer(t,rg,o,GenRisk)
1312                 } , GENERATION(t,o) + FKBand(t,o)
1313                   + sum[ resT, RESERVE(t,o,resC,resT) ]
1314           ]
1315      - FreeReserve(t,isl,resC,GenRisk)
1316      ]
1317  * NMIR update
1318  - RESERVESHAREEFFECTIVE(t,isl,resC,GenRisk)$reserveShareEnabled(t,resC)
1319  * Scarcity reserve (only applied for CE risk)
1320  - RESERVESHORTFALLGROUP(t,isl,rg,resC,GenRisk) $ ContingentEvents(GenRisk)
1321    ;
1322   
1323  * 6.5.1.11: Calculation of the island risk for risk group
1324  GenIslandRiskGroupCalculation(t,isl,rg,resC,GenRisk)
1325    $ islandRiskGroup(t,isl,rg,GenRisk)..
1326    ISLANDRISK(t,isl,resC,GenRisk)
1327  =g=
1328    GENISLANDRISKGROUP(t,isl,rg,resC,GenRisk)
1329    ;
1330   
1331  *======= RISK EQUATIONS END ====================================================
1332   
1333   
1334  *======= NMIR - RESERVE SHARING EQUATIONS ======================================
1335   
1336  * General NMIR equations start -------------------------------------------------
1337   
1338  * Calculation of effective shared reserve - (6.5.2.1)
1339  EffectiveReserveShareCalculation(t,isl,resC,riskC)
1340    $ { reserveShareEnabled(t,resC)
1341    and ( GenRisk(riskC) or ManualRisk(riskC) ) }..
1342    RESERVESHAREEFFECTIVE(t,isl,resC,riskC)
1343  =l=
1344    Sum[ rd , RESERVESHARERECEIVED(t,isl,resC,rd)
1345            * effectiveFactor(t,isl,resC,riskC) ]
1346    ;
1347   
1348  * Shared offered reserve is limited by cleared reserved - (6.5.2.2)
1349  SharedReserveLimitByClearedReserve(t,isl,resC)
1350    $ reserveShareEnabled(t,resC)..
1351    SHAREDRESERVE(t,isl,resC)
1352  =l=
1353    ISLANDRESERVE(t,isl,resC)
1354    ;
1355   
1356  * Both cleared reserved and shareable free reserve can be shared - (6.5.2.4)
1357  BothClearedAndFreeReserveCanBeShared(t,isl,resC,rd)
1358    $ reserveShareEnabled(t,resC)..
1359    RESERVESHARESENT(t,isl,resC,rd)
1360  =l=
1361    SHAREDRESERVE(t,isl,resC) + SHAREDNFR(t,isl)$(ord(resC)=1)
1362    ;
1363   
1364  * Reserve share sent is limited by HVDC control band - (6.5.2.5)
1365  ReserveShareSentLimitByHVDCControlBand(t,isl,resC,rd)
1366    $ reserveShareEnabled(t,resC)..
1367    RESERVESHARESENT(t,isl,resC,rd)
1368  =l=
1369    [ HVDCControlBand(t,rd) - modulationRisk(t)
1370    ] $ (HVDCControlBand(t,rd) > modulationRisk(t))
1371    ;
1372   
1373  * Forward reserve share sent is limited by HVDC capacity - (6.5.2.6)
1374  FwdReserveShareSentLimitByHVDCCapacity(t,isl,resC,rd)
1375    $ { reserveShareEnabled(t,resC) and (ord(rd) = 1) }..
1376    RESERVESHARESENT(t,isl,resC,rd)
1377  + HVDCSENT(t,isl)
1378  =l=
1379    [ HVDCMax(t,isl) - modulationRisk(t) ] $ (HVDCMax(t,isl) > modulationRisk(t))
1380  ;
1381   
1382  * Reverse shared reserve is only possible for receiving island - (6.5.2.7)
1383  ReverseReserveOnlyToEnergySendingIsland(t,isl,resC,rd)
1384    $ { reserveShareEnabled(t,resC) and (ord(rd) = 2) }..
1385    RESERVESHARESENT(t,isl,resC,rd)
1386  =l=
1387    BigM * [ 1 - HVDCSENDING(t,isl) ]
1388    ;
1389   
1390  * Reverse shared reserve recieved at an island is limited by HVDC control band - (6.5.2.8)
1391  ReverseReserveShareLimitByHVDCControlBand(t,isl,resC,rd)
1392    $ { reserveShareEnabled(t,resC) and (ord(rd) = 2) }..
1393    RESERVESHARERECEIVED(t,isl,resC,rd)
1394  =l=
1395    HVDCSENDING(t,isl) * [ HVDCControlBand(t,rd) - modulationRisk(t)
1396                         ] $ ( HVDCControlBand(t,rd) > modulationRisk(t) )
1397    ;
1398   
1399  * Forward received shared reserve only possible for receiving island - (3.4.2.9)
1400  ForwardReserveOnlyToEnergyReceivingIsland(t,isl,resC,rd)
1401    $ { reserveShareEnabled(t,resC) and (ord(rd) = 1) }..
1402    RESERVESHARERECEIVED(t,isl,resC,rd)
1403  =l=
1404    BigM * [ 1 - HVDCSENDING(t,isl) ]
1405    ;
1406   
1407  * Reverse shared reserve limit if HVDC sent flow in reverse zone - (6.5.2.10)
1408  ReverseReserveLimitInReserveZone(t,isl,resC,rd,z)
1409    $ { reserveShareEnabled(t,resC) and (ord(rd) = 2) and (ord(z) = 3) }..
1410    RESERVESHARERECEIVED(t,isl,resC,rd)
1411  =l=
1412    HVDCSENT(t,isl)
1413  - (monopoleMinimum(t) + modulationRisk(t))
1414  + BigM * [ 1 - INZONE(t,isl,resC,z) ]
1415    ;
1416   
1417  * No reverse shared reserve if HVDC sent flow in no reverse zone &
1418  * No forward reserve if HVDC sent flow in no reverse zone and RP disabled
1419  * (6.5.2.11) & (6.5.2.18)
1420  ZeroReserveInNoReserveZone(t,isl,resC,z)
1421    $ { reserveShareEnabled(t,resC) and (ord(z) = 2) }..
1422    Sum[ rd $ (ord(rd) = 2), RESERVESHARERECEIVED(t,isl,resC,rd) ]
1423  + Sum[ rd $ (ord(rd) = 1), RESERVESHARESENT(t,isl,resC,rd)
1424       ] $ {reserveRoundPower(t,resC) = 0}
1425  =l=
1426    BigM * [ 1 - INZONE(t,isl,resC,z) ]
1427    ;
1428   
1429  * Across both island, only one zone is active for each reserve class -(6.5.2.12)
1430  OnlyOneActiveHVDCZoneForEachReserveClass(t,resC) $ reserveShareEnabled(t,resC)..
1431    Sum[ (isl,z), INZONE(t,isl,resC,z) ] =e= 1 ;
1432   
1433  * HVDC sent from sending island only - (6.5.2.13)
1434  ZeroSentHVDCFlowForNonSendingIsland(t,isl) $ reserveShareEnabledOverall(t)..
1435    HVDCSENT(t,isl) =l= BigM * HVDCSENDING(t,isl) ;
1436   
1437  * HVDC sent from an island <= RoundPowerZoneExit level if in round power zone
1438  * of that island - (6.5.2.14)
1439  RoundPowerZoneSentHVDCUpperLimit(t,isl,resC,z)
1440    $ { reserveShareEnabled(t,resC) and (ord(z) = 1) }..
1441    HVDCSENT(t,isl)
1442  =l=
1443    roPwrZoneExit(t,resC) + BigM * [ 1 - INZONE(t,isl,resC,z) ]
1444  ;
1445   
1446  * An island is HVDC sending island if HVDC flow sent is in one of the three
1447  * zones for each reserve class - (6.5.2.15)
1448  HVDCSendingIslandDefinition(t,isl,resC) $ reserveShareEnabled(t,resC)..
1449    HVDCSENDING(t,isl) =e= Sum[ z, INZONE(t,isl,resC,z) ] ;
1450   
1451  * One and only one island is HVDC sending island - (6.5.2.19)
1452  OnlyOneSendingIslandExists(t) $ reserveShareEnabledOverall(t)..
1453   Sum[ isl, HVDCSENDING(t,isl) ] =e= 1 ;
1454   
1455  * Total HVDC sent from each island - (6.5.2.20)
1456  HVDCSentCalculation(t,isl) $ reserveShareEnabledOverall(t)..
1457    HVDCSENT(t,isl)
1458  =e=
1459    Sum[ (b,br) $ { BusIsland(t,b,isl)
1460                and HVDClinkSendingBus(t,br,b)
1461                and HVDClink(t,br)
1462                  }, HVDCLINKFLOW(t,br)
1463       ]
1464  ;
1465   
1466  * General NMIR equations end ---------------------------------------------------
1467   
1468   
1469  * Lamda loss model -------------------------------------------------------------
1470   
1471  * HVDC flow + forward reserve sent from an island - (6.5.2.21)
1472  HVDCFlowAccountedForForwardReserve(t,isl,resC,rd)
1473    $ { reserveShareEnabled(t,resC) and (ord(rd) = 1) }..
1474    HVDCRESERVESENT(t,isl,resC,rd)
1475  =e=
1476    RESERVESHARESENT(t,isl,resC,rd) + HVDCSENT(t,isl)
1477    ;
1478   
1479  * Received forward shared reserve at an HVDC receiving island - (6.5.2.22)
1480  ForwardReserveReceivedAtHVDCReceivingIsland(t,isl,resC,rd)
1481    $ { reserveShareEnabled(t,resC) and (ord(rd) = 1) }..
1482    RESERVESHARERECEIVED(t,isl,resC,rd)
1483  =e=
1484    Sum[ isl1 $ (not sameas(isl1,isl))
1485        , RESERVESHARESENT(t,isl1,resC,rd)
1486        - HVDCRESERVELOSS(t,isl1,resC,rd)
1487        + HVDCSENTLOSS(t,isl1) ]
1488    ;
1489   
1490  * HVDC flow - received reverse reserve sent from an island - (6.5.2.23)
1491  HVDCFlowAccountedForReverseReserve(t,isl,resC,rd)
1492    $ { reserveShareEnabled(t,resC) and (ord(rd) = 2) }..
1493    HVDCRESERVESENT(t,isl,resC,rd)
1494  =e=
1495    HVDCSENT(t,isl) - RESERVESHARERECEIVED(t,isl,resC,rd)
1496    ;
1497   
1498  * Reverse reserve RECEIVED at an HVDC sending island - (6.5.2.24)
1499  ReverseReserveReceivedAtHVDCSendingIsland(t,isl,resC,rd)
1500    $ { reserveShareEnabled(t,resC) and (ord(rd) = 2) }..
1501    RESERVESHARERECEIVED(t,isl,resC,rd)
1502  =e=
1503    Sum[ isl1 $ (not sameas(isl1,isl)), RESERVESHARESENT(t,isl1,resC,rd) ]
1504  - HVDCRESERVELOSS(t,isl,resC,rd)
1505  + HVDCSENTLOSS(t,isl)
1506    ;
1507   
1508  * Total weight factor = 1 for HVDC energy sent from an island - (6.5.2.25)
1509  HVDCSentEnergyLambdaDefinition(t,isl) $ reserveShareEnabledOverall(t)..
1510    Sum[ bp $ (ord(bp) <= 7),LAMBDAHVDCENERGY(t,isl,bp) ] =e= 1 ;
1511   
1512  * Lambda definition of total HVDC energy flow sent from an island
1513  * (6.5.2.26) - SPD version 11.0
1514  HVDCSentEnergyFlowDefinition(t,isl) $ reserveShareEnabledOverall(t)..
1515    HVDCSENT(t,isl)
1516  =e=
1517    Sum[ bp $ (ord(bp) <= 7), HVDCSentBreakPointMWFlow(t,isl,bp)
1518                            * LAMBDAHVDCENERGY(t,isl,bp) ]
1519    ;
1520   
1521  * Lambda definition of total loss of HVDC energy sent from an island
1522  * (6.5.2.27) - SPD version 11.0
1523  HVDCSentEnergyLossesDefinition(t,isl) $ reserveShareEnabledOverall(t)..
1524    HVDCSENTLOSS(t,isl)
1525  =e=
1526    Sum[ bp $ (ord(bp) <= 7), HVDCSentBreakPointMWLoss(t,isl,bp)
1527                            * LAMBDAHVDCENERGY(t,isl,bp) ]
1528    ;
1529   
1530  * Total weight factor = 1 for HVDC+reserve sent from an island -(6.5.2.28)
1531  HVDCSentReserveLambdaDefinition(t,isl,resC,rd) $ reserveShareEnabled(t,resC)..
1532    Sum[ rsbp, LAMBDAHVDCRESERVE(t,isl,resC,rd,rsbp) ] =e= 1 ;
1533   
1534  * Lambda definition of Reserse + Energy flow on HVDC sent from an island
1535  * (3.4.2.29) - SPD version 11.0
1536  HVDCSentReserveFlowDefinition(t,isl,resC,rd)
1537    $ reserveShareEnabled(t,resC)..
1538    HVDCRESERVESENT(t,isl,resC,rd)
1539  =e=
1540    Sum[ rsbp, HVDCReserveBreakPointMWFlow(t,isl,rsbp)
1541             * LAMBDAHVDCRESERVE(t,isl,resC,rd,rsbp) ]
1542    ;
1543   
1544  * Lambda definition of Reserse + Energy Loss on HVDC sent from an island
1545  * (3.4.2.30) - SPD version 11.0
1546  HVDCSentReserveLossesDefinition(t,isl,resC,rd)
1547    $ reserveShareEnabled(t,resC)..
1548    HVDCRESERVELOSS(t,isl,resC,rd)
1549  =e=
1550    Sum[ rsbp, HVDCReserveBreakPointMWLoss(t,isl,rsbp)
1551             * LAMBDAHVDCRESERVE(t,isl,resC,rd,rsbp) ]
1552    ;
1553   
1554  * Lamda loss model end ---------------------------------------------------------
1555   
1556   
1557  * Calculate Reserve sharing excess penalty -------------------------------------
1558   
1559  * Tuong Nguyen added on 24 Feb 2021 to correct the calculation
1560  * Calculate max effective shared reserve for CE risk received at island (6.5.2.31)
1561  ReserveShareEffective_CE_Calculation(t,isl,resC,riskC)
1562    $ { reserveShareEnabled(t,resC) and ContingentEvents(riskC)
1563    and ( GenRisk(riskC) or ManualRisk(riskC) ) }..
1564    RESERVESHAREEFFECTIVE_CE(t,isl,resC)
1565  =g=
1566    RESERVESHAREEFFECTIVE(t,isl,resC,riskC)
1567    ;
1568   
1569  * Tuong Nguyen added on 24 Feb 2021 to correct the calculation
1570  * Calculate max effective shared reserve for CE risk received at island (6.5.2.31)
1571  ReserveShareEffective_ECE_Calculation(t,isl,resC,riskC)
1572    $ { reserveShareEnabled(t,resC) and ExtendedContingentEvent(riskC)
1573    and ( GenRisk(riskC) or ManualRisk(riskC) ) }..
1574    RESERVESHAREEFFECTIVE_ECE(t,isl,resC)
1575  =g=
1576    RESERVESHAREEFFECTIVE(t,isl,resC,riskC)
1577    ;
1578   
1579  * Constraint to avoid excessive reserve share (6.5.2.31)
1580  ExcessReserveSharePenalty(t) $ reserveShareEnabledOverall(t)..
1581    RESERVESHAREPENALTY(t)
1582  =e=
1583    sum[ isl, 1e-5 * SHAREDNFR(t,isl) ]
1584  + sum[ (isl,resC), 2e-5 * SHAREDRESERVE(t,isl,resC) ]
1585  * Tuong Nguyen modified on 24 Feb 2021 to correct the calculation
1586  *+ sum[ (isl,resC,riskC), 3e-5 * RESERVESHAREEFFECTIVE(t,isl,resC,riskC)]
1587  + sum[ (isl,resC), 3e-5 * RESERVESHAREEFFECTIVE_CE(t,isl,resC)]
1588  + sum[ (isl,resC), 3e-5 * RESERVESHAREEFFECTIVE_ECE(t,isl,resC)]
1589  ;
1590  * Calculate Reserve sharing excess penalty end ---------------------------------
1591   
1592  *======= NMIR - RESERVE SHARING EQUATIONS END ==================================
1593   
1594   
1595   
1596  *======= RESERVE EQUATIONS =====================================================
1597  * 6.5.3.1: Maximum PLSR as a proportion of the block MW
1598  PLSRReserveProportionMaximum(offer(t,o),blk,resC,PLRO)
1599    $ resOfrBlk(offer,blk,resC,PLRO)..
1600    RESERVEBLOCK(Offer,blk,resC,PLRO)
1601  =l=
1602    resrvOfrPct(Offer,blk,resC) * GENERATION(Offer)
1603    ;
1604   
1605  * 6.5.3.3: Cleared IL reserve is constrained by cleared dispatchable demand'
1606  ReserveInterruptibleOfferLimit(t,o,bd,resC,ILRO(resT))
1607    $ { sameas(o,bd) and offer(t,o) and bid(t,bd) and (sum[blk,demBidMW(t,bd,blk)] >= 0) } ..
1608    RESERVE(t,o,resC,resT)
1609  =l=
1610    PURCHASE(t,bd);
1611   
1612   
1613  * 6.5.3.4 Definition of the reserve offers of different classes and types
1614  ReserveOfferDefinition(offer(t,o),resC,resT)..
1615    RESERVE(offer,resC,resT)
1616  =e=
1617    sum[ blk, RESERVEBLOCK(offer,blk,resC,resT) ]
1618    ;
1619   
1620  * 6.5.3.5 Definition of maximum energy and reserves from each generator
1621  EnergyAndReserveMaximum(offer(t,o),resC)..
1622    GENERATION(offer)
1623  + reserveMaxFactor(offer,resC)
1624    * sum[ resT $ (not ILRO(resT)), RESERVE(offer,resC,resT) ]
1625  =l=
1626    reserveGenMax(offer)
1627    ;
1628   
1629  *======= RESERVE EQUATIONS END =================================================
1630   
1631   
1632   
1633  *======= RESERVE SCARCITY ======================================================
1634  * 6.5.4.2: Total Reserve Shortfall for DCCE risk
1635  HVDCRiskReserveShortFallCalculation(t,isl,resC,HVDCrisk(RiskC))
1636    $ ContingentEvents(riskC)..
1637    RESERVESHORTFALL(t,isl,resC,riskC)
1638  =e=
1639    sum[ blk, RESERVESHORTFALLBLK(t,isl,resC,riskC,blk) ]
1640    ;
1641   
1642  * 6.5.4.2: Total Reserve Shortfall for Manual risk
1643  ManualRiskReserveShortFallCalculation(t,isl,resC,ManualRisk(RiskC))
1644    $ ContingentEvents(riskC)..
1645    RESERVESHORTFALL(t,isl,resC,riskC)
1646  =e=
1647    sum[ blk, RESERVESHORTFALLBLK(t,isl,resC,riskC,blk) ]
1648    ;
1649   
1650  * 6.5.4.2: Total Reserve Shortfall for generation risk unit
1651  GenRiskReserveShortFallCalculation(t,isl,o,resC,GenRisk(RiskC))
1652    $ { ContingentEvents(riskC) and  islandRiskGenerator(t,isl,o)  }..
1653    RESERVESHORTFALLUNIT(t,isl,o,resC,riskC)
1654  =e=
1655    sum[ blk, RESERVESHORTFALLUNITBLK(t,isl,o,resC,riskC,blk) ]
1656    ;
1657   
1658  * 6.5.4.2: Total Reserve Shortfall for generation unit + HVDC risk
1659  HVDCsecRiskReserveShortFallCalculation(t,isl,o,resC,HVDCsecRisk(RiskC))
1660    $ { ContingentEvents(riskC) and  islandRiskGenerator(t,isl,o)  }..
1661    RESERVESHORTFALLUNIT(t,isl,o,resC,riskC)
1662  =e=
1663    sum[ blk, RESERVESHORTFALLUNITBLK(t,isl,o,resC,riskC,blk) ]
1664    ;
1665   
1666  * 6.5.4.2: Total Reserve Shortfall for Manual risk + HVDC risk
1667  HVDCsecManualRiskReserveShortFallCalculation(t,isl,resC,HVDCsecRisk(RiskC))
1668    $ ContingentEvents(riskC)..
1669    RESERVESHORTFALL(t,isl,resC,riskC)
1670  =e=
1671    sum[ blk, RESERVESHORTFALLBLK(t,isl,resC,riskC,blk) ]
1672    ;
1673   
1674  * 6.5.4.2: Total Reserve Shortfall for risk group
1675  RiskGroupReserveShortFallCalculation(t,isl,rg,resC,GenRisk(RiskC))
1676    $ { ContingentEvents(riskC) and islandRiskGroup(t,isl,rg,RiskC)}..
1677    RESERVESHORTFALLGROUP(t,isl,rg,resC,riskC)
1678  =e=
1679    sum[ blk, RESERVESHORTFALLGROUPBLK(t,isl,rg,resC,riskC,blk) ]
1680    ;
1681   
1682  *======= RESERVE SCARCITY END ==================================================
1683   
1684   
1685   
1686  *======= RISK AND RESERVE BALANCE EQUATIONS ====================================
1687   
1688  * 6.5.5.1: Calculate total island cleared reserve
1689  IslandReserveCalculation(t,isl,resC)..
1690    ISLANDRESERVE(t,isl,resC)
1691  =l=
1692    Sum[ (o,resT) $ { offer(t,o) and offerIsland(t,o,isl) }
1693                  , RESERVE(t,o,resC,resT)
1694       ]
1695    ;
1696   
1697  * 6.5.5.2 & 6.5.5.3: Matching of reserve supply and demand
1698  SupplyDemandReserveRequirement(t,isl,resC,riskC) $ useReserveModel..
1699    ISLANDRISK(t,isl,resC,riskC)
1700  - DEFICITRESERVE_CE(t,isl,resC)   $ ContingentEvents(riskC)
1701  - DEFICITRESERVE_ECE(t,isl,resC)  $ ExtendedContingentEvent(riskC)
1702  =l=
1703    ISLANDRESERVE(t,isl,resC)
1704    ;
1705   
1706  *======= RISK AND RESERVE BALANCE EQUATIONS END ================================
1707   
1708   
1709   
1710  *======= SECURITY EQUATIONS ====================================================
1711   
1712  * 6.6.1.5 Branch security constraint with LE sense
1713  BranchSecurityConstraintLE(t,brCstr)
1714    $ (BranchConstraintSense(t,brCstr) = -1)..
1715    sum[ br $ ACbranch(t,br)
1716       , branchCstrFactors(t,brCstr,br) * ACBRANCHFLOW(t,br) ]
1717  + sum[ br $ HVDClink(t,br)
1718       , branchCstrFactors(t,brCstr,br) * HVDCLINKFLOW(t,br) ]
1719  - SURPLUSBRANCHSECURITYCONSTRAINT(t,brCstr)
1720  =l=
1721    BranchConstraintLimit(t,brCstr)
1722    ;
1723   
1724  * 6.6.1.5 Branch security constraint with GE sense
1725  BranchSecurityConstraintGE(t,brCstr)
1726    $ (BranchConstraintSense(t,brCstr) = 1)..
1727    sum[ br $ ACbranch(t,br)
1728       , branchCstrFactors(t,brCstr,br) * ACBRANCHFLOW(t,br) ]
1729  + sum[ br $ HVDClink(t,br)
1730       , branchCstrFactors(t,brCstr,br) * HVDCLINKFLOW(t,br) ]
1731  + DEFICITBRANCHSECURITYCONSTRAINT(t,brCstr)
1732  =g=
1733    BranchConstraintLimit(t,brCstr)
1734    ;
1735   
1736  * 6.6.1.5 Branch security constraint with EQ sense
1737  BranchSecurityConstraintEQ(t,brCstr)
1738    $ (BranchConstraintSense(t,brCstr) = 0)..
1739    sum[ br $ ACbranch(t,br)
1740       , branchCstrFactors(t,brCstr,br) * ACBRANCHFLOW(t,br) ]
1741  + sum[ br $ HVDClink(t,br)
1742       , branchCstrFactors(t,brCstr,br) * HVDCLINKFLOW(t,br) ]
1743  + DEFICITBRANCHSECURITYCONSTRAINT(t,brCstr)
1744  - SURPLUSBRANCHSECURITYCONSTRAINT(t,brCstr)
1745  =e=
1746    BranchConstraintLimit(t,brCstr)
1747    ;
1748   
1749   
1750   
1751  * Market node security constraint with LE sense (3.5.1.7a)
1752  MNodeSecurityConstraintLE(t,MnodeCstr)
1753    $ (MNodeConstraintSense(t,MnodeCstr) = -1)..
1754    sum[ o $ posEnrgOfr(t,o)
1755         , MNCstrEnrgFactors(t,MnodeCstr,o)
1756         * GENERATION(t,o)
1757       ]
1758  + sum[ (o,resC,resT) $ offer(t,o)
1759         , MNCnstrResrvFactors(t,MnodeCstr,o,resC,resT)
1760         * RESERVE(t,o,resC,resT)
1761       ]
1762  + sum[ bd $ Bid(t,bd)
1763         , mnCnstrEnrgBidFactors(t,MnodeCstr,bd)
1764         * PURCHASE(t,bd)
1765       ]
1766  - SURPLUSMNODECONSTRAINT(t,MnodeCstr)
1767  =l=
1768    MNodeConstraintLimit(t,MnodeCstr)
1769    ;
1770   
1771  * Market node security constraint with GE sense (3.5.1.7b)
1772  MNodeSecurityConstraintGE(t,MnodeCstr)
1773    $ (MNodeConstraintSense(t,MnodeCstr) = 1)..
1774    sum[ o $ posEnrgOfr(t,o)
1775         , MNCstrEnrgFactors(t,MnodeCstr,o)
1776         * GENERATION(t,o)
1777       ]
1778  + sum[ (o,resC,resT) $ offer(t,o)
1779         , MNCnstrResrvFactors(t,MnodeCstr,o,resC,resT)
1780         * RESERVE(t,o,resC,resT)
1781       ]
1782  + sum[ bd $ Bid(t,bd)
1783         , mnCnstrEnrgBidFactors(t,MnodeCstr,bd)
1784         * PURCHASE(t,bd)
1785       ]
1786  + DEFICITMNODECONSTRAINT(t,MnodeCstr)
1787  =g=
1788    MNodeConstraintLimit(t,MnodeCstr)
1789    ;
1790   
1791  * Market node security constraint with EQ sense (3.5.1.7c)
1792  MNodeSecurityConstraintEQ(t,MnodeCstr)
1793    $ (MNodeConstraintSense(t,MnodeCstr) = 0)..
1794    sum[ o $ posEnrgOfr(t,o)
1795         , MNCstrEnrgFactors(t,MnodeCstr,o)
1796         * GENERATION(t,o)
1797       ]
1798  + sum[ (o,resC,resT) $ offer(t,o)
1799         , MNCnstrResrvFactors(t,MnodeCstr,o,resC,resT)
1800         * RESERVE(t,o,resC,resT)
1801       ]
1802  + sum[ bd $ Bid(t,bd)
1803         , mnCnstrEnrgBidFactors(t,MnodeCstr,bd)
1804         * PURCHASE(t,bd)
1805       ]
1806  + DEFICITMNODECONSTRAINT(t,MnodeCstr)
1807  - SURPLUSMNODECONSTRAINT(t,MnodeCstr)
1808  =e=
1809    MNodeConstraintLimit(t,MnodeCstr)
1810    ;
1811   
1812  *======= SECURITY EQUATIONS END ================================================
