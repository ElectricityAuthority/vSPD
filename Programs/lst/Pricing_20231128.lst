3786                 VSPDModel(t) = 0
3787              ) ;
3788          else
3789              loop (t,
3790                  unsolvedDT(t) = yes;
3791                  VSPDModel(t) = 2;
3792                  putclose rep 'The caseID: ' ca.tl ' (' dt.tl ') is 1st solved unsuccessfully for branch integer.'/
3793              ) ;
3794          ) ;
3795      ) ;
3796  *   Solve the vSPD_BranchFlowMIP model end -------------------------------------
3797   
3798   
3799  *   ReSolve the NMIR model and stop --------------------------------------------
3800      if (smax[t, VSPDModel(t)] = 2,
3801   
3802          option bratio = 1 ;
3803          vSPD_NMIR.Optfile = 1 ;
3804          vSPD_NMIR.optcr = MIPOptimality ;
3805          vSPD_NMIR.reslim = MIPTimeLimit ;
3806          vSPD_NMIR.iterlim = MIPIterationLimit ;
3807          solve vSPD_NMIR using mip maximizing NETBENEFIT ;
3808  *       Set the model solve status
