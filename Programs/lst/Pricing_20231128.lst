2628  *+++ vSPD settings +++
2631   
2632  *+++ Paths +++
2634   
2639   
2641   
2642  *+++ Model +++
2643  Scalar sequentialSolve                   / 0 / ;   ! Vectorisation: Yes <-> i_SequentialSolve: 0
2644  Scalar dailymode                         / 1 / ;   ! Solving quickly by using RTD pre-calculated demand or PRSS solved initial MW
2645   
2646  *+++ Network +++
2647  Scalar useACLossModel                    / 1 /    ;
2648  Scalar useHVDCLossModel                  / 1 /    ;
2649  Scalar useACBranchLimits                 / 1 /    ;
2650  Scalar useHVDCBranchLimits               / 1 /    ;
2651  Scalar resolveCircularBranchFlows        / 1 /    ;
2652  Scalar resolveHVDCNonPhysicalLosses      / 1 /    ;
2653  Scalar resolveACNonPhysicalLosses        / 0 /    ;   ! Placeholder for future code development
2654  Scalar circularBranchFlowTolerance       / 1e-4 / ;
2655  Scalar nonPhysicalLossTolerance          / 1e-6 / ;
2656  Scalar useBranchFlowMIPTolerance         / 1e-6 / ;
2657   
2658  *+++ Constraints +++
2659  Scalar useReserveModel                   / 1 /    ;
2660  Scalar suppressMixedConstraint           / 0 /    ;   ! No longer used since Mixed MIP Constraints no longer exists
2661  Scalar mixedMIPtolerance                 / 1e-6 / ;   ! No longer used since Mixed MIP Constraints no longer exists
2662   
2663  *+++ Solver +++
2664  Scalar LPtimeLimit                       / 3600 / ;
2665  Scalar LPiterationLimit                  / 2000000000 / ;
2666  Scalar MIPtimeLimit                      / 3600 / ;
2667  Scalar MIPiterationLimit                 / 2000000000 / ;
2668  Scalar MIPoptimality                     / 0 / ;
2671   
2672   
2673  *+++ Various switches +++
INCLUDE    C:\GitHub\vSPD\Programs\vSPDcase.inc
2677   
2678  * Update the ProgressReport.txt file
2679  File rep "Write to a report" /"ProgressReport.txt"/;  rep.lw = 0;  rep.ap = 1; rep.nd = 4; rep.nw=8;
2680  putclose rep / 'Case "Pricing_20231128" started at: ' system.date " " system.time /;
2681   
2682  * Set the solver for the LP and MIP
2683  option lp = Cplex ;
2684  option mip = Cplex ;
2685   
2686  * Set profile status
2687  option profile = 0 ;
2688   
2689  * Set the solution print status in the lst file
2690  option solprint = off;
2691   
2692  * Set the column (variable) and row (equation) listing in the lst file
2693  option limcol = 0 ;
2694  option limrow = 0 ;
2695   
2696  * Declare a temporary file
2697  File temp ;
2698   
2699  * Allow empty data set declaration
