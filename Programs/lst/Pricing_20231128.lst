2900    o_generationRiskLevel(ca,dt,isl,o,resC,riskC)                    'Audit - generation risk'
2901    o_HVDCriskLevel(ca,dt,isl,resC,riskC)                            'Audit - DCCE and DCECE risk'
2902    o_manuRiskLevel(ca,dt,isl,resC,riskC)                            'Audit - manual risk'
2903    o_genHVDCriskLevel(ca,dt,isl,o,resC,riskC)                       'Audit - generation + HVDC secondary risk'
2904    o_manuHVDCriskLevel(ca,dt,isl,resC,riskC)                        'Audit - manual + HVDC secondary'
2905    o_generationRiskGroupLevel(ca,dt,isl,rg,resC,riskC)              'Audit - generation group risk'
2906   
2907  * TN - output parameters added for NMIR project --------------------------------
2908    o_FirSent_TP(ca,dt,isl)                        'FIR export from an island for each trade period'
2909    o_SirSent_TP(ca,dt,isl)                        'SIR export from an island for each trade period'
2910    o_FirReceived_TP(ca,dt,isl)                    'FIR received at an island for each trade period'
2911    o_SirReceived_TP(ca,dt,isl)                    'SIR received at an island for each trade period'
2912    o_FirEffReport_TP(ca,dt,isl)                   'Effective FIR share for reporting to an island for each trade period'
2913    o_SirEffReport_TP(ca,dt,isl)                   'Effective FIR share for reporting to an island for each trade period'
2914    o_EffectiveRes_TP(ca,dt,isl,resC,riskC)        'Effective reserve share to an island for each trade period'
2915    o_FirEffectiveCE_TP(ca,dt,isl)                 'Effective FIR share to an island for each trade period'
2916    o_SirEffectiveCE_TP(ca,dt,isl)                 'Effective FIR share to an island for each trade period'
2917    o_FirEffectiveECE_TP(ca,dt,isl)                'Effective FIR share to an island for each trade period'
2918    o_SirEffectiveECE_TP(ca,dt,isl)                'Effective FIR share to an island for each trade period'
2919   
2920    o_TotalIslandReserve(ca,dt,isl,resC,riskC)     'Total Reserve cleared in a island including shared Reserve'
2921  * TN - output parameters added for NMIR project end ----------------------------
2922    ;
2923   
2924  Scalars
2925    modelSolved                   'Flag to indicate if the model solved successfully (1 = Yes)'                                           / 0 /
2926    LPmodelSolved                 'Flag to indicate if the final LP model (when MIP fails) is solved successfully (1 = Yes)'              / 0 /
2927    exitLoop                      'Flag to exit solve loop'                                                                               / 0 /
2928    SPDlossTolerance              'Tolerance to check loadlosss calculation'                                                              / 0.00005 /
2929    ;
2930   
2931   
2932   
2933  *=====================================================================================
2934  * 2. Load data from GDX file
2935  *=====================================================================================
2936   
2937  * If input file does not exist then go to the next input file
2939   
2940  * Load trading period to be solved
GDXIN   C:\GitHub\vSPD\Programs\vSPDPeriod.gdx
--- LOAD  ca = 1:i_caseID
--- LOAD  dt = 3:i_dateTime
--- LOAD  tp = 2:i_tradePeriod
--- LOAD  case2dt2tp = 4:i_DateTimeTradePeriod
2945   
2946  * Call the GDX routine and load the input data:
GDXIN   C:\GitHub\vSPD\Input\Pricing_20231128.gdx
--- LOAD  gdxDate = 1:i_gdxDate
--- LOAD  caseDefn = 2:i_caseDefn
--- LOAD  runMode = 3:i_runMode
2949   
--- LOAD  dtParameter = 5:i_dateTimeParameter
--- LOAD  islandParameter = 6:i_dateTimeIslandParameter
2951   
--- LOAD  n = 7:i_node
--- LOAD  node2node = 8:i_dateTimeNodetoNode
--- LOAD  nodeParameter = 9:i_dateTimeNodeParameter
2953   
--- LOAD  b = 10:i_bus
--- LOAD  busIsland = 11:i_dateTimeBusIsland
--- LOAD  busElectricalIsland = 12:i_dateTimeBusElectricalIsland
--- LOAD  nodeBus = 13:i_dateTimeNodeBus
--- LOAD  nodeBusAllocationFactor = 14:i_dateTimeNodeBusAllocationFactor
2956   
--- LOAD  branchDefn = 15:i_dateTimeBranchDefn
--- LOAD  nodeoutagebranch = 16:i_dateTimeNodeOutageBranch
--- LOAD  branchParameter = 17:i_dateTimeBranchParameter
--- LOAD  branchCstrFactors = 19:i_dateTimeBranchConstraintFactors
--- LOAD  branchCstrRHS = 18:i_dateTimeBranchConstraintRHS
2959   
--- LOAD  offerNode = 20:i_dateTimeOfferNode
--- LOAD  offerTrader = 21:i_dateTimeOfferTrader
--- LOAD  primarySecondaryOffer = 22:i_dateTimePrimarySecondaryOffer
--- LOAD  energyOffer = 25:i_dateTimeEnergyOffer
--- LOAD  reserveOffer = 26:i_dateTimeReserveOffer
--- LOAD  offerParameter = 23:i_dateTimeOfferParameter
2962   
--- LOAD  bidNode = 27:i_dateTimeBidNode
--- LOAD  bidTrader = 28:i_dateTimeBidTrader
--- LOAD  energyBid = 30:i_dateTimeEnergyBid
--- LOAD  bidParameter = 29:i_dateTimeBidParameter
2965   
--- LOAD  mnCnstrRHS = 31:i_dateTimeMNCnstrRHS
--- LOAD  mnCstrEnrgFactors = 32:i_dateTimeMNCnstrEnrgFactors
--- LOAD  mnCnstrResrvFactors = 33:i_dateTimeMNCnstrResrvFactors
--- LOAD  mnCnstrEnrgBidFactors = 34:i_dateTimeMNCnstrEnrgBidFactors
--- LOAD  mnCnstrResrvBidFactors = 35:i_dateTimeMNCnstrResrvBidFactors
2969   
--- LOAD  riskParameter = 36:i_dateTimeRiskParameter
--- LOAD  reserveSharingParameter = 37:i_dateTimeReserveSharing
--- LOAD  riskGroupOffer = 24:i_dateTimeRiskGroup
2971   
--- LOAD  scarcityNationalFactor = 38:i_dateTimeScarcityNationalFactor
--- LOAD  scarcityResrvLimit = 39:i_dateTimeScarcityResrvLimit
--- LOAD  scarcityNodeFactor = 40:i_dateTimeScarcityNodeFactor
--- LOAD  scarcityNodeLimit = 41:i_dateTimeScarcityNodeLimit
2974   
--- LOAD  casefileseconds = 42:i_priceCaseFilesPublishedSecs
2976   
2978   
2979  *===============================================================================
2980  * 3. Manage model and data compatability
2981  *===============================================================================
2982  * This section manages the changes to model flags to ensure backward
2983  * compatibility given changes in the SPD model formulation over time:
2984  * Ex: some data (sets) only starting to exist at certain time and we need to use
2985  * GDX time to check if we can load that data (set) from gdx.
2986   
2987  * Gregorian date of when symbols have been included into the GDX files
2988  Scalars inputGDXGDate                     'Gregorian date of input GDX file' ;
2989   
2990  inputGDXGDate = jdate(gdxDate('year'),gdxDate('month'),gdxDate('day'));
2991   
2992  if (inputGDXGDate <= jdate(2023,4,27),
2993    SPDlossTolerance = 0.005 ;
2994  );
2995   
2996  *=====================================================================================
2997  * 4. Input data overrides - declare and apply (include vSPDoverrides.gms)
2998  *=====================================================================================
2999   
       - At this point, vSPDoverrides.gms is included into vSPDsolve.gms if an override
         file defined by the $setglobal vSPDinputOvrdData in vSPDSetting.inc exists.
       - All override data symbols have the characters 'Ovrd' appended to the original
         symbol name. After declaring the override symbols, the override data is
         installed and the original symbols are overwritten.
       - Note that the Excel interface permits a limited number of input data symbols
         to be overridden. The EMI interface will create a GDX file of override values
         for all data inputs to be overridden. If operating in standalone mode,
         overrides can be installed by any means the user prefers - GDX file, $include
         file, hard-coding, etc. But it probably makes sense to mimic the GDX file as
         used by EMI.
3013   
3015   
3016   
3017  *===============================================================================
3018  * 5. Initialise model mapping and inputs
3019  *===============================================================================
3020   
3021  * Calculate studyMode(t) and IntervalDuration(t)
3022  studyMode(ca,dt)        = runMode(ca,'studyMode');
3023  IntervalDuration(ca,dt) = runMode(ca,'intervalLength');
3024  case2dt(ca,dt)          = yes $ sum[ tp $ case2dt2tp(ca,dt,tp), 1] ;
3025   
3026  * Nodal data
3027  node(ca,dt,n) = yes $ sum[ b $ nodeBus(ca,dt,n,b), 1 ] ;
3028  bus(ca,dt,b)  = yes $ sum[ isl $ busIsland(ca,dt,b,isl), 1 ] ;
3029  nodeIsland(ca,dt,n,isl) $ sum[ b $ { bus(ca,dt,b) and node(ca,dt,n) and nodeBus(ca,dt,n,b) and busIsland(ca,dt,b,isl) }, 1 ] = yes ;
3030   
3031  refNode(ca,dt,n)              = nodeParameter(ca,dt,n,'referenceNode') ;
3032  requiredLoad(node)            = nodeParameter(node,'demand') ;
3033  inputInitialLoad(ca,dt,n)     = nodeParameter(ca,dt,n,'initialLoad') ;
3034  conformingFactor(ca,dt,n)     = nodeParameter(ca,dt,n,'conformingFactor') ;
3035  nonConformingLoad(ca,dt,n)    = nodeParameter(ca,dt,n,'nonConformingFactor') ;
3036  loadIsOverride(ca,dt,n)       = nodeParameter(ca,dt,n,'loadIsOverride') ;
3037  loadIsBad(ca,dt,n)            = nodeParameter(ca,dt,n,'loadIsBad') ;
3038  loadIsNCL(ca,dt,n)            = nodeParameter(ca,dt,n,'loadIsNCL') ;
3039  maxLoad(ca,dt,n)              = nodeParameter(ca,dt,n,'maxLoad') ;
3040  instructedLoadShed(ca,dt,n)   = nodeParameter(ca,dt,n,'instructedLoadShed') ;
3041  instructedShedActive(ca,dt,n) = nodeParameter(ca,dt,n,'instructedShedActive') ;
3042  dispatchedLoad(ca,dt,n)       = nodeParameter(ca,dt,n,'dispatchedLoad') ;
3043  dispatchedGeneration(ca,dt,n) = nodeParameter(ca,dt,n,'dispatchedGeneration') ;
3044   
3045  * Factor to prorate the deficit and surplus at the nodal level
3046  totalBusAllocation(ca,dt,b) $ bus(ca,dt,b) = sum[ n $ Node(ca,dt,n), NodeBusAllocationFactor(ca,dt,n,b)];
3047  busNodeAllocationFactor(ca,dt,b,n) $ (totalBusAllocation(ca,dt,b) > 0) = NodeBusAllocationFactor(ca,dt,n,b) / totalBusAllocation(ca,dt,b) ;
3048   
3049  * Network data
3050  branch(ca,dt,br) = yes $ { (not branchParameter(ca,dt,br,'isOpen'))
3051                         and branchParameter(ca,dt,br,'forwardCap') and branchParameter(ca,dt,br,'backwardCap')
3052                         and sum[ (b,b1) $ { bus(ca,dt,b) and bus(ca,dt,b1) and branchDefn(ca,dt,br,b,b1) }, 1 ] }  ;
3053  branch(ca,dt,br) $ { (not branchParameter(ca,dt,br,'isOpen'))
3054                   and branchParameter(ca,dt,br,'forwardCap') and (branchParameter(ca,dt,br,'HVDCbranch'))
3055                   and sum[ (b,b1) $ { bus(ca,dt,b) and bus(ca,dt,b1) and branchDefn(ca,dt,br,b,b1) }, 1 ] } = yes ;
3056   
3057  branchBusDefn(branch,b,b1) $ branchDefn(branch,b,b1)                            = yes ;
3058  branchFrBus(branch,frB)    $ sum[ toB $ branchBusDefn(branch,frB,toB), 1 ]      = yes ;
3059  branchToBus(branch,toB)    $ sum[ frB $ branchBusDefn(branch,frB,toB), 1 ]      = yes ;
3060  branchBusConnect(branch,b) $ { branchFrBus(branch,b) or branchToBus(branch,b) } = yes ;
3061   
3062  * HVDC link and AC branch definition
3063  HVDClink(branch) = yes $ branchParameter(branch,'HVDCbranch') ;
3064  ACbranch(branch) = yes $ [not branchParameter(branch,'HVDCbranch')];
3065   
3066  * Determine sending and receiving bus for each branch flow direction
3067  loop ((frB,toB),
3068      ACbranchSendingBus(ACbranch,frB,fd)   $ { branchBusDefn(ACbranch,frB,toB) and (ord(fd) = 1) } = yes ;
3069      ACbranchReceivingBus(ACbranch,toB,fd) $ { branchBusDefn(ACbranch,frB,toB) and (ord(fd) = 1) } = yes ;
3070      ACbranchSendingBus(ACbranch,toB,fd)   $ { branchBusDefn(ACbranch,frB,toB) and (ord(fd) = 2) } = yes ;
3071      ACbranchReceivingBus(ACbranch,frB,fd) $ { branchBusDefn(ACbranch,frB,toB) and (ord(fd) = 2) } = yes ;
3072  ) ;
3073   
3074   
3075  HVDClinkSendingBus(HVDClink,frB)   $ sum[ branchBusDefn(HVDClink,frB,toB), 1 ] = yes ;
3076  HVDClinkReceivingBus(HVDClink,toB) $ sum[ branchBusDefn(HVDClink,frB,toB), 1 ] = yes ;
3077  HVDClinkBus(HVDClink,b) $ { HVDClinkSendingBus(HVDClink,b) or HVDClinkReceivingBus(HVDClink,b) }  = yes ;
3078   
3079  * Determine the HVDC inter-island pole in the northward and southward direction
3080  HVDCpoleDirection(ca,dt,br,fd) $ { (ord(fd) = 1) and HVDClink(ca,dt,br) } = yes $ sum[ (isl,NodeBus(ca,dt,n,b)) $ { (ord(isl) = 2) and nodeIsland(ca,dt,n,isl) and HVDClinkSendingBus(ca,dt,br,b) }, 1 ] ;
3081  HVDCpoleDirection(ca,dt,br,fd) $ { (ord(fd) = 2) and HVDClink(ca,dt,br) } = yes $ sum[ (isl,NodeBus(ca,dt,n,b)) $ { (ord(isl) = 1) and nodeIsland(ca,dt,n,isl) and HVDClinkSendingBus(ca,dt,br,b) }, 1 ] ;
3082   
3083  * Mapping HVDC branch to pole to account for name changes to Pole 3
3084  HVDCpoleBranchMap('Pole1',br) $ sum[ sameas(br,'BEN_HAY1.1'), 1] = yes ;
3085  HVDCpoleBranchMap('Pole1',br) $ sum[ sameas(br,'HAY_BEN1.1'), 1] = yes ;
3086  HVDCpoleBranchMap('Pole1',br) $ sum[ sameas(br,'BEN_HAY3.1'), 1] = yes ;
3087  HVDCpoleBranchMap('Pole1',br) $ sum[ sameas(br,'HAY_BEN3.1'), 1] = yes ;
3088  HVDCpoleBranchMap('Pole2',br) $ sum[ sameas(br,'BEN_HAY2.1'), 1] = yes ;
3089  HVDCpoleBranchMap('Pole2',br) $ sum[ sameas(br,'HAY_BEN2.1'), 1] = yes ;
3090   
3091  * Branch parameters (capacity, resistance, susceptance, fixedLosses, numLossTranches)
3092  branchCapacity(branch,'forward')  = branchParameter(branch,'forwardCap') ;
3093  branchCapacity(branch,'backward') = branchParameter(branch,'backwardCap') ;
3094  branchResistance(branch)          = branchParameter(branch,'resistance') ;
3095  branchSusceptance(ACbranch)       = -100 * branchParameter(ACbranch,'susceptance');
3096  branchLossBlocks(branch)          = branchParameter(branch,'numLossTranches') ;
3097  branchFixedLoss(ACbranch)         = branchParameter(ACbranch,'fixedLosses') $ (branchLossBlocks(ACbranch) > 1) ;
3098  branchFixedLoss(HVDClink)         = branchParameter(HVDClink,'fixedLosses') ;
3099   
3100   
3101  * Set resistance and fixed loss to zero if do not want to use the loss model
3102  branchResistance(ACbranch) $ (not useAClossModel) = 0 ;
3103  branchFixedLoss(ACbranch)  $ (not useAClossModel) = 0 ;
3104  branchResistance(HVDClink) $ (not useHVDClossModel) = 0 ;
3105  branchFixedLoss(HVDClink)  $ (not useHVDClossModel) = 0 ;
3106   
3107  * Initialise loss tranches data for the current trade period start. The loss factor coefficients assume that the branch capacity is in MW and the resistance is in p.u.
3108  lossSegmentMW(branch,los,fd)     $ { (branchLossBlocks(branch) = 0) and (ord(los) = 1) } = branchCapacity(branch,fd) ;
3109  LossSegmentFactor(branch,los,fd) $ { (branchLossBlocks(branch) = 0) and (ord(los) = 1) } = 0 ;
3110   
3111  LossSegmentMW(branch,los,fd)     $ { (branchLossBlocks(branch) = 1) and (ord(los) = 1) } = maxFlowSegment ;
3112  LossSegmentFactor(branch,los,fd) $ { (branchLossBlocks(branch) = 1) and (ord(los) = 1) } = 0.01 * branchResistance(branch) * branchCapacity(branch,fd) ;
3113   
3114  LossSegmentMW(branch,los,fd)     $ { (branchLossBlocks(branch) = 3) and (ord(los) = 1) } = lossCoeff_A * branchCapacity(branch,fd) ;
3115  LossSegmentMW(branch,los,fd)     $ { (branchLossBlocks(branch) = 3) and (ord(los) = 2) } = (1-lossCoeff_A) * branchCapacity(branch,fd) ;
3116  LossSegmentMW(branch,los,fd)     $ { (branchLossBlocks(branch) = 3) and (ord(los) = 3) } = maxFlowSegment ;
3117  LossSegmentFactor(branch,los,fd) $ { (branchLossBlocks(branch) = 3) and (ord(los) = 2) } = 0.01 * branchResistance(branch) * branchCapacity(branch,fd) ;
3118  LossSegmentFactor(branch,los,fd) $ { (branchLossBlocks(branch) = 3) and (ord(los) = 1) } = 0.01 * 0.75 * lossCoeff_A * branchResistance(branch) * branchCapacity(branch,fd) ;
3119  LossSegmentFactor(branch,los,fd) $ { (branchLossBlocks(branch) = 3) and (ord(los) = 3) } = 0.01 * (2 - (0.75*lossCoeff_A)) * branchResistance(branch) * branchCapacity(branch,fd) ;
3120   
3121  LossSegmentMW(branch,los,fd)     $ { (branchLossBlocks(branch) = 6) and (ord(los) = 1) } = lossCoeff_C  * branchCapacity(branch,fd) ;
3122  LossSegmentMW(branch,los,fd)     $ { (branchLossBlocks(branch) = 6) and (ord(los) = 2) } = lossCoeff_D * branchCapacity(branch,fd) ;
3123  LossSegmentMW(branch,los,fd)     $ { (branchLossBlocks(branch) = 6) and (ord(los) = 3) } = 0.5 * branchCapacity(branch,fd) ;
3124  LossSegmentMW(branch,los,fd)     $ { (branchLossBlocks(branch) = 6) and (ord(los) = 4) } = (1 - lossCoeff_D) * branchCapacity(branch,fd) ;
3125  LossSegmentMW(branch,los,fd)     $ { (branchLossBlocks(branch) = 6) and (ord(los) = 5) } = (1 - lossCoeff_C) * branchCapacity(branch,fd) ;
3126  LossSegmentMW(branch,los,fd)     $ { (branchLossBlocks(branch) = 6) and (ord(los) = 6) } = maxFlowSegment ;
3127  LossSegmentFactor(branch,los,fd) $ { (branchLossBlocks(branch) = 6) and (ord(los) = 1) } = 0.01 * 0.75 * lossCoeff_C * branchResistance(branch) * branchCapacity(branch,fd) ;
3128  LossSegmentFactor(branch,los,fd) $ { (branchLossBlocks(branch) = 6) and (ord(los) = 2) } = 0.01 * lossCoeff_E * branchResistance(branch) * branchCapacity(branch,fd) ;
3129  LossSegmentFactor(branch,los,fd) $ { (branchLossBlocks(branch) = 6) and (ord(los) = 3) } = 0.01 * lossCoeff_F * branchResistance(branch) * branchCapacity(branch,fd) ;
3130  LossSegmentFactor(branch,los,fd) $ { (branchLossBlocks(branch) = 6) and (ord(los) = 4) } = 0.01 * (2 - lossCoeff_F) * branchResistance(branch) * branchCapacity(branch,fd) ;
3131  LossSegmentFactor(branch,los,fd) $ { (branchLossBlocks(branch) = 6) and (ord(los) = 5) } = 0.01 * (2 - lossCoeff_E) * branchResistance(branch) * branchCapacity(branch,fd) ;
3132  LossSegmentFactor(branch,los,fd) $ { (branchLossBlocks(branch) = 6) and (ord(los) = 6) } = 0.01 * (2 - (0.75*lossCoeff_C)) * branchResistance(branch) * branchCapacity(branch,fd) ;
3133   
3134  * HVDC does not have backward flow --> No loss segment for backward flow
3135  LossSegmentMW(HVDClink,los,fd)     $ (ord(fd) = 2) = 0;
3136  LossSegmentFactor(HVDClink,los,fd) $ (ord(fd) = 2) = 0;
3137   
3138  * Valid loss segment for a branch is defined as a loss segment that has a non-zero LossSegmentMW or a non-zero LossSegmentFactor.
3139  validLossSegment(branch,los,fd) = yes $ { (ord(los) = 1) or LossSegmentMW(branch,los,fd) or LossSegmentFactor(branch,los,fd) } ;
3140   
3141  * HVDC loss model requires at least two loss segments and an additional loss block due to cumulative loss formulation
3142  validLossSegment(HVDClink,los,fd) $ { (branchLossBlocks(HVDClink) <= 1) and (ord(los) = 2) } = yes ;
3143  validLossSegment(HVDClink,los,fd) $ { (branchLossBlocks(HVDClink) > 1) and (ord(los) = (branchLossBlocks(HVDClink) + 1))
3144                                    and (sum[ los1, LossSegmentMW(HVDClink,los1,fd) + LossSegmentFactor(HVDClink,los1,fd) ] > 0) } = yes ;
3145   
3146  * branches that have non-zero loss factors
3147  LossBranch(branch) $ sum[ (los,fd), LossSegmentFactor(branch,los,fd) ] = yes ;
3148   
3149  * Create AC branch loss segments
3150  ACbranchLossMW(ACbranch,los,fd) $ { validLossSegment(ACbranch,los,fd) and (ord(los) = 1) } = LossSegmentMW(ACbranch,los,fd) ;
3151  ACbranchLossMW(ACbranch,los,fd) $ { validLossSegment(ACbranch,los,fd) and (ord(los) > 1) } = LossSegmentMW(ACbranch,los,fd) - LossSegmentMW(ACbranch,los-1,fd) ;
3152  ACbranchLossFactor(ACbranch,los,fd) $ validLossSegment(ACbranch,los,fd) = LossSegmentFactor(ACbranch,los,fd) ;
3153   
3154  * Create HVDC loss break points
3155  HVDCBreakPointMWFlow(HVDClink,bp,fd) $ (ord(bp) = 1) = 0 ;
3156  HVDCBreakPointMWLoss(HVDClink,bp,fd) $ (ord(bp) = 1) = 0 ;
3157  HVDCBreakPointMWFlow(HVDClink,bp,fd) $ { validLossSegment(HVDClink,bp,fd) and (ord(bp) > 1) } = LossSegmentMW(HVDClink,bp-1,fd) ;
3158  HVDCBreakPointMWLoss(HVDClink,bp,fd) $ { validLossSegment(HVDClink,bp,fd) and (ord(bp) = 2) } =  LossSegmentMW(HVDClink,bp-1,fd) * LossSegmentFactor(HVDClink,bp-1,fd) ;
3159  loop ((HVDClink(branch),bp) $ (ord(bp) > 2),
3160      HVDCBreakPointMWLoss(branch,bp,fd) $ validLossSegment(branch,bp,fd) = LossSegmentFactor(branch,bp-1,fd) * [ LossSegmentMW(branch,bp-1,fd) - LossSegmentMW(branch,bp-2,fd) ] + HVDCBreakPointMWLoss(branch,bp-1,fd) ;
3161  ) ;
3162   
3163   
3164  * Initialise branch constraint data
3165  branchConstraint(ca,dt,brCstr) $ sum[ branch(ca,dt,br) $ branchCstrFactors(ca,dt,brCstr,br), 1 ] = yes ;
3166  branchConstraintSense(branchConstraint) = branchCstrRHS(branchConstraint,'cnstrSense') ;
3167  branchConstraintLimit(branchConstraint) = branchCstrRHS(branchConstraint,'cnstrLimit') ;
3168   
3169   
3170  * Offer data
3171  * Initialise generating offer parameters
3172  generationStart(ca,dt,o) $ {     (studyMode(ca,dt) = 101 or studyMode(ca,dt) = 201) or (dailymode=0) } = offerParameter(ca,dt,o,'initialMW') ;
3173  generationStart(ca,dt,o) $ { not((studyMode(ca,dt) = 101 or studyMode(ca,dt) = 201) or (dailymode=0))} = offerParameter(ca,dt,o,'solvedInitialMW') ;
3174  * If we run pricing gdx, we need to use "solvedInitialMW" as initialMW for predispatch schedule
3175  generationStart(ca,dt,o) $ { not((studyMode(ca,dt) = 101 or studyMode(ca,dt) = 201)) and sum[dt1, offerParameter(ca,dt1,o,'initialMW') = 0] } = offerParameter(ca,dt,o,'solvedInitialMW') ;
3176   
3177  generationStart(ca,dt,o) = generationStart(ca,dt,o) + sum[ o1 $ primarySecondaryOffer(ca,dt,o,o1), offerParameter(ca,dt,o1,'initialMW') ] ;
3178   
3179  rampRateUp(ca,dt,o)        = offerParameter(ca,dt,o,'rampUpRate')      ;
3180  rampRateDn(ca,dt,o)        = offerParameter(ca,dt,o,'rampDnRate')      ;
3181  reserveGenMax(ca,dt,o)     = offerParameter(ca,dt,o,'resrvGenMax')     ;
3182  intermittentOffer(ca,dt,o) = offerParameter(ca,dt,o,'isIG')            ;
3183  FKband(ca,dt,o)            = offerParameter(ca,dt,o,'FKbandMW')        ;
3184  priceResponsive(ca,dt,o)   = offerParameter(ca,dt,o,'isPriceResponse') ;
3185  potentialMW(ca,dt,o)       = offerParameter(ca,dt,o,'potentialMW')     ;
3186   
      For generators in the PRICERESPONSIVEIG subset, if the potentialMW(g) value is less than ReserveGenerationMaximum(g,c) then pre-processing sets the ReserveGenerationMaximum(g,c) parameter to the PotentialMWg value,
      otherwise if the potentialMW(g) value is greater than or equal to the ReserveGenerationMaximum(g,c) then the ReserveGenerationMaximum(g,c) value is unchanged
      Tuong note: this does not seems to make sense and be used but This is based on the 4.6.2.1 calculation
3192  reserveMaxFactor(ca,dt,o,'FIR') = offerParameter(ca,dt,o,'maxFactorFIR') ;
3193  reserveMaxFactor(ca,dt,o,'SIR') = offerParameter(ca,dt,o,'maxFactorSIR') ;
3194  reserveMaxFactor(ca,dt,o,resC) $ { intermittentOffer(ca,dt,o) and priceResponsive(ca,dt,o) and( potentialMW(ca,dt,o) > 0) and (potentialMW(ca,dt,o) < reserveGenMax(ca,dt,o)) } = reserveGenMax(ca,dt,o) / potentialMW(ca,dt,o) ;
3195   
3196  * Identification of primary and secondary units
3197  primaryOffer(ca,dt,o) = 1 ;
3198  secondaryOffer(ca,dt,o) = 1 $ sum[ o1 $ primarySecondaryOffer(ca,dt,o1,o), 1 ] ;
3199  primaryOffer(ca,dt,o) $ secondaryOffer(ca,dt,o) = 0 ;
3200   
3201  * Initialise energy/reserve offer data
3202  enrgOfrMW(ca,dt,o,blk) = energyOffer(ca,dt,o,blk,'limitMW')  $ { offerParameter(ca,dt,o,'dispatchable') = 1 } ;
3203  enrgOfrPrice(ca,dt,o,blk) = energyOffer(ca,dt,o,blk,'price') $ { offerParameter(ca,dt,o,'dispatchable') = 1 } ;
3204   
3205  resrvOfrPct(ca,dt,o,blk,resC)        = reserveOffer(ca,dt,o,resC,'PLRO',blk,'plsrPct') / 100 ;
3206  resrvOfrMW(ca,dt,o,blk,resC,resT)    = reserveOffer(ca,dt,o,resC,resT,blk,'limitMW')  ;
3207  resrvOfrPrice(ca,dt,o,blk,resC,resT) = reserveOffer(ca,dt,o,resC,resT,blk,'price')  ;
3208   
3209   
3210  * Define valid offers/block sets
3211  * Valid offer must be mapped to a bus with electrical island <> 0. IL offer with non zero total limit is always valid no matter what
3212  offer(ca,dt,o) $ sum[ (n,b) $ { offerNode(ca,dt,o,n) and nodeBus(ca,dt,n,b) }, busElectricalIsland(ca,dt,b) ] = yes ;
3213  offer(ca,dt,o) $ sum[ (blk,resC), resrvOfrMW(ca,dt,o,blk,resC,'ILRO')] = yes ;
3214   
3215  offerIsland(offer(ca,dt,o),isl) $ sum[ n $ { offerNode(ca,dt,o,n) and nodeIsland(ca,dt,n,isl) }, 1 ] = yes ;
3216  islandRiskGenerator(ca,dt,isl,o) $ { offerIsland(ca,dt,o,isl) and offerParameter(ca,dt,o,'riskGenerator') } = yes ;
3217   
3218  * Valid energy offer blocks are defined as those with a positive block limit
3219  genOfrBlk(ca,dt,o,blk) $ ( enrgOfrMW(ca,dt,o,blk) > 0 ) = yes ;
3220   
3221  * Define set of positive (valid) energy offers
3222  posEnrgOfr(ca,dt,o) $ sum[ blk $ genOfrBlk(ca,dt,o,blk), 1 ] = yes ;
3223   
3224  * Only reserve offer block with a positive block limit is valid
3225  resOfrBlk(ca,dt,o,blk,resC,resT) $ (resrvOfrMW(ca,dt,o,blk,resC,resT) > 0) = yes ;
3226   
3227   
3228  * Bid data
3229  bid(ca,dt,bd) $ sum[ (n,b) $ { bidNode(ca,dt,bd,n) and nodeBus(ca,dt,n,b) }, busElectricalIsland(ca,dt,b) ] = yes ;
3230  bidIsland(bid(ca,dt,bd),isl) $ sum[ n $ { bidNode(ca,dt,bd,n) and nodeIsland(ca,dt,n,isl) }, 1 ] = yes ;
3231  * Initialise bid limits and prices
3232  demBidMW(bid,blk)    $ { bidParameter(bid,'dispatchable') = 1 } = energyBid(bid,blk,'limitMW') ;
3233  demBidPrice(bid,blk) $ { bidParameter(bid,'dispatchable') = 1 } = energyBid(bid,blk,'price')   ;
3234  demBidBlk(bid,blk)   $ ( DemBidMW(bid,blk) <> 0 ) = yes ;
3235   
3236   
3237  * Initialise market node constraint data for the current trading period
3238  MnodeConstraint(ca,dt,MnodeCstr) $ sum[ (offer(ca,dt,o),resT,resC) $ { mnCstrEnrgFactors(ca,dt,MnodeCstr,o) or mnCnstrResrvFactors(ca,dt,MnodeCstr,o,resC,resT) }, 1 ] = yes;
3239  MnodeConstraint(ca,dt,MnodeCstr) $ sum[ (bid(ca,dt,bd),resC) $ { mnCnstrEnrgBidFactors(ca,dt,MnodeCstr,bd) or mnCnstrResrvBidFactors(ca,dt,MnodeCstr,bd,resC) }, 1 ]   = yes ;
3240  MnodeConstraintSense(MnodeConstraint) = mnCnstrRHS(MnodeConstraint,'cnstrSense') ;
3241  MnodeConstraintLimit(MnodeConstraint) = mnCnstrRHS(MnodeConstraint,'cnstrLimit') ;
3242   
3243   
3244  * Reserve/Risk data
3245  islandRiskGroup(ca,dt,isl,rg,riskC)             = yes $ sum[ o $ { offerIsland(ca,dt,o,isl) and riskGroupOffer(ca,dt,rg,o,riskC) }, 1 ] ;
3246  HVDCSecRiskEnabled(ca,dt,isl,'HVDCsecRisk')     = islandParameter(ca,dt,isl,'HVDCsecRisk') ;
3247  HVDCSecRiskEnabled(ca,dt,isl,'HVDCsecRiskECE')  = islandParameter(ca,dt,isl,'HVDCsecRiskECE') ;
3248  riskAdjFactor(ca,dt,isl,resC,riskC)             = riskParameter(ca,dt,isl,resC,riskC,'adjustFactor') $ useReserveModel ;
3249  HVDCpoleRampUp(ca,dt,isl,resC,riskC)            = riskParameter(ca,dt,isl,resC,riskC,'HVDCRampUp') ;
3250   
3251   
3252  * Reserve sharing data
3253  rampingConstraint(branchConstraint) = branchCstrRHS(branchConstraint,'rampingCnstr') ;
      TN on 22 May 2017:
      Usually a branch group constraint that limits the HVDC flow only involves the HVDC branch(s) in the same direction. However, during TP6 to TP9 of 18 May 2017, the constraint HAY_BEN_High_Frequency_limit involved all four
      branches in the form: HAY_BEN1.1 + HAY_BEN2.1 - BEN_HAY1.1 - BEN_HAY2.1 <= 530 MW. This method of formulating the constraint prevented the previous formulation of monopoleConstraint and bipoleConstraintfrom working properly.
      Those constraints have been reformulated (see below) in order to cope with the formulation observed on 18 May 2017.
3260  monopoleConstraint(ca,dt,isl,brCstr,br) $ { HVDClink(ca,dt,br) and ( not rampingConstraint(ca,dt,brCstr) ) and ( branchConstraintSense(ca,dt,brCstr) = -1 )
3261                                          and (sum[ (br1,b) $ { HVDClinkSendingBus(ca,dt,br1,b) and busIsland(ca,dt,b,isl) }, branchCstrFactors(ca,dt,brCstr,br1)] = 1)
3262                                          and (sum[ b $ { HVDClinkSendingBus(ca,dt,br,b) and busIsland(ca,dt,b,isl) }, branchCstrFactors(ca,dt,brCstr,br)] = 1)
3263                                            } = yes ;
3264   
3265  bipoleConstraint(ca,dt,isl,brCstr) $ { ( not rampingConstraint(ca,dt,brCstr) ) and ( branchConstraintSense(ca,dt,brCstr) = -1 )
3266                                     and (sum[ (br,b) $ { HVDClink(ca,dt,br) and HVDClinkSendingBus(ca,dt,br,b) and busIsland(ca,dt,b,isl) }, branchCstrFactors(ca,dt,brCstr,br)  ] = 2)
3267                                       } = yes ;
3268   
3269  reserveShareEnabled(ca,dt,'FIR')  = reserveSharingParameter(ca,dt,'sharingFIR') ;
3270  reserveShareEnabled(ca,dt,'SIR')  = reserveSharingParameter(ca,dt,'sharingSIR') ;
3271  reserveShareEnabledOverall(ca,dt) = smax[ resC, reserveShareEnabled(ca,dt,resC)];
3272   
3273  reserveRoundPower(ca,dt,'FIR')    = reserveSharingParameter(ca,dt,'roundPwrFIR') ;
3274  reserveRoundPower(ca,dt,'SIR')    = reserveSharingParameter(ca,dt,'roundPwrSIR') ;
3275   
3276  modulationRiskClass(ca,dt,'DCCE')           = reserveSharingParameter(ca,dt,'MRCE') ;
3277  modulationRiskClass(ca,dt,'DCECE')          = reserveSharingParameter(ca,dt,'MRECE') ;
3278  modulationRiskClass(ca,dt,'HVDCsecRisk')    = reserveSharingParameter(ca,dt,'MRCE') ;
3279  modulationRiskClass(ca,dt,'HVDCsecRiskECE') = reserveSharingParameter(ca,dt,'MRECE') ;
3280  modulationRisk(ca,dt)                       = smax[ riskC, modulationRiskClass(ca,dt,RiskC) ];
3281   
3282  roundPower2MonoLevel(ca,dt) = reserveSharingParameter(ca,dt,'roundPwr2Mono') ;
3283  bipole2MonoLevel(ca,dt)     = reserveSharingParameter(ca,dt,'biPole2Mono') ;
3284  roPwrZoneExit(ca,dt,resC)   = [ roundPower2MonoLevel(ca,dt) - modulationRisk(ca,dt) ]$(ord(resC)=1) + bipole2MonoLevel(ca,dt)$(ord(resC)=2) ;
      SPD pre-processing is changed so that the roundpower settings for FIR are now the same as for SIR. Specifically: (National market refinement - effective date 28 Mar 2019 12:00 )
      -  The RoundPowerZoneExit for FIR will be set at BipoleToMonopoleTransition by SPD pre-processing. A change from the existing where the RoundPowerZoneExit for FIR is set at RoundPowerToMonopoleTransition by SPD pre-processing.
      -  Provided that roundpower is not disabled by the MDB, the InNoReverseZone for FIR will be removed by SPD pre-processing. A change from the existing where the InNoReverseZone for FIR is never removed by SPD pre-processing.
3290  if(inputGDXGDate >= jdate(2019,03,28),
3291      roPwrZoneExit(ca,dt,resC) = bipole2MonoLevel(ca,dt) ;
3292  ) ;
3293   
3294  monopoleMinimum(ca,dt)                = reserveSharingParameter(ca,dt,'monoPoleMin') ;
3295  HVDCControlBand(ca,dt,'forward')      = reserveSharingParameter(ca,dt,'forwardHVDCcontrolBand') ;
3296  HVDCControlBand(ca,dt,'backward')     = reserveSharingParameter(ca,dt,'backwardHVDCcontrolBand') ;
3297  HVDClossScalingFactor(ca,dt)          = reserveSharingParameter(ca,dt,'lossScalingFactorHVDC') ;
3298   
3299  RMTReserveLimit(ca,dt,isl,'FIR')      = islandParameter(ca,dt,isl,'RMTlimitFIR') ;
3300  RMTReserveLimit(ca,dt,isl,'SIR')      = islandParameter(ca,dt,isl,'RMTlimitSIR') ;
3301   
3302  sharedNFRFactor(ca,dt)                = reserveSharingParameter(ca,dt,'sharedNFRfactor') ;
3303  sharedNFRLoadOffset(ca,dt,isl)        = islandParameter(ca,dt,isl,'sharedNFRLoadOffset') ;
3304  effectiveFactor(ca,dt,isl,resC,riskC) = riskParameter(ca,dt,isl,resC,riskC,'sharingEffectiveFactor');
3305   
3306  * Calculate HVDC parameters applied to National Reserve Sharing
3307  numberOfPoles(ca,dt,isl)       = sum[ (b,br) $ { BusIsland(ca,dt,b,isl) and HVDClink(ca,dt,br) and HVDClinkSendingBus(ca,dt,br,b) }, 1 ] ;
3308   
3309  monoPoleCapacity(ca,dt,isl,br) = sum[ b $ { BusIsland(ca,dt,b,isl) and HVDClink(ca,dt,br) and HVDClinkSendingBus(ca,dt,br,b)}, branchCapacity(ca,dt,br,'forward') ] ;
3310  monoPoleCapacity(ca,dt,isl,br) $ sum[ brCstr $ monopoleConstraint(ca,dt,isl,brCstr,br), 1] = Smin[ brCstr $ monopoleConstraint(ca,dt,isl,brCstr,br), branchConstraintLimit(ca,dt,brCstr) ];
3311  monoPoleCapacity(ca,dt,isl,br) = Min[ monoPoleCapacity(ca,dt,isl,br), branchCapacity(ca,dt,br,'forward') ];
3312   
3313  biPoleCapacity(ca,dt,isl) $ sum[ brCstr $ bipoleConstraint(ca,dt,isl,brCstr), 1]  = Smin[ brCstr $ bipoleConstraint(ca,dt,isl,brCstr) , branchConstraintLimit(ca,dt,brCstr) ];
3314  biPoleCapacity(ca,dt,isl) $ { sum[ brCstr $ bipoleConstraint(ca,dt,isl,brCstr), 1] = 0 } = sum[ (b,br,fd) $ { BusIsland(ca,dt,b,isl) and HVDClink(ca,dt,br) and HVDClinkSendingBus(ca,dt,br,b) }, branchCapacity(ca,dt,br,'forward') ] ;
3315   
3316  HVDCMax(ca,dt,isl) = Min( biPoleCapacity(ca,dt,isl), sum[ br, monoPoleCapacity(ca,dt,isl,br) ] ) ;
3317   
3318  * Initialse parameters for NMIR -------------------------------------------
      * When NMIR started on 20/10/2016, the SO decided to incorrectly calculate the HVDC loss curve for reserve sharing based on the HVDC capacity only (i.e. not based on in-service HVDC poles)
      * Tuong Nguyen @ EA discovered this bug and the SO has fixed it as of 22/11/2016.
3323  HVDCCapacity(ca,dt,isl) = sum[ (b,br) $ { BusIsland(ca,dt,b,isl) and HVDClink(ca,dt,br) and HVDClinkSendingBus(ca,dt,br,b) }, branchCapacity(ca,dt,br,'forward') ] ;
3324   
3325  HVDCResistance(ca,dt,isl) $ (numberOfPoles(ca,dt,isl) = 2) = prod[ (b,br) $ { BusIsland(ca,dt,b,isl) and HVDClink(ca,dt,br) and HVDClinkSendingBus(ca,dt,br,b) }, branchResistance(ca,dt,br) ]
3326                                                              / sum[ (b,br) $ { BusIsland(ca,dt,b,isl) and HVDClink(ca,dt,br) and HVDClinkSendingBus(ca,dt,br,b) }, branchResistance(ca,dt,br) ] ;
3327  HVDCResistance(ca,dt,isl) $ (numberOfPoles(ca,dt,isl) = 1) = sum[ br $ monoPoleCapacity(ca,dt,isl,br), branchResistance(ca,dt,br) ] ;
3328   
3329  HVDCLossSegmentMW(ca,dt,isl,los)     $ (ord(los) = 1) = HVDCCapacity(ca,dt,isl) * lossCoeff_C ;
3330  HVDCLossSegmentMW(ca,dt,isl,los)     $ (ord(los) = 2) = HVDCCapacity(ca,dt,isl) * lossCoeff_D ;
3331  HVDCLossSegmentMW(ca,dt,isl,los)     $ (ord(los) = 3) = HVDCCapacity(ca,dt,isl) * 0.5 ;
3332  HVDCLossSegmentMW(ca,dt,isl,los)     $ (ord(los) = 4) = HVDCCapacity(ca,dt,isl) * (1 - lossCoeff_D) ;
3333  HVDCLossSegmentMW(ca,dt,isl,los)     $ (ord(los) = 5) = HVDCCapacity(ca,dt,isl) * (1 - lossCoeff_C) ;
3334  HVDCLossSegmentMW(ca,dt,isl,los)     $ (ord(los) = 6) = HVDCCapacity(ca,dt,isl) ;
3335  HVDCLossSegmentFactor(ca,dt,isl,los) $ (ord(los) = 1) = 0.01 * 0.75 * lossCoeff_C * HVDCResistance(ca,dt,isl) * HVDCCapacity(ca,dt,isl) ;
3336  HVDCLossSegmentFactor(ca,dt,isl,los) $ (ord(los) = 2) = 0.01 * lossCoeff_E * HVDCResistance(ca,dt,isl) * HVDCCapacity(ca,dt,isl) ;
3337  HVDCLossSegmentFactor(ca,dt,isl,los) $ (ord(los) = 3) = 0.01 * lossCoeff_F * HVDCResistance(ca,dt,isl) * HVDCCapacity(ca,dt,isl) ;
3338  HVDCLossSegmentFactor(ca,dt,isl,los) $ (ord(los) = 4) = 0.01 * (2 - lossCoeff_F) * HVDCResistance(ca,dt,isl) * HVDCCapacity(ca,dt,isl) ;
3339  HVDCLossSegmentFactor(ca,dt,isl,los) $ (ord(los) = 5) = 0.01 * (2 - lossCoeff_E) * HVDCResistance(ca,dt,isl) * HVDCCapacity(ca,dt,isl) ;
3340  HVDCLossSegmentFactor(ca,dt,isl,los) $ (ord(los) = 6) = 0.01 * (2 - (0.75*lossCoeff_C)) * HVDCResistance(ca,dt,isl) * HVDCCapacity(ca,dt,isl) ;
3341   
3342  * Parameter for energy lambda loss model
3343  HVDCSentBreakPointMWFlow(ca,dt,isl,bp) $ (ord(bp) = 1) = 0 ;
3344  HVDCSentBreakPointMWLoss(ca,dt,isl,bp) $ (ord(bp) = 1) = 0 ;
3345  HVDCSentBreakPointMWFlow(ca,dt,isl,bp) $ (ord(bp) > 1) = HVDCLossSegmentMW(ca,dt,isl,bp-1) ;
3346  loop( (ca,dt,isl,bp) $ {(ord(bp) > 1) and (ord(bp) <= 7)},
3347      HVDCSentBreakPointMWLoss(ca,dt,isl,bp) = HVDClossScalingFactor(ca,dt) * HVDCLossSegmentFactor(ca,dt,isl,bp-1) * [ HVDCLossSegmentMW(ca,dt,isl,bp-1) - HVDCSentBreakPointMWFlow(ca,dt,isl,bp-1) ] + HVDCSentBreakPointMWLoss(ca,dt,isl,bp-1) ;
3348  ) ;
3349   
3350  * Parameter for energy+reserve lambda loss model
3351  * Ideally SO should use asymmetric loss curve
3352  HVDCReserveBreakPointMWFlow(ca,dt,isl,rsbp) $ (ord(rsbp) <= 7) = sum[ (isl1,rsbp1) $ { ( not sameas(isl1,isl) ) and ( ord(rsbp) + ord(rsbp1) = 8) }, -HVDCSentBreakPointMWFlow(ca,dt,isl1,rsbp1) ];
3353  HVDCReserveBreakPointMWLoss(ca,dt,isl,rsbp) $ (ord(rsbp) <= 7) = sum[ (isl1,rsbp1) $ { ( not sameas(isl1,isl) ) and ( ord(rsbp) + ord(rsbp1) = 8) }, HVDCSentBreakPointMWLoss(ca,dt,isl1,rsbp1) ];
3354  * However, SO decide to use symmetric loss curve instead
3355  HVDCReserveBreakPointMWFlow(ca,dt,isl,rsbp) $ (ord(rsbp) <= 7) = sum[ rsbp1 $ { ord(rsbp) + ord(rsbp1) = 8 }, -HVDCSentBreakPointMWFlow(ca,dt,isl,rsbp1) ];
3356  HVDCReserveBreakPointMWFlow(ca,dt,isl,rsbp) $ { (ord(rsbp) > 7) and (ord(rsbp) <= 13) } = HVDCSentBreakPointMWFlow(ca,dt,isl,rsbp-6) ;
3357  HVDCReserveBreakPointMWLoss(ca,dt,isl,rsbp) $ (ord(rsbp) <= 7) = sum[ rsbp1 $ { ord(rsbp) + ord(rsbp1) = 8 }, HVDCSentBreakPointMWLoss(ca,dt,isl,rsbp1) ];
3358  HVDCReserveBreakPointMWLoss(ca,dt,isl,rsbp) $ { (ord(rsbp) > 7) and (ord(rsbp) <= 13) } = HVDCSentBreakPointMWLoss(ca,dt,isl,rsbp-6);
3359   
3360  * Data appllied to Real Time Pricing
3361    useGenInitialMW(ca,dt)            = dtParameter(ca,dt,'useGenInitialMW') ;
3362    useActualLoad(ca,dt)              = dtParameter(ca,dt,'useActualLoad') ;
3363    maxSolveLoops(ca,dt)              = dtParameter(ca,dt,'maxSolveLoop') ;
3364    islandMWIPS(ca,dt,isl)            = islandParameter(ca,dt,isl,'MWIPS') ;
3365    islandPDS(ca,dt,isl)              = islandParameter(ca,dt,isl,'PSD') ;
3366    islandLosses(ca,dt,isl)           = islandParameter(ca,dt,isl,'Losses') ;
3367    SPDLoadCalcLosses(ca,dt,isl)      = islandParameter(ca,dt,isl,'SPDLoadCalcLosses') ;
3368   
3369  * For PRICERESPONSIVEIG generators, The RTD rampRateUp is capped: (4.7.2.2)
3370  rampRateUp(offer(ca,dt,o)) $ { (studyMode(ca,dt) = 101 or studyMode(ca,dt) = 201) and intermittentOffer(offer) and priceResponsive(offer) }
3371                             = Min[ rampRateUp(offer), dtParameter(ca,dt,'igIncreaseLimitRTD')*60/intervalDuration(ca,dt) ] ;
3372   
3373  * 4.9.2 Dispatchable Pnodes
3374  * If the Pnode associated with a Dispatchable Demand Bid is not a dead Pnode then PnodeRequiredLoad is set to zero. This is not applicable for "difference bid"
3375  requiredLoad(node(ca,dt,n)) $ { sum[ (bd,blk) $ ( bidNode(ca,dt,bd,n) and (bidParameter(ca,dt,bd,'difference') = 0 ) ), DemBidMW(ca,dt,bd,blk) ] > 0 } = 0;
3376  *-------------------------------------------------------------------------------
3377   
3378  * Initialize energy scarcity limits and prices ---------------------------------
3379  energyScarcityEnabled(ca,dt)                 = dtParameter(ca,dt,'enrgScarcity') ;
3380  reserveScarcityEnabled(ca,dt)                = dtParameter(ca,dt,'resrvScarcity') ;
3381  scarcityResrvIslandLimit(ca,dt,isl,resC,blk) = scarcityResrvLimit(ca,dt,isl,resC,blk,'limitMW') ;
3382  scarcityResrvIslandPrice(ca,dt,isl,resC,blk) = scarcityResrvLimit(ca,dt,isl,resC,blk,'price') ;
3383   
3384   
3385  * TN - Pivot or demand analysis begin
3388  * TN - Pivot or demand analysis begin end
3389   
3390  *=====================================================================================
3391  * 7. The vSPD solve loop
3392  *=====================================================================================
3393   
3394   
3395  * Need to initiate value for this parameters before it is used
3396  o_offerEnergy_TP(ca,dt,o) = 0;
3397   
3398  LoadCalcLosses(ca,dt,isl) = islandLosses(ca,dt,isl);
3399  DidShortfallTransfer(ca,dt,n) = 0;
3400  ShortfallDisabledScaling(ca,dt,n) = 0;
3401  CheckedNodeCandidate(ca,dt,n) = 0;
3402  PotentialModellingInconsistency(ca,dt,n)= 1 $ { sum[ branch(ca,dt,br) $ nodeoutagebranch(ca,dt,n,br), 1] < sum[ br $ nodeoutagebranch(ca,dt,n,br), 1] } ;
3403   
3404  unsolvedDT(ca,dt) = yes $ case2dt(ca,dt) ;
3405  VSPDModel(ca,dt) = 0 ;
3406  LoopCount(ca,dt) = 1 $ case2dt(ca,dt) ;
3407  IsNodeDead(ca,dt,n) = 0 ;
3408  nodeTonode(ca,dt,n,n1) = node2node(ca,dt,n,n1) ;
3409   
3410  While ( sum[ (ca,dt) $ {unsolvedDT(ca,dt) and case2dt(ca,dt)} , 1 ],
3411   
3412    loop[ (ca,dt) $ {unsolvedDT(ca,dt) and case2dt(ca,dt) and (LoopCount(ca,dt) <= maxSolveLoops(ca,dt)) },
3413    repeat(
3414  *   7a. Reset all sets, parameters and variables -------------------------------
3415      option clear = t ;
3416  *   Generation variables
3417      option clear = GENERATION ;
3418      option clear = GENERATIONBLOCK ;
3419      option clear = GENERATIONUPDELTA ;
3420      option clear = GENERATIONDNDELTA ;
3421  *   Purchase variables
3422      option clear = PURCHASE ;
3423      option clear = PURCHASEBLOCK ;
3424  *   Network variables
3425      option clear = ACNODENETINJECTION ;
3426      option clear = ACNODEANGLE ;
3427      option clear = ACBRANCHFLOW ;
3428      option clear = ACBRANCHFLOWDIRECTED ;
3429      option clear = ACBRANCHLOSSESDIRECTED ;
3430      option clear = ACBRANCHFLOWBLOCKDIRECTED ;
3431      option clear = ACBRANCHLOSSESBLOCKDIRECTED ;
3432      option clear = ACBRANCHFLOWDIRECTED_INTEGER ;
3433      option clear = HVDCLINKFLOW ;
3434      option clear = HVDCLINKLOSSES ;
3435      option clear = LAMBDA ;
3436      option clear = LAMBDAINTEGER ;
3437      option clear = HVDCLINKFLOWDIRECTED_INTEGER ;
3438      option clear = HVDCPOLEFLOW_INTEGER ;
3439  *   Risk/Reserve variables
3440      option clear = RISKOFFSET ;
3441      option clear = HVDCREC ;
3442      option clear = ISLANDRISK ;
3443      option clear = RESERVEBLOCK ;
3444      option clear = RESERVE ;
3445      option clear = ISLANDRESERVE;
3446  *   NMIR variables
3447      option clear = SHAREDNFR ;
3448      option clear = SHAREDRESERVE ;
3449      option clear = HVDCSENT ;
3450      option clear = RESERVESHAREEFFECTIVE ;
3451      option clear = RESERVESHARERECEIVED ;
3452      option clear = RESERVESHARESENT ;
3453      option clear = HVDCSENDING ;
3454      option clear = INZONE ;
3455      option clear = HVDCSENTINSEGMENT ;
3456      option clear = HVDCRESERVESENT ;
3457      option clear = HVDCSENTLOSS ;
3458      option clear = HVDCRESERVELOSS ;
3459      option clear = LAMBDAHVDCENERGY ;
3460      option clear = LAMBDAHVDCRESERVE ;
3461      option clear = RESERVESHAREPENALTY ;
3462  *   Objective
3463      option clear = NETBENEFIT ;
3464  *   Violation variables
3465      option clear = TOTALPENALTYCOST ;
3466      option clear = DEFICITBUSGENERATION ;
3467      option clear = SURPLUSBUSGENERATION ;
3468      option clear = DEFICITRESERVE_CE ;
3469      option clear = DEFICITRESERVE_ECE ;
3470      option clear = DEFICITBRANCHSECURITYCONSTRAINT ;
3471      option clear = SURPLUSBRANCHSECURITYCONSTRAINT ;
3472      option clear = DEFICITRAMPRATE ;
3473      option clear = SURPLUSRAMPRATE ;
3474      option clear = DEFICITBRANCHFLOW ;
3475      option clear = SURPLUSBRANCHFLOW ;
3476      option clear = DEFICITMNODECONSTRAINT ;
3477      option clear = SURPLUSMNODECONSTRAINT ;
3478  *   Scarcity variables
3479      option clear = SCARCITYCOST;
3480      option clear = ENERGYSCARCITYBLK ;
3481      option clear = ENERGYSCARCITYNODE;
3482  *   Risk violation variables
3483      option clear = RESERVESHORTFALLBLK;
3484      option clear = RESERVESHORTFALL;
3485      option clear = RESERVESHORTFALLUNITBLK;
3486      option clear = RESERVESHORTFALLUNIT;
3487      option clear = RESERVESHORTFALLGROUPBLK;
3488      option clear = RESERVESHORTFALLGROUP;
3489  *   Clear the pole circular branch flow flag
3490      option clear = circularBranchFlowExist ;
3491      option clear = poleCircularBranchFlowExist ;
3492      option clear = northHVDC ;
3493      option clear = southHVDC ;
3494      option clear = manualBranchSegmentMWFlow ;
3495      option clear = manualLossCalculation ;
3496      option clear = nonPhysicalLossExist ;
3497      option clear = modelSolved ;
3498      option clear = LPmodelSolved ;
3499  *   End reset
3500   
3501   
3502  *   7b. Initialise current trade period and model data -------------------------
3503      t(ca,dt)= yes  $ case2dt(ca,dt);
3504   
3505  *   Update initial MW if run NRSS, PRSS, NRSL, PRSL
3506      generationStart(offer(t(ca,dt),o)) $ { sum[ o1, generationStart(ca,dt,o1)] = 0 } = sum[ dt1 $ (ord(dt1) = ord(dt)-1), o_offerEnergy_TP(ca,dt1,o) ] ;
3507   
3508  *   4.10 Real Time Pricing - First RTD load calculation --------------------------
3509      if ( {studyMode(ca,dt) = 101 or studyMode(ca,dt) = 201} and (dailymode = 0),
3510  *       Calculate first target total load [4.10.6.5]
3511  *       Island-level MW load forecast. For the fist loop, uses islandLosses(t,isl)
3512          TargetTotalLoad(t,isl) = islandMWIPS(t,isl) + islandPDS(t,isl) - LoadCalcLosses(t,isl) + sum[n $ nodeIsland(t,n,isl),dispatchedGeneration(t,n) - dispatchedLoad(t,n) ];
3513   
3514  *       Flag if estimate load is scalable [4.10.6.7]
3515  *       If True [1] then ConformingFactor load MW will be scaled in order to calculate EstimatedInitialLoad. If False then EstNonScalableLoad will be assigned directly to EstimatedInitialLoad
3516          EstLoadIsScalable(t,n) =  1 $ { (LoadIsNCL(t,n) = 0) and (ConformingFactor(t,n) > 0) } ;
3517   
3518  *       Calculate estimate non-scalable load [4.10.6.8]
3519  *       For a non-conforming Pnode this will be the NonConformingLoad MW input, for a conforming Pnode this will be the ConformingFactor MW input if that value is negative, otherwise it will be zero
3520          EstNonScalableLoad(t,n) $ ( LoadIsNCL(t,n) = 1 ) = NonConformingLoad(t,n);
3521          EstNonScalableLoad(t,n) $ ( LoadIsNCL(t,n) = 0 ) = ConformingFactor(t,n);
3522          EstNonScalableLoad(t,n) $ ( EstLoadIsScalable(t,n) = 1 ) = 0;
3523   
3524  *       Calculate estimate scalable load [4.10.6.10]
3525  *       For a non-conforming Pnode this value will be zero. For a conforming Pnode this value will be the ConformingFactor if it is non-negative, otherwise this value will be zero
3526          EstScalableLoad(t,n) $ ( EstLoadIsScalable(t,n) = 1 ) = ConformingFactor(t,n);
3527   
3528  *       Calculate Scaling applied to ConformingFactor load MW [4.10.6.9] in order to calculate EstimatedInitialLoad
3529          EstScalingFactor(t,isl) = (islandMWIPS(t,isl) - LoadCalcLosses(t,isl) - sum[ n $ nodeIsland(t,n,isl), EstNonScalableLoad(t,n) ]) / sum[ n $ nodeIsland(t,n,isl), EstScalableLoad(t,n) ] ;
3530   
3531  *       Calculate estimate initial load [4.10.6.6]
3532  *       Calculated estimate of initial MW load, available to be used as an alternative to InputInitialLoad
3533          EstimatedInitialLoad(t,n) $ ( EstLoadIsScalable(t,n) = 1 ) = ConformingFactor(t,n) * sum[ isl $ nodeisland(t,n,isl), EstScalingFactor(t,isl)] ;
3534          EstimatedInitialLoad(t,n) $ ( EstLoadIsScalable(t,n) = 0 ) = EstNonScalableLoad(t,n);
3535   
3536  *       Calculate initial load [4.10.6.2]
3537  *       Value that represents the Pnode load MW at the start of the solution interval. Depending on the inputs this value will be either actual load, an operator applied override or an estimated initial load
3538          InitialLoad(t,n) = InputInitialLoad(t,n);
3539          InitialLoad(t,n) $ { (LoadIsOverride(t,n) = 0) and ( (useActualLoad(t) = 0) or (LoadIsBad(t,n) = 1) ) } = EstimatedInitialLoad(t,n) ;
3540          InitialLoad(t,n) $ { (LoadIsOverride(t,n) = 1) and (useActualLoad(t) = 1) and (InitialLoad(t,n) > MaxLoad(t,n)) } = MaxLoad(t,n) ;
3541          InitialLoad(t,n) $ DidShortfallTransfer(t,n) = requiredLoad(t,n);
3542   
3543  *       Flag if load is scalable [4.10.6.4]
3544  *       If True [1] then the Pnode InitialLoad will be scaled in order to calculate requiredLoad, if False then Pnode InitialLoad will be directly assigned to requiredLoad
3545          LoadIsScalable(t,n) = 1 $ { (LoadIsNCL(t,n) = 0) and (LoadIsOverride(t,n) = 0) and (InitialLoad(t,n) >= 0) and (ShortfallDisabledScaling(t,n) = 0) and (DidShortfallTransfer(t,n) = 0) } ;
3546   
3547  *       Calculate Island-level scaling factor [4.10.6.3] --> applied to InitialLoad in order to calculate requiredLoad
3548          LoadScalingFactor(t,isl) = ( TargetTotalLoad(t,isl) - sum[n $ {nodeIsland(t,n,isl) and (LoadIsScalable(t,n) = 0)}, InitialLoad(t,n)] ) / sum[n $ {nodeIsland(t,n,isl) and (LoadIsScalable(t,n) = 1)}, InitialLoad(t,n)] ;
3549   
3550  *       Calculate requiredLoad [4.10.6.1]
3551          requiredLoad(t,n) $ { (DidShortfallTransfer(t,n)=0) and (LoadIsScalable(t,n) = 1) } = InitialLoad(t,n) * sum[ isl $ nodeisland(t,n,isl), LoadScalingFactor(t,isl) ];
3552          requiredLoad(t,n) $ { (DidShortfallTransfer(t,n)=0) and (LoadIsScalable(t,n) = 0) } = InitialLoad(t,n);
3553          requiredLoad(t,n) $ { (DidShortfallTransfer(t,n)=0)                                } = requiredLoad(t,n) + [InstructedLoadShed(t,n) $ InstructedShedActive(t,n)];
3554   
3555      ) ;
3556   
3557   
3558  *   Recalculate energy scarcity limits -------------------------------------
3559      scarcityEnrgLimit(t,n,blk) = 0 ;
3560      scarcityEnrgLimit(t,n,blk) $ { energyScarcityEnabled(t) and (requiredLoad(t,n) > 0) }                                     = scarcityNationalFactor(t,blk,'factor') * requiredLoad(t,n);
3561      scarcityEnrgPrice(t,n,blk) $ { energyScarcityEnabled(t) and (scarcityEnrgLimit(t,n,blk) > 0 ) }                           = scarcityNationalFactor(t,blk,'price') ;
3562   
3563      scarcityEnrgLimit(t,n,blk) $ { energyScarcityEnabled(t) and (requiredLoad(t,n) > 0) and scarcityNodeFactor(t,n,blk,'factor') } = scarcityNodeFactor(t,n,blk,'factor') * requiredLoad(t,n);
3564      scarcityEnrgPrice(t,n,blk) $ { energyScarcityEnabled(t) and scarcityNodeFactor(t,n,blk,'price') }                        = scarcityNodeFactor(t,n,blk,'price') ;
3565   
3566      scarcityEnrgLimit(t,n,blk) $ { energyScarcityEnabled(t) and                             scarcityNodeLimit(t,n,blk,'limitMW')  } = scarcityNodeLimit(t,n,blk,'limitMW');
3567      scarcityEnrgPrice(t,n,blk) $ { energyScarcityEnabled(t) and scarcityNodeLimit(t,n,blk,'price') }                         = scarcityNodeLimit(t,n,blk,'price') ;
3568  *       ------------------------------------------------------------------------
3569   
3570  *   Update Free Reserve and SharedNFRmax - Pre-processing: Shared Net Free Reserve (NFR) calculation - NMIR (4.5.1.2)
3571      sharedNFRLoad(t,isl) = sum[ nodeIsland(t,n,isl), requiredLoad(t,n)] + sum[ (bd,blk) $ bidIsland(t,bd,isl), DemBidMW(t,bd,blk) ] - sharedNFRLoadOffset(t,isl) ;
3572      sharedNFRLoad(ca,dt,isl) $ { (studyMode(ca,dt) = 130) and (inputGDXGDate <= jdate(2023,04,27)) } = sum[ nodeIsland(ca,dt,n,isl), requiredLoad(ca,dt,n) + nonConformingLoad(ca,dt,n)] - sharedNFRLoadOffset(ca,dt,isl) ;
3573   
3574      sharedNFRMax(t,isl) = Min{ RMTReserveLimit(t,isl,'FIR'), sharedNFRFactor(t)*sharedNFRLoad(t,isl) } ;
3575      FreeReserve(t,isl,resC,riskC) = riskParameter(t,isl,resC,riskC,'freeReserve')
3576                                    - sum[ isl1 $ (not sameas(isl,isl1)),sharedNFRMax(t,isl1) ] $ { (ord(resC)=1) and ( (GenRisk(riskC)) or (ManualRisk(riskC)) ) } ;
3577   
3578   
3579  *   7c. Updating the variable bounds before model solve ------------------------
3580   
3581  * TN - Pivot or Demand Analysis - revise input data
3584  * TN - Pivot or Demand Analysis - revise input data end
3585   
3586  *======= GENERATION, DEMAND AND LOAD FORECAST EQUATIONS ========================
3587  *   Constraint 6.1.1.1 - Offer blocks
3588      GENERATIONBLOCK.up(genOfrBlk(t,o,blk)) = enrgOfrMW(genOfrBlk) ;
3589      GENERATIONBLOCK.fx(t,o,blk) $ (not genOfrBlk(t,o,blk)) = 0 ;
3590  *   Constraint 6.1.1.3 - Fix the invalid generation to Zero
3591      GENERATION.fx(offer(t,o)) $ (not posEnrgOfr(offer)) = 0 ;
3592  *   Constraint 6.1.1.4 - Set Upper Bound for intermittent generation
3593      GENERATION.up(offer(t,o)) $ { intermittentOffer(offer) and priceResponsive(offer) } = min[ potentialMW(offer), reserveGenMax(offer) ] ;
3594   
3595  *   Dead node pre-processing - zero cleared qunatities 4.3.1
3596      GENERATION.fx(offer(t,o)) $ sum[n $ offernode(t,o,n),IsNodeDead(t,n)] = 0 ;
3597      PURCHASE.fx(bid(t,bd)) $ sum[n $ bidnode(t,bd,n),IsNodeDead(t,n)] = 0 ;
3598   
3599  *   Constraint 6.1.1.4 & Constraint 6.1.1.5 - Set Upper/Lower Bound for Positive/Negative Demand Bid
3600      PURCHASEBLOCK.up(demBidBlk(t,bd,blk)) = DemBidMW(t,bd,blk) $ [DemBidMW(t,bd,blk) > 0];
3601      PURCHASEBLOCK.lo(demBidBlk(t,bd,blk)) = DemBidMW(t,bd,blk) $ [DemBidMW(t,bd,blk) < 0];
3602      PURCHASEBLOCK.fx(t,bd,blk) $ (not demBidBlk(t,bd,blk))= 0 ;
3603      PURCHASE.fx(t,bd) $ (sum[blk $ demBidBlk(t,bd,blk), 1] = 0) = 0 ;
3604   
3605  *   Constraint 6.1.1.7 - Set Upper Bound for Energy Scaricty Block
3606      ENERGYSCARCITYBLK.up(t,n,blk) = scarcityEnrgLimit(t,n,blk) ;
3607      ENERGYSCARCITYBLK.fx(t,n,blk) $ (not EnergyScarcityEnabled(t)) = 0;
3608      ENERGYSCARCITYNODE.fx(t,n) $ (not EnergyScarcityEnabled(t)) = 0;
3609  *======= GENERATION, DEMAND AND LOAD FORECAST EQUATIONS END ====================
3610   
3611  *======= HVDC TRANSMISSION EQUATIONS ===========================================
3612  *   Ensure that variables used to specify flow and losses on HVDC link are zero for AC branches and for open HVDC links.
3613      HVDCLINKFLOW.fx(t,br)   $ (not HVDClink(t,br)) = 0 ;
3614      HVDCLINKLOSSES.fx(t,br) $ (not HVDClink(t,br)) = 0 ;
3615  *   Apply an upper bound on the weighting parameter based on its definition
3616      LAMBDA.up(branch,bp) = 1 ;
3617  *   Ensure that the weighting factor value is zero for AC branches and for invalid loss segments on HVDC links
3618      LAMBDA.fx(HVDClink,bp) $ ( sum[fd $ validLossSegment(HVDClink,bp,fd),1] = 0 ) = 0 ;
3619      LAMBDA.fx(t,br,bp) $ (not HVDClink(t,br)) = 0 ;
3620  *======= HVDC TRANSMISSION EQUATIONS END =======================================
3621   
3622  *======= AC TRANSMISSION EQUATIONS =============================================
3623  *   Ensure that variables used to specify flow and losses on AC branches are zero for HVDC links branches and for open AC branches.
3624      ACBRANCHFLOW.fx(t,br)              $ (not ACbranch(t,br)) = 0 ;
3625      ACBRANCHFLOWDIRECTED.fx(t,br,fd)   $ (not ACbranch(t,br)) = 0 ;
3626      ACBRANCHLOSSESDIRECTED.fx(t,br,fd) $ (not ACbranch(t,br)) = 0 ;
3627  *   Ensure directed block flow and loss block variables are zero for non-AC branches and invalid loss segments on AC branches.
3628      ACBRANCHFLOWBLOCKDIRECTED.fx(t,br,los,fd)   $ { not(ACbranch(t,br) and validLossSegment(t,br,los,fd)) } = 0 ;
3629      ACBRANCHLOSSESBLOCKDIRECTED.fx(t,br,los,fd) $ { not(ACbranch(t,br) and validLossSegment(t,br,los,fd)) } = 0 ;
3630  *   Constraint 6.4.1.10 - Ensure that the bus voltage angle for the buses corresponding to the reference nodes and the HVDC nodes are set to zero.
3631      ACNODEANGLE.fx(t,b) $ sum[ n $ { NodeBus(t,n,b) and refNode(t,n) }, 1 ] = 0 ;
3632  *======= AC TRANSMISSION EQUATIONS END =========================================
3633   
3634  *======= RISK & RESERVE EQUATIONS ==============================================
3635  *   Ensure that all the invalid reserve blocks are set to zero for offers and purchasers.
3636      RESERVEBLOCK.fx(offer(t,o),blk,resC,resT) $ (not resOfrBlk(offer,blk,resC,resT)) = 0 ;
3637  *   Constraint 6.5.3.2 - Reserve block maximum for offers and purchasers.
3638      RESERVEBLOCK.up(resOfrBlk(t,o,blk,resC,resT)) = resrvOfrMW(resOfrBlk) ;
3639  *   Fix the reserve variable for invalid reserve offers. These are offers that are either not connected to the grid or have no reserve quantity offered.
3640      RESERVE.fx(t,o,resC,resT) $ (not sum[ blk $ resOfrBlk(t,o,blk,resC,resT), 1 ] ) = 0 ;
3641  *   NMIR project variables
3642      HVDCSENT.fx(t,isl)     $ (HVDCCapacity(t,isl) = 0) = 0 ;
3643      HVDCSENTLOSS.fx(t,isl) $ (HVDCCapacity(t,isl) = 0) = 0 ;
3644  *   Constraint 6.5.3.2.3 - SPD version 12.0
3645      SHAREDNFR.up(t,isl) = Max[0,sharedNFRMax(t,isl)] ;
3646  *   No forward reserve sharing if HVDC capacity is zero
3647      RESERVESHARESENT.fx(t,isl,resC,rd) $ { (HVDCCapacity(t,isl) = 0) and (ord(rd) = 1) } = 0 ;
3648  *   No forward reserve sharing if reserve sharing is disabled
3649      RESERVESHARESENT.fx(t,isl,resC,rd) $ (reserveShareEnabled(t,resC) = 0) = 0;
3650  *   No reserve sharing to cover HVDC risk
3651      RESERVESHAREEFFECTIVE.fx(t,isl,resC,HVDCrisk) = 0;
3652      RESERVESHAREEFFECTIVE.fx(t,isl,resC,HVDCsecRisk) = 0;
3653  *   Constraint 6.5.2.16 - no RP zone if reserve round power disabled
3654      INZONE.fx(t,isl,resC,z) $ {(ord(z) = 1) and (not reserveRoundPower(t,resC))} = 0;
3655  *   Constraint 6.5.2.17 - no no-reserve zone for SIR zone if reserve RP enabled
3656      INZONE.fx(t,isl,resC,z) $ {(ord(resC)=2) and (ord(z)=2) and reserveRoundPower(t,resC)} = 0;
3657  *   Fixing Lambda integer variable for energy sent
3658      LAMBDAHVDCENERGY.fx(t,isl,bp) $ { (HVDCCapacity(t,isl) = 0) and (ord(bp) = 1) } = 1 ;
3659      LAMBDAHVDCENERGY.fx(t,isl,bp) $ (ord(bp) > 7) = 0 ;
3660      LAMBDAHVDCRESERVE.fx(t,isl,resC,rd,rsbp) $ { (HVDCCapacity(t,isl) = 0) and (ord(rsbp) = 7) and (ord(rd) = 1) } = 1 ;
3661      LAMBDAHVDCRESERVE.fx(t,isl,resC,rd,rsbp) $ { (sum[isl1 $ (not sameas(isl1,isl)), HVDCCapacity(t,isl1)] = 0) and (ord(rsbp) < 7) and (ord(rd) = 2) } = 0 ;
3662  *   Contraint 6.5.4.1 - Set Upper Bound for reserve shortfall
3663      RESERVESHORTFALLBLK.up(t,isl,resC,riskC,blk)         = scarcityResrvIslandLimit(t,isl,resC,blk) $ reserveScarcityEnabled(t);
3664      RESERVESHORTFALLBLK.fx(t,isl,resC,riskC,blk)         $ (not reserveScarcityEnabled(t)) = 0;
3665      RESERVESHORTFALL.fx(t,isl,resC,riskC)                $ (not reserveScarcityEnabled(t)) = 0;
3666      RESERVESHORTFALLUNITBLK.up(t,isl,o,resC,riskC,blk)   = scarcityResrvIslandLimit(t,isl,resC,blk) $ reserveScarcityEnabled(t);
3667      RESERVESHORTFALLUNITBLK.fx(t,isl,o,resC,riskC,blk)   $ (not reserveScarcityEnabled(t)) = 0;
3668      RESERVESHORTFALLUNIT.fx(t,isl,o,resC,riskC)          $ (not reserveScarcityEnabled(t)) = 0;
3669      RESERVESHORTFALLGROUPBLK.up(t,isl,rg,resC,riskC,blk) = scarcityResrvIslandLimit(t,isl,resC,blk) $ reserveScarcityEnabled(t);
3670      RESERVESHORTFALLGROUPBLK.fx(t,isl,rg,resC,riskC,blk) $ (not reserveScarcityEnabled(t)) = 0;
3671      RESERVESHORTFALLGROUP.fx(t,isl,rg,resC,riskC)        $ (not reserveScarcityEnabled(t)) = 0;
3672  ;
3673  *======= RISK & RESERVE EQUATIONS END ==========================================
3674   
3675  *   Updating the variable bounds before model solve end
3676   
3677   
3678  *   7d. Solve Models
3679   
3680  *   Solve the NMIR model -------------------------------------------------------
3681      if ( sum[t(ca,dt), VSPDModel(t)] = 0,
3682   
3683          option bratio = 1 ;
3684          vSPD_NMIR.Optfile = 1 ;
3685          vSPD_NMIR.optcr = MIPOptimality ;
3686          vSPD_NMIR.reslim = MIPTimeLimit ;
3687          vSPD_NMIR.iterlim = MIPIterationLimit ;
3688          solve vSPD_NMIR using mip maximizing NETBENEFIT ;
3689  *       Set the model solve status
3690          ModelSolved = 1 $ { ( (vSPD_NMIR.modelstat = 1) or (vSPD_NMIR.modelstat = 8) ) and ( vSPD_NMIR.solvestat = 1 ) } ;
3691   
3692  *       Post a progress message to the console and for use by EMI.
3693          if (ModelSolved = 1,
3694              loop (t,
3695                  putclose rep 'The caseID: ' ca.tl ' (' dt.tl ') is 1st solved successfully.'/
3696                               'Objective function value: ' NETBENEFIT.l:<15:4 /
3697                               'Violations cost         : ' TOTALPENALTYCOST.l:<15:4 /
3698              ) ;
3699          elseif (ModelSolved = 0) and (sequentialSolve = 1),
3700              loop (t,
3701                  unsolvedDT(t) = no;
3702                  putclose rep 'The caseID: ' ca.tl ' (' dt.tl ') is 1st solved unsuccessfully.'/
3703              ) ;
3704   
3705          ) ;
3706   
3707  *       Post-Solve - Circulating flow check ------------------------------------
3708          if((ModelSolved = 1),
3709              Loop( t $ (VSPDModel(t)=0) ,
3710  *               Check if there are circulating branch flows on loss AC branches
3711                  circularBranchFlowExist(LossBranch(ACbranch(t,br))) $ { sum[fd, ACBRANCHFLOWDIRECTED.l(ACbranch,fd)] - abs(ACBRANCHFLOW.l(ACbranch)) > circularBranchFlowTolerance } = 1 ;
3712  *               Determine the circular branch flow flag on each HVDC pole
3713                  TotalHVDCpoleFlow(t,pole) = sum[ br $ HVDCpoleBranchMap(pole,br), HVDCLINKFLOW.l(t,br) ] ;
3714                  MaxHVDCpoleFlow(t,pole) = smax[ br $ HVDCpoleBranchMap(pole,br), HVDCLINKFLOW.l(t,br) ] ;
3715                  poleCircularBranchFlowExist(t,pole) $ { TotalHVDCpoleFlow(t,pole) - MaxHVDCpoleFlow(t,pole) > circularBranchFlowTolerance } = 1 ;
3716  *               Check if there are circulating branch flows on HVDC
3717                  NorthHVDC(t) = sum[ (isl,b,br) $ { (ord(isl) = 2) and busIsland(t,b,isl) and HVDClinkSendingBus(t,br,b) and HVDClink(t,br) }, HVDCLINKFLOW.l(t,br) ] ;
3718                  SouthHVDC(t) = sum[ (isl,b,br) $ { (ord(isl) = 1) and busIsland(t,b,isl) and HVDClinkSendingBus(t,br,b) and HVDClink(t,br) }, HVDCLINKFLOW.l(t,br) ] ;
3719                  circularBranchFlowExist(t,br) $ { HVDClink(t,br) and LossBranch(t,br) and (NorthHVDC(t) > circularBranchFlowTolerance) and (SouthHVDC(t) > circularBranchFlowTolerance) } = 1 ;
3720  *               Check if there are non-physical losses on HVDC links
3721                  ManualBranchSegmentMWFlow(LossBranch(HVDClink(t,br)),los,fd) $ { ( ord(los) <= branchLossBlocks(HVDClink) ) and validLossSegment(t,br,los,fd) }
3722                      = Min[ Max( 0, [ abs(HVDCLINKFLOW.l(HVDClink)) - [LossSegmentMW(HVDClink,los-1,fd) $ (ord(los) > 1)] ] ), ( LossSegmentMW(HVDClink,los,fd) - [LossSegmentMW(HVDClink,los-1,fd) $ (ord(los) > 1)] ) ] ;
3723                  ManualLossCalculation(LossBranch(HVDClink(t,br))) = sum[ (los,fd) $ validLossSegment(t,br,los,fd), LossSegmentFactor(HVDClink,los,fd) * ManualBranchSegmentMWFlow(HVDClink,los,fd) ] ;
3724                  NonPhysicalLossExist(LossBranch(HVDClink(t,br))) $ { abs( HVDCLINKLOSSES.l(HVDClink) - ManualLossCalculation(HVDClink) ) > NonPhysicalLossTolerance } = 1 ;
3725  *               Set UseBranchFlowMIP = 1 if the number of circular branch flow or non-physical loss branches exceeds the specified tolerance
3726                  useBranchFlowMIP(t) $ { ( sum[ br $ { ACbranch(t,br) and LossBranch(t,br) }, resolveCircularBranchFlows * circularBranchFlowExist(t,br)]
3727                                          + sum[ br $ { HVDClink(t,br) and LossBranch(t,br) }, resolveCircularBranchFlows * circularBranchFlowExist(t,br)]
3728                                          + sum[ br $ { HVDClink(t,br) and LossBranch(t,br) }, resolveHVDCnonPhysicalLosses * NonPhysicalLossExist(t,br) ]
3729                                          + sum[ pole, resolveCircularBranchFlows * poleCircularBranchFlowExist(t,pole)]
3730                                          ) > UseBranchFlowMIPTolerance
3731                                        } = 1 ;
3732   
3733   
3734   
3735              );
3736  *           Post-Solve - Circulating flow check end
3737   
3738  *           A period is unsolved if MILP model is required
3739              unsolvedDT(t) = yes $ UseBranchFlowMIP(t) ;
3740   
3741  *           Post a progress message for use by EMI. Reverting to the sequential mode for integer resolves.
3742              loop( unsolvedDT(t),
3743                  if( UseBranchFlowMIP(t) >= 1,
3744                      VSPDModel(t) = 1;
3745                      putclose rep 'The caseID: ' ca.tl ' requires a vSPD_BranchFlowMIP resolve for period ' dt.tl '.'/
3746                  ) ;
3747              ) ;
3748          ) ;
3749  *   Check if the NMIR results are valid end
3750      ) ;
3751  *   Solve the NMIR model end ---------------------------------------------------
3752   
3753   
3754  *   Solve the vSPD_BranchFlowMIP -----------------------------------------------
3755      if ( smax[t, VSPDModel(t)] = 1,
3756  *       Fix the values of these integer variables that are not needed
3757          ACBRANCHFLOWDIRECTED_INTEGER.fx(branch(t,br),fd) $ { (not ACbranch(t,br)) or (not LossBranch(branch)) } = 0 ;
3758  *       Fix the integer AC branch flow variable to zero for invalid branches
3759          ACBRANCHFLOWDIRECTED_INTEGER.fx(t,br,fd) $ (not branch(t,br)) = 0 ;
3760  *       Apply an upper bound on the integer weighting parameter
3761          LAMBDAINTEGER.up(branch(t,br),bp) = 1 ;
3762  *       Ensure that the weighting factor value is zero for AC branches and for invalid loss segments on HVDC links
3763          LAMBDAINTEGER.fx(branch(t,br),bp) $ { ACbranch(branch) or ( sum[fd $ validLossSegment(branch,bp,fd),1 ] = 0 ) } = 0 ;
3764  *       Fix the lambda integer variable to zero for invalid branches
3765          LAMBDAINTEGER.fx(t,br,bp) $ (not branch(t,br)) = 0 ;
3766   
3767          option bratio = 1 ;
3768          vSPD_BranchFlowMIP.Optfile = 1 ;
3769          vSPD_BranchFlowMIP.optcr = MIPOptimality ;
3770          vSPD_BranchFlowMIP.reslim = MIPTimeLimit ;
3771          vSPD_BranchFlowMIP.iterlim = MIPIterationLimit ;
3772          solve vSPD_BranchFlowMIP using mip maximizing NETBENEFIT ;
3773  *       Set the model solve status
3774          ModelSolved = 1 $ { [ ( vSPD_BranchFlowMIP.modelstat = 1) or (vSPD_BranchFlowMIP.modelstat = 8) ] and [ vSPD_BranchFlowMIP.solvestat = 1 ] } ;
3775   
