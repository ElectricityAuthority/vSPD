5282  *+++ vSPD settings +++
5285   
5286  *+++ Paths +++
5288   
5293   
5295   
5296  *+++ Model +++
5297  Scalar sequentialSolve                   / 0 / ;   ! Vectorisation: Yes <-> i_SequentialSolve: 0
5298  Scalar dailymode                         / 1 / ;   ! Solving quickly by using RTD pre-calculated demand or PRSS solved initial MW
5299   
5300  *+++ Network +++
5301  Scalar useACLossModel                    / 1 /    ;
5302  Scalar useHVDCLossModel                  / 1 /    ;
5303  Scalar useACBranchLimits                 / 1 /    ;
5304  Scalar useHVDCBranchLimits               / 1 /    ;
5305  Scalar resolveCircularBranchFlows        / 1 /    ;
5306  Scalar resolveHVDCNonPhysicalLosses      / 1 /    ;
5307  Scalar resolveACNonPhysicalLosses        / 0 /    ;   ! Placeholder for future code development
5308  Scalar circularBranchFlowTolerance       / 1e-4 / ;
5309  Scalar nonPhysicalLossTolerance          / 1e-6 / ;
5310  Scalar useBranchFlowMIPTolerance         / 1e-6 / ;
5311   
5312  *+++ Constraints +++
5313  Scalar useReserveModel                   / 1 /    ;
5314  Scalar suppressMixedConstraint           / 0 /    ;   ! No longer used since Mixed MIP Constraints no longer exists
5315  Scalar mixedMIPtolerance                 / 1e-6 / ;   ! No longer used since Mixed MIP Constraints no longer exists
5316   
5317  *+++ Solver +++
5318  Scalar LPtimeLimit                       / 3600 / ;
5319  Scalar LPiterationLimit                  / 2000000000 / ;
5320  Scalar MIPtimeLimit                      / 3600 / ;
5321  Scalar MIPiterationLimit                 / 2000000000 / ;
5322  Scalar MIPoptimality                     / 0 / ;
5325   
5326   
5327  *+++ Various switches +++
INCLUDE    C:\GitHub\vSPD\Programs\vSPDcase.inc
5331   
5332  * Update the ProgressReport.txt file
5333  File rep "Write to a report" /"ProgressReport.txt"/;  rep.lw = 0;  rep.ap = 1; rep.nd = 4; rep.nw=8;
5334  putclose rep / 'Case "Pricing_20240620" started at: ' system.date " " system.time /;
5335   
5336  * Set the solver for the LP and MIP
5337  option lp = Cplex ;
5338  option mip = Cplex ;
5339   
5340  * Set profile status
5341  option profile = 0 ;
5342   
5343  * Set the solution print status in the lst file
5344  option solprint = off;
5345   
5346  * Set the column (variable) and row (equation) listing in the lst file
5347  option limcol = 0 ;
5348  option limrow = 0 ;
5349   
5350  * Declare a temporary file
5351  File temp ;
5352   
5353  * Allow empty data set declaration
5355   
