5509    o_brConstraintLHS_TP(ca,dt,brCstr)                     'Branch constraint LHS for each output report'
5510    o_brConstraintRHS_TP(ca,dt,brCstr)                     'Branch constraint RHS for each output report'
5511    o_brConstraintPrice_TP(ca,dt,brCstr)                   'Branch constraint price for each output report'
5512  * Mnode constraint data
5513    o_MnodeConstraintSense_TP(ca,dt,MnodeCstr)             'Market node constraint sense for each output report'
5514    o_MnodeConstraintLHS_TP(ca,dt,MnodeCstr)               'Market node constraint LHS for each output report'
5515    o_MnodeConstraintRHS_TP(ca,dt,MnodeCstr)               'Market node constraint RHS for each output report'
5516    o_MnodeConstraintPrice_TP(ca,dt,MnodeCstr)             'Market node constraint price for each output report'
5517  * TradePeriod summary report
5518    o_solveOK_TP(ca,dt)                                    'Solve status for summary report (1=OK)'
5519    o_systemCost_TP(ca,dt)                                 'System cost for summary report'
5520    o_systemBenefit_TP(ca,dt)                              'System benefit of cleared bids for summary report'
5521    o_ofv_TP(ca,dt)                                        'Objective function value for summary report'
5522    o_penaltyCost_TP(ca,dt)                                'Penalty cost for summary report'
5523    o_defGenViolation_TP(ca,dt)                            'Deficit generation violation for summary report'
5524    o_surpGenViolation_TP(ca,dt)                           'Surplus generaiton violation for summary report'
5525    o_surpBranchFlow_TP(ca,dt)                             'Surplus branch flow violation for summary report'
5526    o_defRampRate_TP(ca,dt)                                'Deficit ramp rate violation for summary report'
5527    o_surpRampRate_TP(ca,dt)                               'Surplus ramp rate violation for summary report'
5528    o_surpBranchGroupConst_TP(ca,dt)                       'Surplus branch group constraint violation for summary report'
5529    o_defBranchGroupConst_TP(ca,dt)                        'Deficit branch group constraint violation for summary report'
5530    o_defMnodeConst_TP(ca,dt)                              'Deficit market node constraint violation for summary report'
5531    o_surpMnodeConst_TP(ca,dt)                             'Surplus market node constraint violation for summary report'
5532    o_defResv_TP(ca,dt)                                    'Deficit reserve violation for summary report'
5533   
5534  * Published prices
5535    o_PublisedPrice_TP(tp,n)                               'Output $/MW price at each node for the different trading periods'
5536    o_PublisedFIRPrice_TP(tp,isl)                          'Output $/MW FIR price at each island for the different trading periods'
5537    o_PublisedSIRPrice_TP(tp,isl)                          'Output $/MW SIR price at each island for the different trading periods'
5538   
5539  * Audit - extra output declaration
5540    o_lossSegmentBreakPoint(ca,dt,br,los)                            'Audit - loss segment MW'
5541    o_lossSegmentFactor(ca,dt,br,los)                                'Audit - loss factor of each loss segment'
5542    o_ACbusAngle(ca,dt,b)                                            'Audit - bus voltage angle'
5543    o_nonPhysicalLoss(ca,dt,br)                                      'Audit - non physical loss'
5544   
5545    o_ILRO_FIR_TP(ca,dt,o)                                           'Audit - ILRO FIR offer cleared (MWh)'
5546    o_ILRO_SIR_TP(ca,dt,o)                                           'Audit - ILRO SIR offer cleared (MWh)'
5547    o_ILbus_FIR_TP(ca,dt,b)                                          'Audit - ILRO FIR cleared at bus (MWh)'
5548    o_ILbus_SIR_TP(ca,dt,b)                                          'Audit - ILRO SIR cleared at bus (MWh)'
5549    o_PLRO_FIR_TP(ca,dt,o)                                           'Audit - PLRO FIR offer cleared (MWh)'
5550    o_PLRO_SIR_TP(ca,dt,o)                                           'Audit - PLRO SIR offer cleared (MWh)'
5551    o_TWRO_FIR_TP(ca,dt,o)                                           'Audit - TWRO FIR offer cleared (MWh)'
5552    o_TWRO_SIR_TP(ca,dt,o)                                           'Audit - TWRO SIR offer cleared (MWh)'
5553   
5554    o_generationRiskLevel(ca,dt,isl,o,resC,riskC)                    'Audit - generation risk'
5555    o_HVDCriskLevel(ca,dt,isl,resC,riskC)                            'Audit - DCCE and DCECE risk'
5556    o_manuRiskLevel(ca,dt,isl,resC,riskC)                            'Audit - manual risk'
5557    o_genHVDCriskLevel(ca,dt,isl,o,resC,riskC)                       'Audit - generation + HVDC secondary risk'
5558    o_manuHVDCriskLevel(ca,dt,isl,resC,riskC)                        'Audit - manual + HVDC secondary'
5559    o_generationRiskGroupLevel(ca,dt,isl,rg,resC,riskC)              'Audit - generation group risk'
5560   
5561  * TN - output parameters added for NMIR project --------------------------------
5562    o_FirSent_TP(ca,dt,isl)                        'FIR export from an island for each trade period'
5563    o_SirSent_TP(ca,dt,isl)                        'SIR export from an island for each trade period'
5564    o_FirReceived_TP(ca,dt,isl)                    'FIR received at an island for each trade period'
5565    o_SirReceived_TP(ca,dt,isl)                    'SIR received at an island for each trade period'
5566    o_FirEffReport_TP(ca,dt,isl)                   'Effective FIR share for reporting to an island for each trade period'
5567    o_SirEffReport_TP(ca,dt,isl)                   'Effective FIR share for reporting to an island for each trade period'
5568    o_EffectiveRes_TP(ca,dt,isl,resC,riskC)        'Effective reserve share to an island for each trade period'
5569    o_FirEffectiveCE_TP(ca,dt,isl)                 'Effective FIR share to an island for each trade period'
5570    o_SirEffectiveCE_TP(ca,dt,isl)                 'Effective FIR share to an island for each trade period'
5571    o_FirEffectiveECE_TP(ca,dt,isl)                'Effective FIR share to an island for each trade period'
5572    o_SirEffectiveECE_TP(ca,dt,isl)                'Effective FIR share to an island for each trade period'
5573   
5574    o_TotalIslandReserve(ca,dt,isl,resC,riskC)     'Total Reserve cleared in a island including shared Reserve'
5575  * TN - output parameters added for NMIR project end ----------------------------
5576    ;
5577   
5578  Scalars
5579    modelSolved                   'Flag to indicate if the model solved successfully (1 = Yes)'                                           / 0 /
5580    LPmodelSolved                 'Flag to indicate if the final LP model (when MIP fails) is solved successfully (1 = Yes)'              / 0 /
5581    exitLoop                      'Flag to exit solve loop'                                                                               / 0 /
5582    SPDlossTolerance              'Tolerance to check loadlosss calculation'                                                              / 0.00005 /
5583    ;
5584   
5585   
5586   
5587  *=====================================================================================
5588  * 2. Load data from GDX file
5589  *=====================================================================================
5590   
5591  * If input file does not exist then go to the next input file
5593   
5594  * Load trading period to be solved
GDXIN   C:\GitHub\vSPD\Programs\vSPDPeriod.gdx
--- LOAD  ca = 1:i_caseID
--- LOAD  dt = 3:i_dateTime
--- LOAD  tp = 2:i_tradePeriod
--- LOAD  case2dt2tp = 4:i_DateTimeTradePeriod
5599   
5600  * Call the GDX routine and load the input data:
GDXIN   C:\GitHub\vSPD\Input\Pricing_20240620.gdx
--- LOAD  gdxDate = 1:i_gdxDate
--- LOAD  caseDefn = 2:i_caseDefn
--- LOAD  runMode = 3:i_runMode
5603   
--- LOAD  dtParameter = 5:i_dateTimeParameter
--- LOAD  islandParameter = 6:i_dateTimeIslandParameter
5605   
--- LOAD  n = 7:i_node
--- LOAD  node2node = 8:i_dateTimeNodetoNode
--- LOAD  nodeParameter = 9:i_dateTimeNodeParameter
5607   
--- LOAD  b = 10:i_bus
--- LOAD  busIsland = 11:i_dateTimeBusIsland
--- LOAD  busElectricalIsland = 12:i_dateTimeBusElectricalIsland
--- LOAD  nodeBus = 13:i_dateTimeNodeBus
--- LOAD  nodeBusAllocationFactor = 14:i_dateTimeNodeBusAllocationFactor
5610   
--- LOAD  branchDefn = 15:i_dateTimeBranchDefn
--- LOAD  nodeoutagebranch = 16:i_dateTimeNodeOutageBranch
--- LOAD  branchParameter = 17:i_dateTimeBranchParameter
--- LOAD  branchCstrFactors = 19:i_dateTimeBranchConstraintFactors
--- LOAD  branchCstrRHS = 18:i_dateTimeBranchConstraintRHS
5613   
--- LOAD  offerNode = 20:i_dateTimeOfferNode
--- LOAD  offerTrader = 21:i_dateTimeOfferTrader
--- LOAD  primarySecondaryOffer = 22:i_dateTimePrimarySecondaryOffer
--- LOAD  energyOffer = 25:i_dateTimeEnergyOffer
--- LOAD  reserveOffer = 26:i_dateTimeReserveOffer
--- LOAD  offerParameter = 23:i_dateTimeOfferParameter
5616   
--- LOAD  bidNode = 27:i_dateTimeBidNode
--- LOAD  bidTrader = 28:i_dateTimeBidTrader
--- LOAD  energyBid = 30:i_dateTimeEnergyBid
--- LOAD  bidParameter = 29:i_dateTimeBidParameter
5619   
--- LOAD  mnCnstrRHS = 31:i_dateTimeMNCnstrRHS
--- LOAD  mnCstrEnrgFactors = 32:i_dateTimeMNCnstrEnrgFactors
--- LOAD  mnCnstrResrvFactors = 33:i_dateTimeMNCnstrResrvFactors
--- LOAD  mnCnstrEnrgBidFactors = 34:i_dateTimeMNCnstrEnrgBidFactors
--- LOAD  mnCnstrResrvBidFactors = 35:i_dateTimeMNCnstrResrvBidFactors
5623   
--- LOAD  riskParameter = 36:i_dateTimeRiskParameter
--- LOAD  reserveSharingParameter = 37:i_dateTimeReserveSharing
--- LOAD  riskGroupOffer = 24:i_dateTimeRiskGroup
5625   
--- LOAD  scarcityNationalFactor = 38:i_dateTimeScarcityNationalFactor
--- LOAD  scarcityResrvLimit = 39:i_dateTimeScarcityResrvLimit
--- LOAD  scarcityNodeFactor = 40:i_dateTimeScarcityNodeFactor
--- LOAD  scarcityNodeLimit = 41:i_dateTimeScarcityNodeLimit
5628   
--- LOAD  casefileseconds = 42:i_priceCaseFilesPublishedSecs
5630   
5632   
5633  *===============================================================================
5634  * 3. Manage model and data compatability
5635  *===============================================================================
5636  * This section manages the changes to model flags to ensure backward
5637  * compatibility given changes in the SPD model formulation over time:
5638  * Ex: some data (sets) only starting to exist at certain time and we need to use
5639  * GDX time to check if we can load that data (set) from gdx.
5640   
5641  * Gregorian date of when symbols have been included into the GDX files
5642  Scalars inputGDXGDate                     'Gregorian date of input GDX file' ;
5643   
5644  inputGDXGDate = jdate(gdxDate('year'),gdxDate('month'),gdxDate('day'));
5645   
5646  if (inputGDXGDate <= jdate(2023,4,27),
5647    SPDlossTolerance = 0.005 ;
5648  );
5649   
5650  *=====================================================================================
5651  * 4. Input data overrides - declare and apply (include vSPDoverrides.gms)
5652  *=====================================================================================
5653   
       - At this point, vSPDoverrides.gms is included into vSPDsolve.gms if an override
         file defined by the $setglobal vSPDinputOvrdData in vSPDSetting.inc exists.
       - All override data symbols have the characters 'Ovrd' appended to the original
         symbol name. After declaring the override symbols, the override data is
         installed and the original symbols are overwritten.
       - Note that the Excel interface permits a limited number of input data symbols
         to be overridden. The EMI interface will create a GDX file of override values
         for all data inputs to be overridden. If operating in standalone mode,
         overrides can be installed by any means the user prefers - GDX file, $include
         file, hard-coding, etc. But it probably makes sense to mimic the GDX file as
         used by EMI.
5667   
5669   
5670   
5671  *===============================================================================
5672  * 5. Initialise model mapping and inputs
5673  *===============================================================================
5674   
5675  * Calculate studyMode(t) and IntervalDuration(t)
5676  studyMode(ca,dt)        = runMode(ca,'studyMode');
5677  IntervalDuration(ca,dt) = runMode(ca,'intervalLength');
5678  case2dt(ca,dt)          = yes $ sum[ tp $ case2dt2tp(ca,dt,tp), 1] ;
5679  tp2dt(tp,dt) = yes $ [ord(dt) = smin[case2dt2tp(ca,dt1,tp), ord(dt1)] ];
5680   
5681  * Nodal data
5682  node(ca,dt,n) = yes $ sum[ b $ nodeBus(ca,dt,n,b), 1 ] ;
5683  bus(ca,dt,b)  = yes $ sum[ isl $ busIsland(ca,dt,b,isl), 1 ] ;
5684  nodeIsland(ca,dt,n,isl) $ sum[ b $ { bus(ca,dt,b) and node(ca,dt,n) and nodeBus(ca,dt,n,b) and busIsland(ca,dt,b,isl) }, 1 ] = yes ;
5685   
5686  refNode(ca,dt,n)              = nodeParameter(ca,dt,n,'referenceNode') ;
5687  requiredLoad(node)            = nodeParameter(node,'demand') ;
5688  inputInitialLoad(ca,dt,n)     = nodeParameter(ca,dt,n,'initialLoad') ;
5689  conformingFactor(ca,dt,n)     = nodeParameter(ca,dt,n,'conformingFactor') ;
5690  nonConformingLoad(ca,dt,n)    = nodeParameter(ca,dt,n,'nonConformingFactor') ;
5691  loadIsOverride(ca,dt,n)       = nodeParameter(ca,dt,n,'loadIsOverride') ;
5692  loadIsBad(ca,dt,n)            = nodeParameter(ca,dt,n,'loadIsBad') ;
5693  loadIsNCL(ca,dt,n)            = nodeParameter(ca,dt,n,'loadIsNCL') ;
5694  maxLoad(ca,dt,n)              = nodeParameter(ca,dt,n,'maxLoad') ;
5695  instructedLoadShed(ca,dt,n)   = nodeParameter(ca,dt,n,'instructedLoadShed') ;
5696  instructedShedActive(ca,dt,n) = nodeParameter(ca,dt,n,'instructedShedActive') ;
5697  dispatchedLoad(ca,dt,n)       = nodeParameter(ca,dt,n,'dispatchedLoad') ;
5698  dispatchedGeneration(ca,dt,n) = nodeParameter(ca,dt,n,'dispatchedGeneration') ;
5699   
5700  * Factor to prorate the deficit and surplus at the nodal level
5701  totalBusAllocation(ca,dt,b) $ bus(ca,dt,b) = sum[ n $ Node(ca,dt,n), NodeBusAllocationFactor(ca,dt,n,b)];
5702  busNodeAllocationFactor(ca,dt,b,n) $ (totalBusAllocation(ca,dt,b) > 0) = NodeBusAllocationFactor(ca,dt,n,b) / totalBusAllocation(ca,dt,b) ;
5703   
5704  * Network data
5705  branch(ca,dt,br) = yes $ { (not branchParameter(ca,dt,br,'isOpen'))
5706                         and branchParameter(ca,dt,br,'forwardCap') and branchParameter(ca,dt,br,'backwardCap')
5707                         and sum[ (b,b1) $ { bus(ca,dt,b) and bus(ca,dt,b1) and branchDefn(ca,dt,br,b,b1) }, 1 ] }  ;
5708  branch(ca,dt,br) $ { (not branchParameter(ca,dt,br,'isOpen'))
5709                   and branchParameter(ca,dt,br,'forwardCap') and (branchParameter(ca,dt,br,'HVDCbranch'))
5710                   and sum[ (b,b1) $ { bus(ca,dt,b) and bus(ca,dt,b1) and branchDefn(ca,dt,br,b,b1) }, 1 ] } = yes ;
5711   
5712  branchBusDefn(branch,b,b1) $ branchDefn(branch,b,b1)                            = yes ;
5713  branchFrBus(branch,frB)    $ sum[ toB $ branchBusDefn(branch,frB,toB), 1 ]      = yes ;
5714  branchToBus(branch,toB)    $ sum[ frB $ branchBusDefn(branch,frB,toB), 1 ]      = yes ;
5715  branchBusConnect(branch,b) $ { branchFrBus(branch,b) or branchToBus(branch,b) } = yes ;
5716   
5717  * HVDC link and AC branch definition
5718  HVDClink(branch) = yes $ branchParameter(branch,'HVDCbranch') ;
5719  ACbranch(branch) = yes $ [not branchParameter(branch,'HVDCbranch')];
5720   
5721  * Determine sending and receiving bus for each branch flow direction
5722  loop ((frB,toB),
5723      ACbranchSendingBus(ACbranch,frB,fd)   $ { branchBusDefn(ACbranch,frB,toB) and (ord(fd) = 1) } = yes ;
5724      ACbranchReceivingBus(ACbranch,toB,fd) $ { branchBusDefn(ACbranch,frB,toB) and (ord(fd) = 1) } = yes ;
5725      ACbranchSendingBus(ACbranch,toB,fd)   $ { branchBusDefn(ACbranch,frB,toB) and (ord(fd) = 2) } = yes ;
5726      ACbranchReceivingBus(ACbranch,frB,fd) $ { branchBusDefn(ACbranch,frB,toB) and (ord(fd) = 2) } = yes ;
5727  ) ;
5728   
5729   
5730  HVDClinkSendingBus(HVDClink,frB)   $ sum[ branchBusDefn(HVDClink,frB,toB), 1 ] = yes ;
5731  HVDClinkReceivingBus(HVDClink,toB) $ sum[ branchBusDefn(HVDClink,frB,toB), 1 ] = yes ;
5732  HVDClinkBus(HVDClink,b) $ { HVDClinkSendingBus(HVDClink,b) or HVDClinkReceivingBus(HVDClink,b) }  = yes ;
5733   
5734  * Determine the HVDC inter-island pole in the northward and southward direction
5735  HVDCpoleDirection(ca,dt,br,fd) $ { (ord(fd) = 1) and HVDClink(ca,dt,br) } = yes $ sum[ (isl,NodeBus(ca,dt,n,b)) $ { (ord(isl) = 2) and nodeIsland(ca,dt,n,isl) and HVDClinkSendingBus(ca,dt,br,b) }, 1 ] ;
5736  HVDCpoleDirection(ca,dt,br,fd) $ { (ord(fd) = 2) and HVDClink(ca,dt,br) } = yes $ sum[ (isl,NodeBus(ca,dt,n,b)) $ { (ord(isl) = 1) and nodeIsland(ca,dt,n,isl) and HVDClinkSendingBus(ca,dt,br,b) }, 1 ] ;
5737   
5738  * Mapping HVDC branch to pole to account for name changes to Pole 3
5739  HVDCpoleBranchMap('Pole1',br) $ sum[ sameas(br,'BEN_HAY1.1'), 1] = yes ;
5740  HVDCpoleBranchMap('Pole1',br) $ sum[ sameas(br,'HAY_BEN1.1'), 1] = yes ;
5741  HVDCpoleBranchMap('Pole1',br) $ sum[ sameas(br,'BEN_HAY3.1'), 1] = yes ;
5742  HVDCpoleBranchMap('Pole1',br) $ sum[ sameas(br,'HAY_BEN3.1'), 1] = yes ;
5743  HVDCpoleBranchMap('Pole2',br) $ sum[ sameas(br,'BEN_HAY2.1'), 1] = yes ;
5744  HVDCpoleBranchMap('Pole2',br) $ sum[ sameas(br,'HAY_BEN2.1'), 1] = yes ;
5745   
5746  * Branch parameters (capacity, resistance, susceptance, fixedLosses, numLossTranches)
5747  branchCapacity(branch,'forward')  = branchParameter(branch,'forwardCap') ;
5748  branchCapacity(branch,'backward') = branchParameter(branch,'backwardCap') ;
5749  branchResistance(branch)          = branchParameter(branch,'resistance') ;
5750  branchSusceptance(ACbranch)       = -100 * branchParameter(ACbranch,'susceptance');
5751  branchLossBlocks(branch)          = branchParameter(branch,'numLossTranches') ;
5752  branchFixedLoss(ACbranch)         = branchParameter(ACbranch,'fixedLosses') $ (branchLossBlocks(ACbranch) > 1) ;
5753  branchFixedLoss(HVDClink)         = branchParameter(HVDClink,'fixedLosses') ;
5754   
5755   
5756  * Set resistance and fixed loss to zero if do not want to use the loss model
5757  branchResistance(ACbranch) $ (not useAClossModel) = 0 ;
5758  branchFixedLoss(ACbranch)  $ (not useAClossModel) = 0 ;
5759  branchResistance(HVDClink) $ (not useHVDClossModel) = 0 ;
5760  branchFixedLoss(HVDClink)  $ (not useHVDClossModel) = 0 ;
5761   
5762  * Initialise loss tranches data for the current trade period start. The loss factor coefficients assume that the branch capacity is in MW and the resistance is in p.u.
5763  lossSegmentMW(branch,los,fd)     $ { (branchLossBlocks(branch) = 0) and (ord(los) = 1) } = branchCapacity(branch,fd) ;
5764  LossSegmentFactor(branch,los,fd) $ { (branchLossBlocks(branch) = 0) and (ord(los) = 1) } = 0 ;
5765   
5766  LossSegmentMW(branch,los,fd)     $ { (branchLossBlocks(branch) = 1) and (ord(los) = 1) } = maxFlowSegment ;
5767  LossSegmentFactor(branch,los,fd) $ { (branchLossBlocks(branch) = 1) and (ord(los) = 1) } = 0.01 * branchResistance(branch) * branchCapacity(branch,fd) ;
5768   
5769  LossSegmentMW(branch,los,fd)     $ { (branchLossBlocks(branch) = 3) and (ord(los) = 1) } = lossCoeff_A * branchCapacity(branch,fd) ;
5770  LossSegmentMW(branch,los,fd)     $ { (branchLossBlocks(branch) = 3) and (ord(los) = 2) } = (1-lossCoeff_A) * branchCapacity(branch,fd) ;
5771  LossSegmentMW(branch,los,fd)     $ { (branchLossBlocks(branch) = 3) and (ord(los) = 3) } = maxFlowSegment ;
5772  LossSegmentFactor(branch,los,fd) $ { (branchLossBlocks(branch) = 3) and (ord(los) = 2) } = 0.01 * branchResistance(branch) * branchCapacity(branch,fd) ;
5773  LossSegmentFactor(branch,los,fd) $ { (branchLossBlocks(branch) = 3) and (ord(los) = 1) } = 0.01 * 0.75 * lossCoeff_A * branchResistance(branch) * branchCapacity(branch,fd) ;
5774  LossSegmentFactor(branch,los,fd) $ { (branchLossBlocks(branch) = 3) and (ord(los) = 3) } = 0.01 * (2 - (0.75*lossCoeff_A)) * branchResistance(branch) * branchCapacity(branch,fd) ;
5775   
5776  LossSegmentMW(branch,los,fd)     $ { (branchLossBlocks(branch) = 6) and (ord(los) = 1) } = lossCoeff_C  * branchCapacity(branch,fd) ;
5777  LossSegmentMW(branch,los,fd)     $ { (branchLossBlocks(branch) = 6) and (ord(los) = 2) } = lossCoeff_D * branchCapacity(branch,fd) ;
5778  LossSegmentMW(branch,los,fd)     $ { (branchLossBlocks(branch) = 6) and (ord(los) = 3) } = 0.5 * branchCapacity(branch,fd) ;
5779  LossSegmentMW(branch,los,fd)     $ { (branchLossBlocks(branch) = 6) and (ord(los) = 4) } = (1 - lossCoeff_D) * branchCapacity(branch,fd) ;
5780  LossSegmentMW(branch,los,fd)     $ { (branchLossBlocks(branch) = 6) and (ord(los) = 5) } = (1 - lossCoeff_C) * branchCapacity(branch,fd) ;
5781  LossSegmentMW(branch,los,fd)     $ { (branchLossBlocks(branch) = 6) and (ord(los) = 6) } = maxFlowSegment ;
5782  LossSegmentFactor(branch,los,fd) $ { (branchLossBlocks(branch) = 6) and (ord(los) = 1) } = 0.01 * 0.75 * lossCoeff_C * branchResistance(branch) * branchCapacity(branch,fd) ;
5783  LossSegmentFactor(branch,los,fd) $ { (branchLossBlocks(branch) = 6) and (ord(los) = 2) } = 0.01 * lossCoeff_E * branchResistance(branch) * branchCapacity(branch,fd) ;
5784  LossSegmentFactor(branch,los,fd) $ { (branchLossBlocks(branch) = 6) and (ord(los) = 3) } = 0.01 * lossCoeff_F * branchResistance(branch) * branchCapacity(branch,fd) ;
5785  LossSegmentFactor(branch,los,fd) $ { (branchLossBlocks(branch) = 6) and (ord(los) = 4) } = 0.01 * (2 - lossCoeff_F) * branchResistance(branch) * branchCapacity(branch,fd) ;
5786  LossSegmentFactor(branch,los,fd) $ { (branchLossBlocks(branch) = 6) and (ord(los) = 5) } = 0.01 * (2 - lossCoeff_E) * branchResistance(branch) * branchCapacity(branch,fd) ;
5787  LossSegmentFactor(branch,los,fd) $ { (branchLossBlocks(branch) = 6) and (ord(los) = 6) } = 0.01 * (2 - (0.75*lossCoeff_C)) * branchResistance(branch) * branchCapacity(branch,fd) ;
5788   
5789  * HVDC does not have backward flow --> No loss segment for backward flow
5790  LossSegmentMW(HVDClink,los,fd)     $ (ord(fd) = 2) = 0;
5791  LossSegmentFactor(HVDClink,los,fd) $ (ord(fd) = 2) = 0;
5792   
5793  * Valid loss segment for a branch is defined as a loss segment that has a non-zero LossSegmentMW or a non-zero LossSegmentFactor.
5794  validLossSegment(branch,los,fd) = yes $ { (ord(los) = 1) or LossSegmentMW(branch,los,fd) or LossSegmentFactor(branch,los,fd) } ;
5795   
5796  * HVDC loss model requires at least two loss segments and an additional loss block due to cumulative loss formulation
5797  validLossSegment(HVDClink,los,fd) $ { (branchLossBlocks(HVDClink) <= 1) and (ord(los) = 2) } = yes ;
5798  validLossSegment(HVDClink,los,fd) $ { (branchLossBlocks(HVDClink) > 1) and (ord(los) = (branchLossBlocks(HVDClink) + 1))
5799                                    and (sum[ los1, LossSegmentMW(HVDClink,los1,fd) + LossSegmentFactor(HVDClink,los1,fd) ] > 0) } = yes ;
5800   
5801  * branches that have non-zero loss factors
5802  LossBranch(branch) $ sum[ (los,fd), LossSegmentFactor(branch,los,fd) ] = yes ;
5803   
5804  * Create AC branch loss segments
5805  ACbranchLossMW(ACbranch,los,fd) $ { validLossSegment(ACbranch,los,fd) and (ord(los) = 1) } = LossSegmentMW(ACbranch,los,fd) ;
5806  ACbranchLossMW(ACbranch,los,fd) $ { validLossSegment(ACbranch,los,fd) and (ord(los) > 1) } = LossSegmentMW(ACbranch,los,fd) - LossSegmentMW(ACbranch,los-1,fd) ;
5807  ACbranchLossFactor(ACbranch,los,fd) $ validLossSegment(ACbranch,los,fd) = LossSegmentFactor(ACbranch,los,fd) ;
5808   
5809  * Create HVDC loss break points
5810  HVDCBreakPointMWFlow(HVDClink,bp,fd) $ (ord(bp) = 1) = 0 ;
5811  HVDCBreakPointMWLoss(HVDClink,bp,fd) $ (ord(bp) = 1) = 0 ;
5812  HVDCBreakPointMWFlow(HVDClink,bp,fd) $ { validLossSegment(HVDClink,bp,fd) and (ord(bp) > 1) } = LossSegmentMW(HVDClink,bp-1,fd) ;
5813  HVDCBreakPointMWLoss(HVDClink,bp,fd) $ { validLossSegment(HVDClink,bp,fd) and (ord(bp) = 2) } =  LossSegmentMW(HVDClink,bp-1,fd) * LossSegmentFactor(HVDClink,bp-1,fd) ;
5814  loop ((HVDClink(branch),bp) $ (ord(bp) > 2),
5815      HVDCBreakPointMWLoss(branch,bp,fd) $ validLossSegment(branch,bp,fd) = LossSegmentFactor(branch,bp-1,fd) * [ LossSegmentMW(branch,bp-1,fd) - LossSegmentMW(branch,bp-2,fd) ] + HVDCBreakPointMWLoss(branch,bp-1,fd) ;
5816  ) ;
5817   
5818   
5819  * Initialise branch constraint data
5820  branchConstraint(ca,dt,brCstr) $ sum[ branch(ca,dt,br) $ branchCstrFactors(ca,dt,brCstr,br), 1 ] = yes ;
5821  branchConstraintSense(branchConstraint) = branchCstrRHS(branchConstraint,'cnstrSense') ;
5822  branchConstraintLimit(branchConstraint) = branchCstrRHS(branchConstraint,'cnstrLimit') ;
5823   
5824   
5825  * Offer data
5826  * Initialise generating offer parameters
5827  generationStart(ca,dt,o) $ {     (studyMode(ca,dt) = 101 or studyMode(ca,dt) = 201) or (dailymode=0) } = offerParameter(ca,dt,o,'initialMW') ;
5828  generationStart(ca,dt,o) $ { not((studyMode(ca,dt) = 101 or studyMode(ca,dt) = 201) or (dailymode=0))} = offerParameter(ca,dt,o,'solvedInitialMW') ;
5829  * If we run pricing gdx, we need to use "solvedInitialMW" as initialMW for predispatch schedule
5830  generationStart(ca,dt,o) $ { not((studyMode(ca,dt) = 101 or studyMode(ca,dt) = 201)) and sum[dt1, offerParameter(ca,dt1,o,'initialMW') = 0] } = offerParameter(ca,dt,o,'solvedInitialMW') ;
5831   
5832  generationStart(ca,dt,o) = generationStart(ca,dt,o) + sum[ o1 $ primarySecondaryOffer(ca,dt,o,o1), offerParameter(ca,dt,o1,'initialMW') ] ;
5833   
5834  rampRateUp(ca,dt,o)        = offerParameter(ca,dt,o,'rampUpRate')      ;
5835  rampRateDn(ca,dt,o)        = offerParameter(ca,dt,o,'rampDnRate')      ;
5836  reserveGenMax(ca,dt,o)     = offerParameter(ca,dt,o,'resrvGenMax')     ;
5837  intermittentOffer(ca,dt,o) = offerParameter(ca,dt,o,'isIG')            ;
5838  FKband(ca,dt,o)            = offerParameter(ca,dt,o,'FKbandMW')        ;
5839  priceResponsive(ca,dt,o)   = offerParameter(ca,dt,o,'isPriceResponse') ;
5840  potentialMW(ca,dt,o)       = offerParameter(ca,dt,o,'potentialMW')     ;
5841   
      For generators in the PRICERESPONSIVEIG subset, if the potentialMW(g) value is less than ReserveGenerationMaximum(g,c) then pre-processing sets the ReserveGenerationMaximum(g,c) parameter to the PotentialMWg value,
      otherwise if the potentialMW(g) value is greater than or equal to the ReserveGenerationMaximum(g,c) then the ReserveGenerationMaximum(g,c) value is unchanged
      Tuong note: this does not seems to make sense and be used but This is based on the 4.6.2.1 calculation
5847  reserveMaxFactor(ca,dt,o,'FIR') = offerParameter(ca,dt,o,'maxFactorFIR') ;
5848  reserveMaxFactor(ca,dt,o,'SIR') = offerParameter(ca,dt,o,'maxFactorSIR') ;
5849  reserveMaxFactor(ca,dt,o,resC) $ { intermittentOffer(ca,dt,o) and priceResponsive(ca,dt,o) and( potentialMW(ca,dt,o) > 0) and (potentialMW(ca,dt,o) < reserveGenMax(ca,dt,o)) } = reserveGenMax(ca,dt,o) / potentialMW(ca,dt,o) ;
5850   
5851  * Identification of primary and secondary units
5852  primaryOffer(ca,dt,o) = 1 ;
5853  secondaryOffer(ca,dt,o) = 1 $ sum[ o1 $ primarySecondaryOffer(ca,dt,o1,o), 1 ] ;
5854  primaryOffer(ca,dt,o) $ secondaryOffer(ca,dt,o) = 0 ;
5855   
5856  * Initialise energy/reserve offer data
5857  enrgOfrMW(ca,dt,o,blk) = energyOffer(ca,dt,o,blk,'limitMW')  $ { offerParameter(ca,dt,o,'dispatchable') = 1 } ;
5858  enrgOfrPrice(ca,dt,o,blk) = energyOffer(ca,dt,o,blk,'price') $ { offerParameter(ca,dt,o,'dispatchable') = 1 } ;
5859   
5860  resrvOfrPct(ca,dt,o,blk,resC)        = reserveOffer(ca,dt,o,resC,'PLRO',blk,'plsrPct') / 100 ;
5861  resrvOfrMW(ca,dt,o,blk,resC,resT)    = reserveOffer(ca,dt,o,resC,resT,blk,'limitMW')  ;
5862  resrvOfrPrice(ca,dt,o,blk,resC,resT) = reserveOffer(ca,dt,o,resC,resT,blk,'price')  ;
5863   
5864   
5865  * Define valid offers/block sets
5866  * Valid offer must be mapped to a bus with electrical island <> 0. IL offer with non zero total limit is always valid no matter what
5867  offer(ca,dt,o) $ sum[ (n,b) $ { offerNode(ca,dt,o,n) and nodeBus(ca,dt,n,b) }, busElectricalIsland(ca,dt,b) ] = yes ;
5868  offer(ca,dt,o) $ sum[ (blk,resC), resrvOfrMW(ca,dt,o,blk,resC,'ILRO')] = yes ;
5869   
5870  offerIsland(offer(ca,dt,o),isl) $ sum[ n $ { offerNode(ca,dt,o,n) and nodeIsland(ca,dt,n,isl) }, 1 ] = yes ;
5871  islandRiskGenerator(ca,dt,isl,o) $ { offerIsland(ca,dt,o,isl) and offerParameter(ca,dt,o,'riskGenerator') } = yes ;
5872   
5873  * Valid energy offer blocks are defined as those with a positive block limit
5874  genOfrBlk(ca,dt,o,blk) $ ( enrgOfrMW(ca,dt,o,blk) > 0 ) = yes ;
5875   
5876  * Define set of positive (valid) energy offers
5877  posEnrgOfr(ca,dt,o) $ sum[ blk $ genOfrBlk(ca,dt,o,blk), 1 ] = yes ;
5878   
5879  * Only reserve offer block with a positive block limit is valid
5880  resOfrBlk(ca,dt,o,blk,resC,resT) $ (resrvOfrMW(ca,dt,o,blk,resC,resT) > 0) = yes ;
5881   
5882   
5883  * Bid data
5884  bid(ca,dt,bd) $ sum[ (n,b) $ { bidNode(ca,dt,bd,n) and nodeBus(ca,dt,n,b) }, busElectricalIsland(ca,dt,b) ] = yes ;
5885  bidIsland(bid(ca,dt,bd),isl) $ sum[ n $ { bidNode(ca,dt,bd,n) and nodeIsland(ca,dt,n,isl) }, 1 ] = yes ;
5886  * Initialise bid limits and prices
5887  demBidMW(bid,blk)    $ { bidParameter(bid,'dispatchable') = 1 } = energyBid(bid,blk,'limitMW') ;
5888  demBidPrice(bid,blk) $ { bidParameter(bid,'dispatchable') = 1 } = energyBid(bid,blk,'price')   ;
5889  demBidBlk(bid,blk)   $ ( DemBidMW(bid,blk) <> 0 ) = yes ;
5890   
5891   
5892  * Initialise market node constraint data for the current trading period
5893  MnodeConstraint(ca,dt,MnodeCstr) $ sum[ (offer(ca,dt,o),resT,resC) $ { mnCstrEnrgFactors(ca,dt,MnodeCstr,o) or mnCnstrResrvFactors(ca,dt,MnodeCstr,o,resC,resT) }, 1 ] = yes;
5894  MnodeConstraint(ca,dt,MnodeCstr) $ sum[ (bid(ca,dt,bd),resC) $ { mnCnstrEnrgBidFactors(ca,dt,MnodeCstr,bd) or mnCnstrResrvBidFactors(ca,dt,MnodeCstr,bd,resC) }, 1 ]   = yes ;
5895  MnodeConstraintSense(MnodeConstraint) = mnCnstrRHS(MnodeConstraint,'cnstrSense') ;
5896  MnodeConstraintLimit(MnodeConstraint) = mnCnstrRHS(MnodeConstraint,'cnstrLimit') ;
5897   
5898   
5899  * Reserve/Risk data
5900  islandRiskGroup(ca,dt,isl,rg,riskC)             = yes $ sum[ o $ { offerIsland(ca,dt,o,isl) and riskGroupOffer(ca,dt,rg,o,riskC) }, 1 ] ;
5901  HVDCSecRiskEnabled(ca,dt,isl,'HVDCsecRisk')     = islandParameter(ca,dt,isl,'HVDCsecRisk') ;
5902  HVDCSecRiskEnabled(ca,dt,isl,'HVDCsecRiskECE')  = islandParameter(ca,dt,isl,'HVDCsecRiskECE') ;
5903  riskAdjFactor(ca,dt,isl,resC,riskC)             = riskParameter(ca,dt,isl,resC,riskC,'adjustFactor') $ useReserveModel ;
5904  HVDCpoleRampUp(ca,dt,isl,resC,riskC)            = riskParameter(ca,dt,isl,resC,riskC,'HVDCRampUp') ;
5905   
5906   
5907  * Reserve sharing data
5908  rampingConstraint(branchConstraint) = branchCstrRHS(branchConstraint,'rampingCnstr') ;
      TN on 22 May 2017:
      Usually a branch group constraint that limits the HVDC flow only involves the HVDC branch(s) in the same direction. However, during TP6 to TP9 of 18 May 2017, the constraint HAY_BEN_High_Frequency_limit involved all four
      branches in the form: HAY_BEN1.1 + HAY_BEN2.1 - BEN_HAY1.1 - BEN_HAY2.1 <= 530 MW. This method of formulating the constraint prevented the previous formulation of monopoleConstraint and bipoleConstraintfrom working properly.
      Those constraints have been reformulated (see below) in order to cope with the formulation observed on 18 May 2017.
5915  monopoleConstraint(ca,dt,isl,brCstr,br) $ { HVDClink(ca,dt,br) and ( not rampingConstraint(ca,dt,brCstr) ) and ( branchConstraintSense(ca,dt,brCstr) = -1 )
5916                                          and (sum[ (br1,b) $ { HVDClinkSendingBus(ca,dt,br1,b) and busIsland(ca,dt,b,isl) }, branchCstrFactors(ca,dt,brCstr,br1)] = 1)
5917                                          and (sum[ b $ { HVDClinkSendingBus(ca,dt,br,b) and busIsland(ca,dt,b,isl) }, branchCstrFactors(ca,dt,brCstr,br)] = 1)
5918                                            } = yes ;
5919   
5920  bipoleConstraint(ca,dt,isl,brCstr) $ { ( not rampingConstraint(ca,dt,brCstr) ) and ( branchConstraintSense(ca,dt,brCstr) = -1 )
5921                                     and (sum[ (br,b) $ { HVDClink(ca,dt,br) and HVDClinkSendingBus(ca,dt,br,b) and busIsland(ca,dt,b,isl) }, branchCstrFactors(ca,dt,brCstr,br)  ] = 2)
5922                                       } = yes ;
5923   
5924  reserveShareEnabled(ca,dt,'FIR')  = reserveSharingParameter(ca,dt,'sharingFIR') ;
5925  reserveShareEnabled(ca,dt,'SIR')  = reserveSharingParameter(ca,dt,'sharingSIR') ;
5926  reserveShareEnabledOverall(ca,dt) = smax[ resC, reserveShareEnabled(ca,dt,resC)];
5927   
5928  reserveRoundPower(ca,dt,'FIR')    = reserveSharingParameter(ca,dt,'roundPwrFIR') ;
5929  reserveRoundPower(ca,dt,'SIR')    = reserveSharingParameter(ca,dt,'roundPwrSIR') ;
5930   
5931  modulationRiskClass(ca,dt,'DCCE')           = reserveSharingParameter(ca,dt,'MRCE') ;
5932  modulationRiskClass(ca,dt,'DCECE')          = reserveSharingParameter(ca,dt,'MRECE') ;
5933  modulationRiskClass(ca,dt,'HVDCsecRisk')    = reserveSharingParameter(ca,dt,'MRCE') ;
5934  modulationRiskClass(ca,dt,'HVDCsecRiskECE') = reserveSharingParameter(ca,dt,'MRECE') ;
5935  modulationRisk(ca,dt)                       = smax[ riskC, modulationRiskClass(ca,dt,RiskC) ];
5936   
5937  roundPower2MonoLevel(ca,dt) = reserveSharingParameter(ca,dt,'roundPwr2Mono') ;
5938  bipole2MonoLevel(ca,dt)     = reserveSharingParameter(ca,dt,'biPole2Mono') ;
5939  roPwrZoneExit(ca,dt,resC)   = [ roundPower2MonoLevel(ca,dt) - modulationRisk(ca,dt) ]$(ord(resC)=1) + bipole2MonoLevel(ca,dt)$(ord(resC)=2) ;
      SPD pre-processing is changed so that the roundpower settings for FIR are now the same as for SIR. Specifically: (National market refinement - effective date 28 Mar 2019 12:00 )
      -  The RoundPowerZoneExit for FIR will be set at BipoleToMonopoleTransition by SPD pre-processing. A change from the existing where the RoundPowerZoneExit for FIR is set at RoundPowerToMonopoleTransition by SPD pre-processing.
      -  Provided that roundpower is not disabled by the MDB, the InNoReverseZone for FIR will be removed by SPD pre-processing. A change from the existing where the InNoReverseZone for FIR is never removed by SPD pre-processing.
5945  if(inputGDXGDate >= jdate(2019,03,28),
5946      roPwrZoneExit(ca,dt,resC) = bipole2MonoLevel(ca,dt) ;
5947  ) ;
5948   
5949  monopoleMinimum(ca,dt)                = reserveSharingParameter(ca,dt,'monoPoleMin') ;
5950  HVDCControlBand(ca,dt,'forward')      = reserveSharingParameter(ca,dt,'forwardHVDCcontrolBand') ;
5951  HVDCControlBand(ca,dt,'backward')     = reserveSharingParameter(ca,dt,'backwardHVDCcontrolBand') ;
5952  HVDClossScalingFactor(ca,dt)          = reserveSharingParameter(ca,dt,'lossScalingFactorHVDC') ;
5953   
5954  RMTReserveLimit(ca,dt,isl,'FIR')      = islandParameter(ca,dt,isl,'RMTlimitFIR') ;
5955  RMTReserveLimit(ca,dt,isl,'SIR')      = islandParameter(ca,dt,isl,'RMTlimitSIR') ;
5956   
5957  sharedNFRFactor(ca,dt)                = reserveSharingParameter(ca,dt,'sharedNFRfactor') ;
5958  sharedNFRLoadOffset(ca,dt,isl)        = islandParameter(ca,dt,isl,'sharedNFRLoadOffset') ;
5959  effectiveFactor(ca,dt,isl,resC,riskC) = riskParameter(ca,dt,isl,resC,riskC,'sharingEffectiveFactor');
5960   
5961  * Calculate HVDC parameters applied to National Reserve Sharing
5962  numberOfPoles(ca,dt,isl)       = sum[ (b,br) $ { BusIsland(ca,dt,b,isl) and HVDClink(ca,dt,br) and HVDClinkSendingBus(ca,dt,br,b) }, 1 ] ;
5963   
5964  monoPoleCapacity(ca,dt,isl,br) = sum[ b $ { BusIsland(ca,dt,b,isl) and HVDClink(ca,dt,br) and HVDClinkSendingBus(ca,dt,br,b)}, branchCapacity(ca,dt,br,'forward') ] ;
5965  monoPoleCapacity(ca,dt,isl,br) $ sum[ brCstr $ monopoleConstraint(ca,dt,isl,brCstr,br), 1] = Smin[ brCstr $ monopoleConstraint(ca,dt,isl,brCstr,br), branchConstraintLimit(ca,dt,brCstr) ];
5966  monoPoleCapacity(ca,dt,isl,br) = Min[ monoPoleCapacity(ca,dt,isl,br), branchCapacity(ca,dt,br,'forward') ];
5967   
5968  biPoleCapacity(ca,dt,isl) $ sum[ brCstr $ bipoleConstraint(ca,dt,isl,brCstr), 1]  = Smin[ brCstr $ bipoleConstraint(ca,dt,isl,brCstr) , branchConstraintLimit(ca,dt,brCstr) ];
5969  biPoleCapacity(ca,dt,isl) $ { sum[ brCstr $ bipoleConstraint(ca,dt,isl,brCstr), 1] = 0 } = sum[ (b,br,fd) $ { BusIsland(ca,dt,b,isl) and HVDClink(ca,dt,br) and HVDClinkSendingBus(ca,dt,br,b) }, branchCapacity(ca,dt,br,'forward') ] ;
5970   
5971  HVDCMax(ca,dt,isl) = Min( biPoleCapacity(ca,dt,isl), sum[ br, monoPoleCapacity(ca,dt,isl,br) ] ) ;
5972   
5973  * Initialse parameters for NMIR -------------------------------------------
      * When NMIR started on 20/10/2016, the SO decided to incorrectly calculate the HVDC loss curve for reserve sharing based on the HVDC capacity only (i.e. not based on in-service HVDC poles)
      * Tuong Nguyen @ EA discovered this bug and the SO has fixed it as of 22/11/2016.
5978  HVDCCapacity(ca,dt,isl) = sum[ (b,br) $ { BusIsland(ca,dt,b,isl) and HVDClink(ca,dt,br) and HVDClinkSendingBus(ca,dt,br,b) }, branchCapacity(ca,dt,br,'forward') ] ;
5979   
5980  HVDCResistance(ca,dt,isl) $ (numberOfPoles(ca,dt,isl) = 2) = prod[ (b,br) $ { BusIsland(ca,dt,b,isl) and HVDClink(ca,dt,br) and HVDClinkSendingBus(ca,dt,br,b) }, branchResistance(ca,dt,br) ]
5981                                                              / sum[ (b,br) $ { BusIsland(ca,dt,b,isl) and HVDClink(ca,dt,br) and HVDClinkSendingBus(ca,dt,br,b) }, branchResistance(ca,dt,br) ] ;
5982  HVDCResistance(ca,dt,isl) $ (numberOfPoles(ca,dt,isl) = 1) = sum[ br $ monoPoleCapacity(ca,dt,isl,br), branchResistance(ca,dt,br) ] ;
5983   
5984  HVDCLossSegmentMW(ca,dt,isl,los)     $ (ord(los) = 1) = HVDCCapacity(ca,dt,isl) * lossCoeff_C ;
5985  HVDCLossSegmentMW(ca,dt,isl,los)     $ (ord(los) = 2) = HVDCCapacity(ca,dt,isl) * lossCoeff_D ;
5986  HVDCLossSegmentMW(ca,dt,isl,los)     $ (ord(los) = 3) = HVDCCapacity(ca,dt,isl) * 0.5 ;
5987  HVDCLossSegmentMW(ca,dt,isl,los)     $ (ord(los) = 4) = HVDCCapacity(ca,dt,isl) * (1 - lossCoeff_D) ;
5988  HVDCLossSegmentMW(ca,dt,isl,los)     $ (ord(los) = 5) = HVDCCapacity(ca,dt,isl) * (1 - lossCoeff_C) ;
5989  HVDCLossSegmentMW(ca,dt,isl,los)     $ (ord(los) = 6) = HVDCCapacity(ca,dt,isl) ;
5990  HVDCLossSegmentFactor(ca,dt,isl,los) $ (ord(los) = 1) = 0.01 * 0.75 * lossCoeff_C * HVDCResistance(ca,dt,isl) * HVDCCapacity(ca,dt,isl) ;
5991  HVDCLossSegmentFactor(ca,dt,isl,los) $ (ord(los) = 2) = 0.01 * lossCoeff_E * HVDCResistance(ca,dt,isl) * HVDCCapacity(ca,dt,isl) ;
5992  HVDCLossSegmentFactor(ca,dt,isl,los) $ (ord(los) = 3) = 0.01 * lossCoeff_F * HVDCResistance(ca,dt,isl) * HVDCCapacity(ca,dt,isl) ;
5993  HVDCLossSegmentFactor(ca,dt,isl,los) $ (ord(los) = 4) = 0.01 * (2 - lossCoeff_F) * HVDCResistance(ca,dt,isl) * HVDCCapacity(ca,dt,isl) ;
5994  HVDCLossSegmentFactor(ca,dt,isl,los) $ (ord(los) = 5) = 0.01 * (2 - lossCoeff_E) * HVDCResistance(ca,dt,isl) * HVDCCapacity(ca,dt,isl) ;
5995  HVDCLossSegmentFactor(ca,dt,isl,los) $ (ord(los) = 6) = 0.01 * (2 - (0.75*lossCoeff_C)) * HVDCResistance(ca,dt,isl) * HVDCCapacity(ca,dt,isl) ;
5996   
5997  * Parameter for energy lambda loss model
5998  HVDCSentBreakPointMWFlow(ca,dt,isl,bp) $ (ord(bp) = 1) = 0 ;
5999  HVDCSentBreakPointMWLoss(ca,dt,isl,bp) $ (ord(bp) = 1) = 0 ;
6000  HVDCSentBreakPointMWFlow(ca,dt,isl,bp) $ (ord(bp) > 1) = HVDCLossSegmentMW(ca,dt,isl,bp-1) ;
6001  loop( (ca,dt,isl,bp) $ {(ord(bp) > 1) and (ord(bp) <= 7)},
6002      HVDCSentBreakPointMWLoss(ca,dt,isl,bp) = HVDClossScalingFactor(ca,dt) * HVDCLossSegmentFactor(ca,dt,isl,bp-1) * [ HVDCLossSegmentMW(ca,dt,isl,bp-1) - HVDCSentBreakPointMWFlow(ca,dt,isl,bp-1) ] + HVDCSentBreakPointMWLoss(ca,dt,isl,bp-1) ;
6003  ) ;
6004   
6005  * Parameter for energy+reserve lambda loss model
6006  * Ideally SO should use asymmetric loss curve
6007  HVDCReserveBreakPointMWFlow(ca,dt,isl,rsbp) $ (ord(rsbp) <= 7) = sum[ (isl1,rsbp1) $ { ( not sameas(isl1,isl) ) and ( ord(rsbp) + ord(rsbp1) = 8) }, -HVDCSentBreakPointMWFlow(ca,dt,isl1,rsbp1) ];
6008  HVDCReserveBreakPointMWLoss(ca,dt,isl,rsbp) $ (ord(rsbp) <= 7) = sum[ (isl1,rsbp1) $ { ( not sameas(isl1,isl) ) and ( ord(rsbp) + ord(rsbp1) = 8) }, HVDCSentBreakPointMWLoss(ca,dt,isl1,rsbp1) ];
6009  * However, SO decide to use symmetric loss curve instead
6010  HVDCReserveBreakPointMWFlow(ca,dt,isl,rsbp) $ (ord(rsbp) <= 7) = sum[ rsbp1 $ { ord(rsbp) + ord(rsbp1) = 8 }, -HVDCSentBreakPointMWFlow(ca,dt,isl,rsbp1) ];
6011  HVDCReserveBreakPointMWFlow(ca,dt,isl,rsbp) $ { (ord(rsbp) > 7) and (ord(rsbp) <= 13) } = HVDCSentBreakPointMWFlow(ca,dt,isl,rsbp-6) ;
6012  HVDCReserveBreakPointMWLoss(ca,dt,isl,rsbp) $ (ord(rsbp) <= 7) = sum[ rsbp1 $ { ord(rsbp) + ord(rsbp1) = 8 }, HVDCSentBreakPointMWLoss(ca,dt,isl,rsbp1) ];
6013  HVDCReserveBreakPointMWLoss(ca,dt,isl,rsbp) $ { (ord(rsbp) > 7) and (ord(rsbp) <= 13) } = HVDCSentBreakPointMWLoss(ca,dt,isl,rsbp-6);
6014   
6015  * Data appllied to Real Time Pricing
6016    useGenInitialMW(ca,dt)            = dtParameter(ca,dt,'useGenInitialMW') ;
6017    useActualLoad(ca,dt)              = dtParameter(ca,dt,'useActualLoad') ;
6018    maxSolveLoops(ca,dt)              = dtParameter(ca,dt,'maxSolveLoop') ;
6019    islandMWIPS(ca,dt,isl)            = islandParameter(ca,dt,isl,'MWIPS') ;
6020    islandPDS(ca,dt,isl)              = islandParameter(ca,dt,isl,'PSD') ;
6021    islandLosses(ca,dt,isl)           = islandParameter(ca,dt,isl,'Losses') ;
6022    SPDLoadCalcLosses(ca,dt,isl)      = islandParameter(ca,dt,isl,'SPDLoadCalcLosses') ;
6023   
6024  * For PRICERESPONSIVEIG generators, The RTD rampRateUp is capped: (4.7.2.2)
6025  rampRateUp(offer(ca,dt,o)) $ { (studyMode(ca,dt) = 101 or studyMode(ca,dt) = 201) and intermittentOffer(offer) and priceResponsive(offer) }
6026                             = Min[ rampRateUp(offer), dtParameter(ca,dt,'igIncreaseLimitRTD')*60/intervalDuration(ca,dt) ] ;
6027   
6028  * 4.9.2 Dispatchable Pnodes
6029  * If the Pnode associated with a Dispatchable Demand Bid is not a dead Pnode then PnodeRequiredLoad is set to zero. This is not applicable for "difference bid"
6030  requiredLoad(node(ca,dt,n)) $ { sum[ (bd,blk) $ ( bidNode(ca,dt,bd,n) and (bidParameter(ca,dt,bd,'difference') = 0 ) ), DemBidMW(ca,dt,bd,blk) ] > 0 } = 0;
6031  *-------------------------------------------------------------------------------
6032   
6033  * Initialize energy scarcity limits and prices ---------------------------------
6034  energyScarcityEnabled(ca,dt)                 = dtParameter(ca,dt,'enrgScarcity') ;
6035  reserveScarcityEnabled(ca,dt)                = dtParameter(ca,dt,'resrvScarcity') ;
6036  scarcityResrvIslandLimit(ca,dt,isl,resC,blk) = scarcityResrvLimit(ca,dt,isl,resC,blk,'limitMW') ;
6037  scarcityResrvIslandPrice(ca,dt,isl,resC,blk) = scarcityResrvLimit(ca,dt,isl,resC,blk,'price') ;
6038   
6039   
6040  * TN - Pivot or demand analysis begin
6043  * TN - Pivot or demand analysis begin end
6044   
6045  *=====================================================================================
6046  * 7. The vSPD solve loop
6047  *=====================================================================================
6048   
6049   
6050  * Need to initiate value for this parameters before it is used
6051  o_offerEnergy_TP(ca,dt,o) = 0;
6052   
6053  LoadCalcLosses(ca,dt,isl) = (islandLosses(ca,dt,isl)$(dailymode = 0)) + (SPDLoadCalcLosses(ca,dt,isl)$(dailymode = 1));
6054  DidShortfallTransfer(ca,dt,n) = 0;
6055  ShortfallDisabledScaling(ca,dt,n) = 0;
6056  CheckedNodeCandidate(ca,dt,n) = 0;
6057  PotentialModellingInconsistency(ca,dt,n)= 1 $ { sum[ branch(ca,dt,br) $ nodeoutagebranch(ca,dt,n,br), 1] < sum[ br $ nodeoutagebranch(ca,dt,n,br), 1] } ;
6058   
6059  unsolvedDT(ca,dt) = yes $ case2dt(ca,dt) ;
6060  VSPDModel(ca,dt) = 0 ;
6061  LoopCount(ca,dt) = 1 $ case2dt(ca,dt) ;
6062  IsNodeDead(ca,dt,n) = 0 ;
6063  nodeTonode(ca,dt,n,n1) = node2node(ca,dt,n,n1) ;
6064   
6065  While ( sum[ (ca,dt) $ {unsolvedDT(ca,dt) and case2dt(ca,dt)} , 1 ],
6066   
6067    loop[ (ca,dt) $ {unsolvedDT(ca,dt) and case2dt(ca,dt) and (LoopCount(ca,dt) <= maxSolveLoops(ca,dt)) },
6068    repeat(
6069  *   7a. Reset all sets, parameters and variables -------------------------------
6070      option clear = t ;
6071  *   Generation variables
6072      option clear = GENERATION ;
6073      option clear = GENERATIONBLOCK ;
6074      option clear = GENERATIONUPDELTA ;
6075      option clear = GENERATIONDNDELTA ;
6076  *   Purchase variables
6077      option clear = PURCHASE ;
6078      option clear = PURCHASEBLOCK ;
6079  *   Network variables
6080      option clear = ACNODENETINJECTION ;
6081      option clear = ACNODEANGLE ;
6082      option clear = ACBRANCHFLOW ;
6083      option clear = ACBRANCHFLOWDIRECTED ;
6084      option clear = ACBRANCHLOSSESDIRECTED ;
6085      option clear = ACBRANCHFLOWBLOCKDIRECTED ;
6086      option clear = ACBRANCHLOSSESBLOCKDIRECTED ;
6087      option clear = ACBRANCHFLOWDIRECTED_INTEGER ;
6088      option clear = HVDCLINKFLOW ;
6089      option clear = HVDCLINKLOSSES ;
6090      option clear = LAMBDA ;
6091      option clear = LAMBDAINTEGER ;
6092      option clear = HVDCLINKFLOWDIRECTED_INTEGER ;
6093      option clear = HVDCPOLEFLOW_INTEGER ;
6094  *   Risk/Reserve variables
6095      option clear = RISKOFFSET ;
6096      option clear = HVDCREC ;
6097      option clear = ISLANDRISK ;
6098      option clear = RESERVEBLOCK ;
6099      option clear = RESERVE ;
6100      option clear = ISLANDRESERVE;
6101  *   NMIR variables
6102      option clear = SHAREDNFR ;
6103      option clear = SHAREDRESERVE ;
6104      option clear = HVDCSENT ;
6105      option clear = RESERVESHAREEFFECTIVE ;
6106      option clear = RESERVESHARERECEIVED ;
6107      option clear = RESERVESHARESENT ;
6108      option clear = HVDCSENDING ;
6109      option clear = INZONE ;
6110      option clear = HVDCSENTINSEGMENT ;
6111      option clear = HVDCRESERVESENT ;
6112      option clear = HVDCSENTLOSS ;
6113      option clear = HVDCRESERVELOSS ;
6114      option clear = LAMBDAHVDCENERGY ;
6115      option clear = LAMBDAHVDCRESERVE ;
6116      option clear = RESERVESHAREPENALTY ;
6117  *   Objective
6118      option clear = NETBENEFIT ;
6119  *   Violation variables
6120      option clear = TOTALPENALTYCOST ;
6121      option clear = DEFICITBUSGENERATION ;
6122      option clear = SURPLUSBUSGENERATION ;
6123      option clear = DEFICITRESERVE_CE ;
6124      option clear = DEFICITRESERVE_ECE ;
6125      option clear = DEFICITBRANCHSECURITYCONSTRAINT ;
6126      option clear = SURPLUSBRANCHSECURITYCONSTRAINT ;
6127      option clear = DEFICITRAMPRATE ;
6128      option clear = SURPLUSRAMPRATE ;
6129      option clear = DEFICITBRANCHFLOW ;
6130      option clear = SURPLUSBRANCHFLOW ;
6131      option clear = DEFICITMNODECONSTRAINT ;
6132      option clear = SURPLUSMNODECONSTRAINT ;
6133  *   Scarcity variables
6134      option clear = SCARCITYCOST;
6135      option clear = ENERGYSCARCITYBLK ;
6136      option clear = ENERGYSCARCITYNODE;
6137  *   Risk violation variables
6138      option clear = RESERVESHORTFALLBLK;
6139      option clear = RESERVESHORTFALL;
6140      option clear = RESERVESHORTFALLUNITBLK;
6141      option clear = RESERVESHORTFALLUNIT;
6142      option clear = RESERVESHORTFALLGROUPBLK;
6143      option clear = RESERVESHORTFALLGROUP;
6144  *   Clear the pole circular branch flow flag
6145      option clear = circularBranchFlowExist ;
6146      option clear = poleCircularBranchFlowExist ;
6147      option clear = northHVDC ;
6148      option clear = southHVDC ;
6149      option clear = manualBranchSegmentMWFlow ;
6150      option clear = manualLossCalculation ;
6151      option clear = nonPhysicalLossExist ;
6152      option clear = modelSolved ;
6153      option clear = LPmodelSolved ;
6154  *   End reset
6155   
6156   
6157  *   7b. Initialise current trade period and model data -------------------------
6158      t(ca,dt)= yes  $ case2dt(ca,dt);
6159   
6160  *   Update initial MW if run NRSS, PRSS, NRSL, PRSL
6161      generationStart(offer(t(ca,dt),o)) $ { sum[ o1, generationStart(ca,dt,o1)] = 0 } = sum[ dt1 $ (ord(dt1) = ord(dt)-1), o_offerEnergy_TP(ca,dt1,o) ] ;
6162   
6163  *   4.10 Real Time Pricing - First RTD load calculation --------------------------
6164      if ( { (studyMode(ca,dt) = 101) or (studyMode(ca,dt) = 201)} and {(dailymode = 0) or (LoopCount(ca,dt) > 1)},
6165  *       Calculate first target total load [4.10.6.5]
6166  *       Island-level MW load forecast. For the fist loop, uses islandLosses(t,isl)
6167          TargetTotalLoad(t,isl) = islandMWIPS(t,isl) + islandPDS(t,isl) - LoadCalcLosses(t,isl) + sum[n $ nodeIsland(t,n,isl),dispatchedGeneration(t,n) - dispatchedLoad(t,n) ];
6168   
6169  *       Flag if estimate load is scalable [4.10.6.7]
6170  *       If True [1] then ConformingFactor load MW will be scaled in order to calculate EstimatedInitialLoad. If False then EstNonScalableLoad will be assigned directly to EstimatedInitialLoad
6171          EstLoadIsScalable(t,n) =  1 $ { (LoadIsNCL(t,n) = 0) and (ConformingFactor(t,n) > 0) } ;
6172   
6173  *       Calculate estimate non-scalable load [4.10.6.8]
6174  *       For a non-conforming Pnode this will be the NonConformingLoad MW input, for a conforming Pnode this will be the ConformingFactor MW input if that value is negative, otherwise it will be zero
6175          EstNonScalableLoad(t,n) $ ( LoadIsNCL(t,n) = 1 ) = NonConformingLoad(t,n);
6176          EstNonScalableLoad(t,n) $ ( LoadIsNCL(t,n) = 0 ) = ConformingFactor(t,n);
6177          EstNonScalableLoad(t,n) $ ( EstLoadIsScalable(t,n) = 1 ) = 0;
6178   
6179  *       Calculate estimate scalable load [4.10.6.10]
6180  *       For a non-conforming Pnode this value will be zero. For a conforming Pnode this value will be the ConformingFactor if it is non-negative, otherwise this value will be zero
6181          EstScalableLoad(t,n) $ ( EstLoadIsScalable(t,n) = 1 ) = ConformingFactor(t,n);
6182   
6183  *       Calculate Scaling applied to ConformingFactor load MW [4.10.6.9] in order to calculate EstimatedInitialLoad
6184          EstScalingFactor(t,isl) = (islandMWIPS(t,isl) - LoadCalcLosses(t,isl) - sum[ n $ nodeIsland(t,n,isl), EstNonScalableLoad(t,n) ]) / sum[ n $ nodeIsland(t,n,isl), EstScalableLoad(t,n) ] ;
6185   
6186  *       Calculate estimate initial load [4.10.6.6]
6187  *       Calculated estimate of initial MW load, available to be used as an alternative to InputInitialLoad
6188          EstimatedInitialLoad(t,n) $ ( EstLoadIsScalable(t,n) = 1 ) = ConformingFactor(t,n) * sum[ isl $ nodeisland(t,n,isl), EstScalingFactor(t,isl)] ;
6189          EstimatedInitialLoad(t,n) $ ( EstLoadIsScalable(t,n) = 0 ) = EstNonScalableLoad(t,n);
6190   
6191  *       Calculate initial load [4.10.6.2]
6192  *       Value that represents the Pnode load MW at the start of the solution interval. Depending on the inputs this value will be either actual load, an operator applied override or an estimated initial load
6193          InitialLoad(t,n) = InputInitialLoad(t,n);
6194          InitialLoad(t,n) $ { (LoadIsOverride(t,n) = 0) and ( (useActualLoad(t) = 0) or (LoadIsBad(t,n) = 1) ) } = EstimatedInitialLoad(t,n) ;
6195          InitialLoad(t,n) $ { (LoadIsOverride(t,n) = 1) and (useActualLoad(t) = 1) and (InitialLoad(t,n) > MaxLoad(t,n)) } = MaxLoad(t,n) ;
6196          InitialLoad(t,n) $ DidShortfallTransfer(t,n) = requiredLoad(t,n);
6197   
6198  *       Flag if load is scalable [4.10.6.4]
6199  *       If True [1] then the Pnode InitialLoad will be scaled in order to calculate requiredLoad, if False then Pnode InitialLoad will be directly assigned to requiredLoad
6200          LoadIsScalable(t,n) = 1 $ { (LoadIsNCL(t,n) = 0) and (LoadIsOverride(t,n) = 0) and (InitialLoad(t,n) >= 0) and (ShortfallDisabledScaling(t,n) = 0) and (DidShortfallTransfer(t,n) = 0) } ;
6201   
6202  *       Calculate Island-level scaling factor [4.10.6.3] --> applied to InitialLoad in order to calculate requiredLoad
6203          LoadScalingFactor(t,isl) = ( TargetTotalLoad(t,isl) - sum[n $ {nodeIsland(t,n,isl) and (LoadIsScalable(t,n) = 0)}, InitialLoad(t,n)] ) / sum[n $ {nodeIsland(t,n,isl) and (LoadIsScalable(t,n) = 1)}, InitialLoad(t,n)] ;
6204   
6205  *       Calculate requiredLoad [4.10.6.1]
6206          requiredLoad(t,n) $ { (DidShortfallTransfer(t,n)=0) and (LoadIsScalable(t,n) = 1) } = InitialLoad(t,n) * sum[ isl $ nodeisland(t,n,isl), LoadScalingFactor(t,isl) ];
6207          requiredLoad(t,n) $ { (DidShortfallTransfer(t,n)=0) and (LoadIsScalable(t,n) = 0) } = InitialLoad(t,n);
6208          requiredLoad(t,n) $ { (DidShortfallTransfer(t,n)=0)                                } = requiredLoad(t,n) + [InstructedLoadShed(t,n) $ InstructedShedActive(t,n)];
6209   
6210      ) ;
6211   
6212   
6213  *   Recalculate energy scarcity limits -------------------------------------
6214      scarcityEnrgLimit(t,n,blk) = 0 ;
6215      scarcityEnrgLimit(t,n,blk) $ { energyScarcityEnabled(t) and (requiredLoad(t,n) > 0) }                                     = scarcityNationalFactor(t,blk,'factor') * requiredLoad(t,n);
6216      scarcityEnrgPrice(t,n,blk) $ { energyScarcityEnabled(t) and (scarcityEnrgLimit(t,n,blk) > 0 ) }                           = scarcityNationalFactor(t,blk,'price') ;
6217   
6218      scarcityEnrgLimit(t,n,blk) $ { energyScarcityEnabled(t) and (requiredLoad(t,n) > 0) and scarcityNodeFactor(t,n,blk,'factor') } = scarcityNodeFactor(t,n,blk,'factor') * requiredLoad(t,n);
6219      scarcityEnrgPrice(t,n,blk) $ { energyScarcityEnabled(t) and scarcityNodeFactor(t,n,blk,'price') }                        = scarcityNodeFactor(t,n,blk,'price') ;
6220   
6221      scarcityEnrgLimit(t,n,blk) $ { energyScarcityEnabled(t) and                             scarcityNodeLimit(t,n,blk,'limitMW')  } = scarcityNodeLimit(t,n,blk,'limitMW');
6222      scarcityEnrgPrice(t,n,blk) $ { energyScarcityEnabled(t) and scarcityNodeLimit(t,n,blk,'price') }                         = scarcityNodeLimit(t,n,blk,'price') ;
6223  *       ------------------------------------------------------------------------
6224   
6225  *   Update Free Reserve and SharedNFRmax - Pre-processing: Shared Net Free Reserve (NFR) calculation - NMIR (4.5.1.2)
6226      sharedNFRLoad(t,isl) = sum[ nodeIsland(t,n,isl), requiredLoad(t,n)] + sum[ (bd,blk) $ bidIsland(t,bd,isl), DemBidMW(t,bd,blk) ] - sharedNFRLoadOffset(t,isl) ;
6227      sharedNFRLoad(ca,dt,isl) $ { (studyMode(ca,dt) = 130) and (inputGDXGDate <= jdate(2023,04,27)) } = sum[ nodeIsland(ca,dt,n,isl), requiredLoad(ca,dt,n) + nonConformingLoad(ca,dt,n)] - sharedNFRLoadOffset(ca,dt,isl) ;
6228   
6229      sharedNFRMax(t,isl) = Min{ RMTReserveLimit(t,isl,'FIR'), sharedNFRFactor(t)*sharedNFRLoad(t,isl) } ;
6230      FreeReserve(t,isl,resC,riskC) = riskParameter(t,isl,resC,riskC,'freeReserve')
6231                                    - sum[ isl1 $ (not sameas(isl,isl1)),sharedNFRMax(t,isl1) ] $ { (ord(resC)=1) and ( (GenRisk(riskC)) or (ManualRisk(riskC)) ) } ;
6232   
6233   
6234  *   7c. Updating the variable bounds before model solve ------------------------
6235   
6236  * TN - Pivot or Demand Analysis - revise input data
6239  * TN - Pivot or Demand Analysis - revise input data end
6240   
6241  *======= GENERATION, DEMAND AND LOAD FORECAST EQUATIONS ========================
6242  *   Constraint 6.1.1.1 - Offer blocks
6243      GENERATIONBLOCK.up(genOfrBlk(t,o,blk)) = enrgOfrMW(genOfrBlk) ;
6244      GENERATIONBLOCK.fx(t,o,blk) $ (not genOfrBlk(t,o,blk)) = 0 ;
6245  *   Constraint 6.1.1.3 - Fix the invalid generation to Zero
6246      GENERATION.fx(offer(t,o)) $ (not posEnrgOfr(offer)) = 0 ;
6247  *   Constraint 6.1.1.4 - Set Upper Bound for intermittent generation
6248      GENERATION.up(offer(t,o)) $ { intermittentOffer(offer) and priceResponsive(offer) } = min[ potentialMW(offer), reserveGenMax(offer) ] ;
6249   
6250  *   Dead node pre-processing - zero cleared qunatities 4.3.1
6251      GENERATION.fx(offer(t,o)) $ sum[n $ offernode(t,o,n),IsNodeDead(t,n)] = 0 ;
6252      PURCHASE.fx(bid(t,bd)) $ sum[n $ bidnode(t,bd,n),IsNodeDead(t,n)] = 0 ;
6253   
6254  *   Constraint 6.1.1.4 & Constraint 6.1.1.5 - Set Upper/Lower Bound for Positive/Negative Demand Bid
6255      PURCHASEBLOCK.up(demBidBlk(t,bd,blk)) = DemBidMW(t,bd,blk) $ [DemBidMW(t,bd,blk) > 0];
6256      PURCHASEBLOCK.lo(demBidBlk(t,bd,blk)) = DemBidMW(t,bd,blk) $ [DemBidMW(t,bd,blk) < 0];
6257      PURCHASEBLOCK.fx(t,bd,blk) $ (not demBidBlk(t,bd,blk))= 0 ;
6258      PURCHASE.fx(t,bd) $ (sum[blk $ demBidBlk(t,bd,blk), 1] = 0) = 0 ;
6259   
6260  *   Constraint 6.1.1.7 - Set Upper Bound for Energy Scaricty Block
6261      ENERGYSCARCITYBLK.up(t,n,blk) = scarcityEnrgLimit(t,n,blk) ;
6262      ENERGYSCARCITYBLK.fx(t,n,blk) $ (not EnergyScarcityEnabled(t)) = 0;
6263      ENERGYSCARCITYNODE.fx(t,n) $ (not EnergyScarcityEnabled(t)) = 0;
6264  *======= GENERATION, DEMAND AND LOAD FORECAST EQUATIONS END ====================
6265   
6266  *======= HVDC TRANSMISSION EQUATIONS ===========================================
6267  *   Ensure that variables used to specify flow and losses on HVDC link are zero for AC branches and for open HVDC links.
6268      HVDCLINKFLOW.fx(t,br)   $ (not HVDClink(t,br)) = 0 ;
6269      HVDCLINKLOSSES.fx(t,br) $ (not HVDClink(t,br)) = 0 ;
6270  *   Apply an upper bound on the weighting parameter based on its definition
6271      LAMBDA.up(branch,bp) = 1 ;
6272  *   Ensure that the weighting factor value is zero for AC branches and for invalid loss segments on HVDC links
6273      LAMBDA.fx(HVDClink,bp) $ ( sum[fd $ validLossSegment(HVDClink,bp,fd),1] = 0 ) = 0 ;
6274      LAMBDA.fx(t,br,bp) $ (not HVDClink(t,br)) = 0 ;
6275  *======= HVDC TRANSMISSION EQUATIONS END =======================================
6276   
6277  *======= AC TRANSMISSION EQUATIONS =============================================
6278  *   Ensure that variables used to specify flow and losses on AC branches are zero for HVDC links branches and for open AC branches.
6279      ACBRANCHFLOW.fx(t,br)              $ (not ACbranch(t,br)) = 0 ;
6280      ACBRANCHFLOWDIRECTED.fx(t,br,fd)   $ (not ACbranch(t,br)) = 0 ;
6281      ACBRANCHLOSSESDIRECTED.fx(t,br,fd) $ (not ACbranch(t,br)) = 0 ;
6282  *   Ensure directed block flow and loss block variables are zero for non-AC branches and invalid loss segments on AC branches.
6283      ACBRANCHFLOWBLOCKDIRECTED.fx(t,br,los,fd)   $ { not(ACbranch(t,br) and validLossSegment(t,br,los,fd)) } = 0 ;
6284      ACBRANCHLOSSESBLOCKDIRECTED.fx(t,br,los,fd) $ { not(ACbranch(t,br) and validLossSegment(t,br,los,fd)) } = 0 ;
6285  *   Constraint 6.4.1.10 - Ensure that the bus voltage angle for the buses corresponding to the reference nodes and the HVDC nodes are set to zero.
6286      ACNODEANGLE.fx(t,b) $ sum[ n $ { NodeBus(t,n,b) and refNode(t,n) }, 1 ] = 0 ;
6287  *======= AC TRANSMISSION EQUATIONS END =========================================
6288   
6289  *======= RISK & RESERVE EQUATIONS ==============================================
6290  *   Ensure that all the invalid reserve blocks are set to zero for offers and purchasers.
6291      RESERVEBLOCK.fx(offer(t,o),blk,resC,resT) $ (not resOfrBlk(offer,blk,resC,resT)) = 0 ;
6292  *   Constraint 6.5.3.2 - Reserve block maximum for offers and purchasers.
6293      RESERVEBLOCK.up(resOfrBlk(t,o,blk,resC,resT)) = resrvOfrMW(resOfrBlk) ;
6294  *   Fix the reserve variable for invalid reserve offers. These are offers that are either not connected to the grid or have no reserve quantity offered.
6295      RESERVE.fx(t,o,resC,resT) $ (not sum[ blk $ resOfrBlk(t,o,blk,resC,resT), 1 ] ) = 0 ;
6296  *   NMIR project variables
6297      HVDCSENT.fx(t,isl)     $ (HVDCCapacity(t,isl) = 0) = 0 ;
6298      HVDCSENTLOSS.fx(t,isl) $ (HVDCCapacity(t,isl) = 0) = 0 ;
6299  *   Constraint 6.5.3.2.3 - SPD version 12.0
6300      SHAREDNFR.up(t,isl) = Max[0,sharedNFRMax(t,isl)] ;
6301  *   No forward reserve sharing if HVDC capacity is zero
6302      RESERVESHARESENT.fx(t,isl,resC,rd) $ { (HVDCCapacity(t,isl) = 0) and (ord(rd) = 1) } = 0 ;
6303  *   No forward reserve sharing if reserve sharing is disabled
6304      RESERVESHARESENT.fx(t,isl,resC,rd) $ (reserveShareEnabled(t,resC) = 0) = 0;
6305  *   No reserve sharing to cover HVDC risk
6306      RESERVESHAREEFFECTIVE.fx(t,isl,resC,HVDCrisk) = 0;
6307      RESERVESHAREEFFECTIVE.fx(t,isl,resC,HVDCsecRisk) = 0;
6308  *   Constraint 6.5.2.16 - no RP zone if reserve round power disabled
6309      INZONE.fx(t,isl,resC,z) $ {(ord(z) = 1) and (not reserveRoundPower(t,resC))} = 0;
6310  *   Constraint 6.5.2.17 - no no-reserve zone for SIR zone if reserve RP enabled
6311      INZONE.fx(t,isl,resC,z) $ {(ord(resC)=2) and (ord(z)=2) and reserveRoundPower(t,resC)} = 0;
6312  *   Fixing Lambda integer variable for energy sent
6313      LAMBDAHVDCENERGY.fx(t,isl,bp) $ { (HVDCCapacity(t,isl) = 0) and (ord(bp) = 1) } = 1 ;
6314      LAMBDAHVDCENERGY.fx(t,isl,bp) $ (ord(bp) > 7) = 0 ;
6315      LAMBDAHVDCRESERVE.fx(t,isl,resC,rd,rsbp) $ { (HVDCCapacity(t,isl) = 0) and (ord(rsbp) = 7) and (ord(rd) = 1) } = 1 ;
6316      LAMBDAHVDCRESERVE.fx(t,isl,resC,rd,rsbp) $ { (sum[isl1 $ (not sameas(isl1,isl)), HVDCCapacity(t,isl1)] = 0) and (ord(rsbp) < 7) and (ord(rd) = 2) } = 0 ;
6317  *   Contraint 6.5.4.1 - Set Upper Bound for reserve shortfall
6318      RESERVESHORTFALLBLK.up(t,isl,resC,riskC,blk)         = scarcityResrvIslandLimit(t,isl,resC,blk) $ reserveScarcityEnabled(t);
6319      RESERVESHORTFALLBLK.fx(t,isl,resC,riskC,blk)         $ (not reserveScarcityEnabled(t)) = 0;
6320      RESERVESHORTFALL.fx(t,isl,resC,riskC)                $ (not reserveScarcityEnabled(t)) = 0;
6321      RESERVESHORTFALLUNITBLK.up(t,isl,o,resC,riskC,blk)   = scarcityResrvIslandLimit(t,isl,resC,blk) $ reserveScarcityEnabled(t);
6322      RESERVESHORTFALLUNITBLK.fx(t,isl,o,resC,riskC,blk)   $ (not reserveScarcityEnabled(t)) = 0;
6323      RESERVESHORTFALLUNIT.fx(t,isl,o,resC,riskC)          $ (not reserveScarcityEnabled(t)) = 0;
6324      RESERVESHORTFALLGROUPBLK.up(t,isl,rg,resC,riskC,blk) = scarcityResrvIslandLimit(t,isl,resC,blk) $ reserveScarcityEnabled(t);
6325      RESERVESHORTFALLGROUPBLK.fx(t,isl,rg,resC,riskC,blk) $ (not reserveScarcityEnabled(t)) = 0;
6326      RESERVESHORTFALLGROUP.fx(t,isl,rg,resC,riskC)        $ (not reserveScarcityEnabled(t)) = 0;
6327  ;
6328  *======= RISK & RESERVE EQUATIONS END ==========================================
6329   
6330  *   Updating the variable bounds before model solve end
6331   
6332   
6333  *   7d. Solve Models
6334   
6335  *   Solve the NMIR model -------------------------------------------------------
6336      if ( sum[t(ca,dt), VSPDModel(t)] = 0,
6337   
6338          option bratio = 1 ;
6339          vSPD_NMIR.Optfile = 1 ;
6340          vSPD_NMIR.optcr = MIPOptimality ;
6341          vSPD_NMIR.reslim = MIPTimeLimit ;
6342          vSPD_NMIR.iterlim = MIPIterationLimit ;
6343          solve vSPD_NMIR using mip maximizing NETBENEFIT ;
6344  *       Set the model solve status
6345          ModelSolved = 1 $ { ( (vSPD_NMIR.modelstat = 1) or (vSPD_NMIR.modelstat = 8) ) and ( vSPD_NMIR.solvestat = 1 ) } ;
6346   
6347  *       Post a progress message to the console and for use by EMI.
6348          if (ModelSolved = 1,
6349              loop (t,
6350                  putclose rep 'The caseID: ' ca.tl ' (' dt.tl ') is 1st solved successfully.'/
6351                               'Objective function value: ' NETBENEFIT.l:<15:4 /
6352                               'Violations cost         : ' TOTALPENALTYCOST.l:<15:4 /
6353              ) ;
6354          elseif (ModelSolved = 0) and (sequentialSolve = 1),
6355              loop (t,
6356                  unsolvedDT(t) = no;
6357                  putclose rep 'The caseID: ' ca.tl ' (' dt.tl ') is 1st solved unsuccessfully.'/
6358              ) ;
6359   
6360          ) ;
6361   
6362  *       Post-Solve - Circulating flow check ------------------------------------
6363          if((ModelSolved = 1),
6364              Loop( t $ (VSPDModel(t)=0) ,
6365  *               Check if there are circulating branch flows on loss AC branches
6366                  circularBranchFlowExist(LossBranch(ACbranch(t,br))) $ { sum[fd, ACBRANCHFLOWDIRECTED.l(ACbranch,fd)] - abs(ACBRANCHFLOW.l(ACbranch)) > circularBranchFlowTolerance } = 1 ;
6367  *               Determine the circular branch flow flag on each HVDC pole
6368                  TotalHVDCpoleFlow(t,pole) = sum[ br $ HVDCpoleBranchMap(pole,br), HVDCLINKFLOW.l(t,br) ] ;
6369                  MaxHVDCpoleFlow(t,pole) = smax[ br $ HVDCpoleBranchMap(pole,br), HVDCLINKFLOW.l(t,br) ] ;
6370                  poleCircularBranchFlowExist(t,pole) $ { TotalHVDCpoleFlow(t,pole) - MaxHVDCpoleFlow(t,pole) > circularBranchFlowTolerance } = 1 ;
6371  *               Check if there are circulating branch flows on HVDC
6372                  NorthHVDC(t) = sum[ (isl,b,br) $ { (ord(isl) = 2) and busIsland(t,b,isl) and HVDClinkSendingBus(t,br,b) and HVDClink(t,br) }, HVDCLINKFLOW.l(t,br) ] ;
6373                  SouthHVDC(t) = sum[ (isl,b,br) $ { (ord(isl) = 1) and busIsland(t,b,isl) and HVDClinkSendingBus(t,br,b) and HVDClink(t,br) }, HVDCLINKFLOW.l(t,br) ] ;
6374                  circularBranchFlowExist(t,br) $ { HVDClink(t,br) and LossBranch(t,br) and (NorthHVDC(t) > circularBranchFlowTolerance) and (SouthHVDC(t) > circularBranchFlowTolerance) } = 1 ;
6375  *               Check if there are non-physical losses on HVDC links
6376                  ManualBranchSegmentMWFlow(LossBranch(HVDClink(t,br)),los,fd) $ { ( ord(los) <= branchLossBlocks(HVDClink) ) and validLossSegment(t,br,los,fd) }
6377                      = Min[ Max( 0, [ abs(HVDCLINKFLOW.l(HVDClink)) - [LossSegmentMW(HVDClink,los-1,fd) $ (ord(los) > 1)] ] ), ( LossSegmentMW(HVDClink,los,fd) - [LossSegmentMW(HVDClink,los-1,fd) $ (ord(los) > 1)] ) ] ;
6378                  ManualLossCalculation(LossBranch(HVDClink(t,br))) = sum[ (los,fd) $ validLossSegment(t,br,los,fd), LossSegmentFactor(HVDClink,los,fd) * ManualBranchSegmentMWFlow(HVDClink,los,fd) ] ;
6379                  NonPhysicalLossExist(LossBranch(HVDClink(t,br))) $ { abs( HVDCLINKLOSSES.l(HVDClink) - ManualLossCalculation(HVDClink) ) > NonPhysicalLossTolerance } = 1 ;
6380  *               Set UseBranchFlowMIP = 1 if the number of circular branch flow or non-physical loss branches exceeds the specified tolerance
6381                  useBranchFlowMIP(t) $ { ( sum[ br $ { ACbranch(t,br) and LossBranch(t,br) }, resolveCircularBranchFlows * circularBranchFlowExist(t,br)]
6382                                          + sum[ br $ { HVDClink(t,br) and LossBranch(t,br) }, resolveCircularBranchFlows * circularBranchFlowExist(t,br)]
6383                                          + sum[ br $ { HVDClink(t,br) and LossBranch(t,br) }, resolveHVDCnonPhysicalLosses * NonPhysicalLossExist(t,br) ]
6384                                          + sum[ pole, resolveCircularBranchFlows * poleCircularBranchFlowExist(t,pole)]
6385                                          ) > UseBranchFlowMIPTolerance
6386                                        } = 1 ;
6387   
6388   
6389   
6390              );
6391  *           Post-Solve - Circulating flow check end
6392   
6393  *           A period is unsolved if MILP model is required
6394              unsolvedDT(t) = yes $ UseBranchFlowMIP(t) ;
6395   
6396  *           Post a progress message for use by EMI. Reverting to the sequential mode for integer resolves.
6397              loop( unsolvedDT(t),
6398                  if( UseBranchFlowMIP(t) >= 1,
6399                      VSPDModel(t) = 1;
6400                      putclose rep 'The caseID: ' ca.tl ' requires a vSPD_BranchFlowMIP resolve for period ' dt.tl '.'/
6401                  ) ;
6402              ) ;
6403          ) ;
6404  *   Check if the NMIR results are valid end
6405      ) ;
6406  *   Solve the NMIR model end ---------------------------------------------------
6407   
6408   
6409  *   Solve the vSPD_BranchFlowMIP -----------------------------------------------
6410      if ( smax[t, VSPDModel(t)] = 1,
6411  *       Fix the values of these integer variables that are not needed
6412          ACBRANCHFLOWDIRECTED_INTEGER.fx(branch(t,br),fd) $ { (not ACbranch(t,br)) or (not LossBranch(branch)) } = 0 ;
6413  *       Fix the integer AC branch flow variable to zero for invalid branches
6414          ACBRANCHFLOWDIRECTED_INTEGER.fx(t,br,fd) $ (not branch(t,br)) = 0 ;
6415  *       Apply an upper bound on the integer weighting parameter
6416          LAMBDAINTEGER.up(branch(t,br),bp) = 1 ;
6417  *       Ensure that the weighting factor value is zero for AC branches and for invalid loss segments on HVDC links
6418          LAMBDAINTEGER.fx(branch(t,br),bp) $ { ACbranch(branch) or ( sum[fd $ validLossSegment(branch,bp,fd),1 ] = 0 ) } = 0 ;
6419  *       Fix the lambda integer variable to zero for invalid branches
6420          LAMBDAINTEGER.fx(t,br,bp) $ (not branch(t,br)) = 0 ;
6421   
6422          option bratio = 1 ;
6423          vSPD_BranchFlowMIP.Optfile = 1 ;
6424          vSPD_BranchFlowMIP.optcr = MIPOptimality ;
6425          vSPD_BranchFlowMIP.reslim = MIPTimeLimit ;
6426          vSPD_BranchFlowMIP.iterlim = MIPIterationLimit ;
6427          solve vSPD_BranchFlowMIP using mip maximizing NETBENEFIT ;
6428  *       Set the model solve status
6429          ModelSolved = 1 $ { [ ( vSPD_BranchFlowMIP.modelstat = 1) or (vSPD_BranchFlowMIP.modelstat = 8) ] and [ vSPD_BranchFlowMIP.solvestat = 1 ] } ;
6430   
6431  *       Post a progress message for use by EMI.
6432          if(ModelSolved = 1,
6433  *           Flag to show the period that required SOS1 solve
6434              SOS1_solve(t)  = yes;
6435              loop(t,
6436                  unsolvedDT(t) = no;
6437                  putclose rep 'The caseID: ' ca.tl ' (' dt.tl ') is 1st solved successfully for branch integer.'/
6438                               'Objective function value: ' NETBENEFIT.l:<15:4 /
6439                               'Violations cost         : ' TOTALPENALTYCOST.l:<15:4 /;
6440  *              set vSPD model to solve as normal mode after successfully resolving using branch integer
6441                 VSPDModel(t) = 0
6442              ) ;
6443          else
6444              loop (t,
6445                  unsolvedDT(t) = yes;
6446                  VSPDModel(t) = 2;
6447                  putclose rep 'The caseID: ' ca.tl ' (' dt.tl ') is 1st solved unsuccessfully for branch integer.'/
6448              ) ;
6449          ) ;
6450      ) ;
6451  *   Solve the vSPD_BranchFlowMIP model end -------------------------------------
6452   
6453   
6454  *   ReSolve the NMIR model and stop --------------------------------------------
6455      if (smax[t, VSPDModel(t)] = 2,
6456   
6457          option bratio = 1 ;
6458          vSPD_NMIR.Optfile = 1 ;
6459          vSPD_NMIR.optcr = MIPOptimality ;
6460          vSPD_NMIR.reslim = MIPTimeLimit ;
6461          vSPD_NMIR.iterlim = MIPIterationLimit ;
6462          solve vSPD_NMIR using mip maximizing NETBENEFIT ;
6463  *       Set the model solve status
6464          ModelSolved = 1 $ { ( (vSPD_NMIR.modelstat = 1) or (vSPD_NMIR.modelstat = 8) ) and ( vSPD_NMIR.solvestat = 1 ) } ;
6465   
6466  *       Post a progress message for use by EMI.
6467          if (ModelSolved = 1,
6468              loop (t,
6469                  putclose rep 'The caseID: ' ca.tl ' (' dt.tl ') branch flow integer resolve was unsuccessful.' /
6470                                  'Reverting back to base model (NMIR) and solve successfully. ' /
6471                                  'Objective function value: ' NETBENEFIT.l:<15:4 /
6472                                  'Violations cost         : '  TOTALPENALTYCOST.l:<15:4 /
6473                                  'Solution may have circulating flows and/or non-physical losses.' /
6474              ) ;
6475          else
6476              loop (t,
6477                  putclose rep 'The caseID: ' ca.tl ' (' dt.tl ') integer solve was unsuccessful. Reverting back to base model (NMIR) and solve unsuccessfully.' /
6478              ) ;
6479          ) ;
6480   
6481          unsolvedDT(t) = no;
6482   
6483  *   ReSolve the NMIR model and stop end ----------------------------------------
6484   
6485      ) ;
6486  *   Solve the models end
6487   
6488   
6489  *   Post-Solve Checks ----------------------------------------------------------
6490   
6491  *   Check for disconnected nodes
          8.2 Dead Electrical Island
              If an Electrical Island > 2 has no positive load or if the total energy offered within the Electrical Island is zero then the Electrical Island is determined to be a dead
              Electrical Island and each ACNode in the Electrical Island is added to the set of DeadACNodes and each Pnode in the Electrical Island is added to the set of DeadPnodes.
          8.4 Disconnected Pnodes
              Each Pnode that has a scheduled load of zero and is in the set of DeadPnodes is added to the set of DisconnectedPnodes.
6499      busGeneration(bus(t,b)) = sum[ (o,n) $ { offerNode(t,o,n) and NodeBus(t,n,b) } , NodeBusAllocationFactor(t,n,b) * GENERATION.l(t,o) ] ;
6500      busLoad(bus(t,b))       = sum[ NodeBus(t,n,b), NodeBusAllocationFactor(t,n,b) * requiredLoad(t,n) ] ;
6501      busDisconnected(bus(t,b)) $ { ( [busElectricalIsland(bus) = 0] and [busLoad(bus) = 0] )
6502                                 or ( sum[ b1 $ { busElectricalIsland(t,b1) = busElectricalIsland(bus) } , busLoad(t,b1) ] = 0 )
6503                                 or ( sum[ b1 $ { busElectricalIsland(t,b1) = busElectricalIsland(bus) } , busGeneration(t,b1) ] = 0 ) } = 1 ;
6504   
6505  *   Energy Shortfall Check (7.2)
6506      if( (smax[t, dtParameter(t,'enrgShortfallTransfer')] = 1) and (LoopCount(ca,dt) < maxSolveLoops(ca,dt)),
6507   
6508  *       Check for dead nodes
6509          IsNodeDead(t,n) = 1 $ ( sum[b $ { NodeBus(t,n,b) and (busDisconnected(t,b)=0) }, NodeBusAllocationFactor(t,n,b) ] = 0 ) ;
6510          IsNodeDead(t,n) $ ( sum[b $ NodeBus(t,n,b), busElectricalIsland(t,b) ] = 0 ) = 1 ;
6511          NodeElectricalIsland(t,n) = smin[b $ NodeBusAllocationFactor(t,n,b), busElectricalIsland(t,b)] ;
6512          InputInitialLoad(t,n) $ { IsNodeDead(t,n) and (NodeElectricalIsland(t,n) > 0) } = 0;
6513   
6514  *       Check if a pnode has energy shortfall
6515          EnergyShortfallMW(t,n) $ Node(t,n) = ENERGYSCARCITYNODE.l(t,n) + sum[ b $ NodeBus(t,n,b), busNodeAllocationFactor(t,b,n) * DEFICITBUSGENERATION.l(t,b) ] ;
6516          EnergyShortfallMW(t,n) $ { IsNodeDead(t,n) and (NodeElectricalIsland(t,n) > 0) } = 0;
6517   
6518  *       a.Checkable Energy Shortfall:
6519  *       If a node has an EnergyShortfallMW greater than zero and the node has LoadIsOverride set to False and the Pnode has InstructedShedActivepn set to False, then EnergyShortfall is checked.
6520          EnergyShortFallCheck(t,n) = 1 $ { (EnergyShortfallMW(t,n) > 0) and (LoadIsOverride(t,n) = 0) and (instructedShedActive(t,n) = 0) } ;
6521   
6522  *       c. Eligible for Removal:
6523  *       An EnergyShortfall is eligible for removal if there is evidence that it is due to a modelling inconsistency (as described below),
6524  *       or if the RTD Required Load calculation used an estimated initial load rather than an actual initial load, or if the node is dead node.
6525          EligibleShortfallRemoval(t,n) = 1 $ [EnergyShortFallCheck(t,n)  and { PotentialModellingInconsistency(t,n) or (useActualLoad(t) = 0) or (LoadIsBad(t,n) = 1) or (IsNodeDead(t,n) = 1) }] ;
6526   
6527  *       d. Shortfall Removal:
6528  *       If the shortfall at a node is eligible for removal then a Shortfall Adjustment quantity is subtracted from the requiredLoad in order to remove the shortfall.
6529  *       If the node is dead node then the Shortfall Adjustment is equal to EnergyShortfallMW otherwise it's equal to EnergyShortfall plus EnergyShortfallRemovalMargin.
6530  *       If the adjustment would make requiredLoad negative then requiredLoad is assigned a value of zero. The adjusted node has DidShortfallTransferpn set to True so that
6531  *       the RTD Required Load calculation does not recalculate its requiredLoad at this node
6532          ShortfallAdjustmentMW(t,n) $ EligibleShortfallRemoval(t,n) = [ dtParameter(ca,dt,'shortfallRemovalMargin') $ (IsNodeDead(t,n) = 0) ] + EnergyShortfallMW(t,n) ;
6533   
6534          requiredLoad(t,n) $ EligibleShortfallRemoval(t,n) = requiredLoad(t,n) - ShortfallAdjustmentMW(t,n) ;
6535          requiredLoad(t,n) $ { EligibleShortfallRemoval(t,n) and (requiredLoad(t,n) < 0) } = 0 ;
6536          DidShortfallTransfer(t,n) $ EligibleShortfallRemoval(t,n) = 1 ;
6537   
6538          loop( (t,n) $ EnergyShortfallMW(t,n),
6539              putclose rep 'Energy shortfall at node' n.tl,': ', EnergyShortfallMW(t,n)' MW. Eligible for shortfall removal: ' EligibleShortfallRemoval(t,n):<1:0 /;
6540          ) ;
6541   
      e. Shortfall Transfer:
      If the previous step adjusts requiredLoad then the processing will search for a transfer target Pnode to receive the Shortfall Adjustment quantity (the search process is described below).
      If a transfer target node is found then the ShortfallAdjustmentMW is added to the requiredLoad of the transfer target node and the DidShortfallTransfer of the transfer target Pnode flag is set to True.
      k. Shortfall Transfer Target:
      In the Shortfall Transfer step, the search for a transfer target node proceeds as follows.
      The first choice candidate for price transfer source is the PnodeTransferPnode of the target Pnode. If the candidate is ineligible then the new candidate will be the PnodeTransferPnode of the candidate,
      if any, but only if this new candidate has not already been visited in this search. The process of locating and checking candidates will continue until an eligible transfer Pnode is located or until no
      more candidates are found. A candidate node isn't eligible as a target if it has a non-zero EnergyShortfall in the solution being checked or had one in the solution of a previous solve loop, or if the
      candidate node has LoadIsOverridepn set to True, or if the candidate node has InstructedShedActivepn set to True, or if the node with the shortfall is not in Electrical Island 0 and the ElectricalIsland
      of the candidate node is not the same as the ElectricalIslandpn of the node with the shortfall, or if the candidate node is in the set of DEADPNODESpn.
6554          unsolvedDT(t) = yes $ sum[n $ EligibleShortfallRemoval(t,n), ShortfallAdjustmentMW(t,n)] ;
6555   
6556  *        while( sum[n, ShortfallAdjustmentMW(ca,dt,n)],
6557   
6558  * If target node is dead --> move it up to one level
6559              nodeTonode(t,n,n2) $ sum[n1 $ { nodeTonode(t,n,n1) and nodeTonode(t,n1,n2) }, IsNodeDead(t,n1)] = yes ;
6560              nodeTonode(t,n,n1) $ IsNodeDead(t,n1) = no ;
6561   
6562  * This is the approach SPD is using (a deficit node is ineligible as target node )
6563              nodeTonode(t,n,n2) $ sum[n1 $ { nodeTonode(t,n,n1) and nodeTonode(t,n1,n2) }, ShortfallAdjustmentMW(t,n1)] = yes;
6564              nodeTonode(t,n,n1) $ sum[n2 $ { nodeTonode(t,n,n2) and nodeTonode(t,n1,n2) }, ShortfallAdjustmentMW(t,n1)] = no;
6565   
6566  *           Check if shortfall from node n is eligibly transfered to node n1
6567              ShortfallTransferFromTo(nodeTonode(t,n,n1))
6568                  $ { (ShortfallAdjustmentMW(t,n) > 0)
6569                  and (LoadIsOverride(t,n1) = 0) and (InstructedShedActive(t,n1) = 0)
6570                  and [ (NodeElectricalIsland(t,n) = NodeElectricalIsland(t,n1)) or (NodeElectricalIsland(t,n) = 0) ]
6571                    } = 1;
6572   
6573  * This is the approach Tuong propose (a target node is ineligible as target node twice consecutively  ))
6574  *            nodeTonode(t,n,n2) $ sum[n1 $ nodeTonode(t,n1,n2), ShortfallTransferFromTo(t,n,n1)] = yes;
6575  *            nodeTonode(t,n,n1) $ ShortfallTransferFromTo(t,n,n1) = no;
6576   
6577              loop( nodeTonode(t,n,n1) $ ShortfallTransferFromTo(t,n,n1),
6578                 putclose rep 'Short fall adjustment from 'n.tl' to ', n1.tl,': ', ShortfallAdjustmentMW(t,n)' MW' /;
6579              ) ;
6580   
6581  *           If a transfer target node is found then the ShortfallAdjustmentMW is added to the requiredLoad of the transfer target node
6582              requiredLoad(t,n1) $ (IsNodeDead(t,n1) = 0)= requiredLoad(t,n1) + sum[ n $ ShortfallTransferFromTo(t,n,n1), ShortfallAdjustmentMW(t,n)] ;
6583              PotentialModellingInconsistency(t,n1) $ {(IsNodeDead(t,n1)=0) and sum[ n $ ShortfallTransferFromTo(t,n,n1), ShortfallAdjustmentMW(t,n)] } = 1;
6584   
6585  *           If a transfer target node is dead then the ShortfallAdjustmentMW is added to the ShortfallAdjustmentMW of the transfer target node
6586              ShortfallAdjustmentMW(t,n1) $ (IsNodeDead(t,n1) = 1) = ShortfallAdjustmentMW(t,n1) + sum[ n $ ShortfallTransferFromTo(t,n,n1), ShortfallAdjustmentMW(t,n)] ;
6587   
6588  *           and the DidShortfallTransfer of the transfer target node is set to 1
6589              DidShortfallTransfer(t,n1) $ sum[n, ShortfallTransferFromTo(t,n,n1)] = 1 ;
6590   
6591  *           Set ShortfallAdjustmentMW at node n to zero if shortfall can be transfered to a target node
6592              ShortfallAdjustmentMW(t,n) $ sum[ n1, ShortfallTransferFromTo(t,n,n1)] = 0;
6593              ShortfallTransferFromTo(t,n,n1) = 0;
6594   
6595  *        ) ;
6596   
6597  *       f. Scaling Disabled: For an RTD schedule type, when an EnergyShortfallpn is checked but the shortfall is not eligible for removal then ShortfallDisabledScalingpn is set to True
6598  *       which will prevent the RTD Required Load calculation from scaling InitialLoad.
6599          ShortfallDisabledScaling(t,n) = 1 $ { (EnergyShortFallCheck(t,n)=1) and (EligibleShortfallRemoval(t,n)=0) };
6600      ) ;
6601  *   Energy Shortfall Check End
6602   
6603      unsolvedDT(t) $ {(studyMode(t) = 101 or studyMode(t) = 201) and (LoopCount(t)=1) and (dailymode = 0)} = yes ;
6604      if ((studyMode(ca,dt) = 101 or studyMode(ca,dt) = 201) and sum[unsolvedDT(t),1] and (dailymode = 0),
6605          putclose rep 'Recalculate RTD Island Loss for next solve'/;
6606          LoadCalcLosses(t,isl)= Sum[ (br,frB,toB) $ { ACbranch(t,br) and branchBusDefn(t,br,frB,toB) and busIsland(t,toB,isl) }, sum[ fd, ACBRANCHLOSSESDIRECTED.l(t,br,fd) ] + branchFixedLoss(t,br) ]
6607                               + Sum[ (br,frB,toB) $ { HVDClink(t,br) and branchBusDefn(t,br,frB,toB) and ( busIsland(t,toB,isl) or busIsland(t,frB,isl) ) }, 0.5 * branchFixedLoss(t,br) ]
6608                               + Sum[ (br,frB,toB) $ { HVDClink(t,br) and branchBusDefn(t,br,frB,toB) and busIsland(t,toB,isl) and (not (busIsland(t,frB,isl))) }, HVDCLINKLOSSES.l(t,br) ] ;
6609  *        LoopCount(t) = LoopCount(t) + 1 ;
6610          loop( (t,isl) $ {unsolvedDT(t) and ( SPDLoadCalcLosses(t,isl) > 0 ) and ( abs( SPDLoadCalcLosses(t,isl) - LoadCalcLosses(t,isl) ) > SPDlossTolerance )},
6611              putclose rep 'Recalulated losses for ' isl.tl ' are different between vSPD (' LoadCalcLosses(t,isl):<10:5 ') and SPD (' SPDLoadCalcLosses(t,isl):<10:5 ') --> Using SPD calculated losses instead.' ;
6612  *            putclose rep 'Using SPDLoadCalcLosses instead. /' ;
6613              LoadCalcLosses(t,isl) = SPDLoadCalcLosses(t,isl);
6614   
6615          );
6616      ) ;
6617      LoopCount(t) = LoopCount(t) + 1 ;
6618      unsolvedDT(t) $ (LoopCount(t) > maxSolveLoops(t)) = no ;
6619  *   6g. Collect and store results of solved periods into output parameters -----
6620  *   Note: all the price relating outputs such as costs and revenues are calculated in section 7.b
6621   
6623   
6624  *   Normal vSPD run - write results out for for reporting
6625      Loop (t $ (not unsolvedDT(t)),
6626   
6627   
6628  *       6f. Check for disconnected nodes and adjust prices accordingly -------------
          8.2 Dead Electrical Island
              If an Electrical Island > 2 has no positive load or if the total energy offered within the Electrical Island is zero then the Electrical Island is determined to be a dead
              Electrical Island and each ACNode in the Electrical Island is added to the set of DeadACNodes and each Pnode in the Electrical Island is added to the set of DeadPnodes.
          8.4 Disconnected Pnodes
              Each Pnode that has a scheduled load of zero and is in the set of DeadPnodes is added to the set of DisconnectedPnodes.
6636   
6637          busGeneration(bus(t,b)) = sum[ (o,n) $ { offerNode(t,o,n) and NodeBus(t,n,b) } , NodeBusAllocationFactor(t,n,b) * GENERATION.l(t,o) ] ;
6638          busLoad(bus(t,b))       = sum[ NodeBus(t,n,b), NodeBusAllocationFactor(t,n,b) * requiredLoad(t,n) ] ;
6639          busPrice(bus(t,b))      = ACnodeNetInjectionDefinition2.m(t,b) ;
6640   
6641          busDisconnected(bus(t,b)) $ { (busLoad(bus) = 0) and (busElectricalIsland(bus) = 0) } = 1 ;
6642          busDisconnected(bus(t,b)) $ { ( sum[ b1 $ { busElectricalIsland(t,b1) = busElectricalIsland(bus) }, busLoad(t,b1) ] = 0) and ( busElectricalIsland(bus) > 0 ) } = 1 ;
6643  *       Set prices at dead buses with non-zero load
6644          busPrice(bus(t,b)) $ { (busLoad(bus) > 0) and (busElectricalIsland(bus)= 0) } = DeficitBusGenerationPenalty ;
6645          busPrice(bus(t,b)) $ { (busLoad(bus) < 0) and (busElectricalIsland(bus)= 0) } = -SurplusBusGenerationPenalty ;
6646  *       Set price at identified disconnected buses to 0
6647          busPrice(bus)$busDisconnected(bus) = 0 ;
6648  *       End Check for disconnected nodes and adjust prices accordingly
6649   
6650  *       6f0. Replacing invalid prices after SOS1 (7.1.3)----------------------------
6651          if ( SOS1_solve(ca,dt),
6652  *           Calculate highest bus cleared offere price
6653              busClearedPrice(ca,dt,b) = smax[ (o,n,blk) $ { offernode(ca,dt,o,n) and nodebus(ca,dt,n,b) and (GENERATIONBLOCK.l(ca,dt,o,blk) > 0) },enrgOfrPrice(ca,dt,o,blk) ];
6654              busSOSinvalid(ca,dt,b)
6655                  = 1 $ { [ ( busPrice(ca,dt,b) = 0 ) or ( busPrice(ca,dt,b) > 0.9*deficitBusGenerationPenalty ) or ( busPrice(ca,dt,b) < -0.9*surplusBusGenerationPenalty )
6656                          or (busPrice(ca,dt,b)=busClearedPrice(ca,dt,b) ) or (busPrice(ca,dt,b)=busClearedPrice(ca,dt,b) + 0.0005 ) or (busPrice(ca,dt,b)=busClearedPrice(ca,dt,b) - 0.0005 )   ]
6657                      and bus(ca,dt,b)  and [ not busDisconnected(ca,dt,b) ]  and [ busLoad(ca,dt,b) = busGeneration(ca,dt,b) ]
6658                      and [ sum[(br,fd) $ { BranchBusConnect(ca,dt,br,b) and branch(ca,dt,br) }, ACBRANCHFLOWDIRECTED.l(ca,dt,br,fd) ] = 0 ]
6659                      and [ sum[ br     $ { BranchBusConnect(ca,dt,br,b) and branch(ca,dt,br) } , 1 ] > 0 ]
6660                        };
6661  *display busClearedPrice,busSOSinvalid;
6662              numberofbusSOSinvalid(ca,dt) = 2*sum[b, busSOSinvalid(ca,dt,b)];
6663   
6664              While ( sum[b, busSOSinvalid(ca,dt,b)] < numberofbusSOSinvalid(ca,dt) ,
6665                  numberofbusSOSinvalid(ca,dt) = sum[b, busSOSinvalid(ca,dt,b)];
6666   
6667                  busPrice(ca,dt,b) $ { busSOSinvalid(ca,dt,b) and ( sum[ b1 $ { [ not busSOSinvalid(ca,dt,b1) ] and sum[ br $ { branch(ca,dt,br) and BranchBusConnect(ca,dt,br,b) and BranchBusConnect(ca,dt,br,b1) }, 1 ] }, 1 ] > 0 ) }
6668                      = sum[ b1 $ { [ not busSOSinvalid(ca,dt,b1) ] and sum[ br $ { branch(ca,dt,br) and BranchBusConnect(ca,dt,br,b) and BranchBusConnect(ca,dt,br,b1) }, 1 ] }, busPrice(ca,dt,b1) ]
6669                      / sum[ b1 $ { [ not busSOSinvalid(ca,dt,b1) ] and sum[ br $ { branch(ca,dt,br) and BranchBusConnect(ca,dt,br,b) and BranchBusConnect(ca,dt,br,b1) }, 1 ] }, 1 ];
6670   
6671                  busSOSinvalid(ca,dt,b)
6672                    = 1 $ { [ ( busPrice(ca,dt,b) = 0 ) or ( busPrice(ca,dt,b) > 0.9 * deficitBusGenerationPenalty ) or ( busPrice(ca,dt,b) < -0.9 * surplusBusGenerationPenalty ) ]
6673                        and bus(ca,dt,b) and [ not busDisconnected(ca,dt,b) ] and [ busLoad(ca,dt,b) = busGeneration(ca,dt,b) ]
6674                        and [ sum[(br,fd) $ { BranchBusConnect(ca,dt,br,b) and branch(ca,dt,br) }, ACBRANCHFLOWDIRECTED.l(ca,dt,br,fd) ] = 0 ]
6675                        and [ sum[ br $ { BranchBusConnect(ca,dt,br,b) and branch(ca,dt,br) }, 1 ] > 0 ]
6676                          };
6677              );
6678          );
6679  *   End Replacing invalid prices after SOS1 (7.1.3) ----------------------------
6680   
6681   
6682  *   Reporting at trading period start
6683  *       Node level output
6684          o_nodeGeneration_TP(t,n) $ Node(t,n) = sum[ o $ offerNode(t,o,n), GENERATION.l(t,o) ] ;
6685          o_nodeLoad_TP(t,n)       $ Node(t,n) = requiredLoad(t,n) + sum[ bd $ bidNode(t,bd,n), PURCHASE.l(t,bd) ];
6686          o_nodePrice_TP(t,n)      $ Node(t,n) = sum[ b $ NodeBus(t,n,b), NodeBusAllocationFactor(t,n,b) * busPrice(t,b) ] ;
6687   
              8.3.5 Dead Price Replacement
              Dead Price Replacement is applied to the Schedule Types that produce settlement prices, i.e., RTD, RTDP, PRS. For each Pnode in the set of DeadPnodes the Dead Price Replacement processing will search for a suitable
              price transfer source Pnode to provide a replacement price
       
              The first choice candidate for price transfer source is the PnodeTransferPnode of the target Pnode. If the candidate is ineligible then the new candidate will be the PnodeTransferPnodepn of the candidate, if any, but
              only if this new candidate has not already been visited in this search. The process of locating and checking candidates will continue until an eligible transfer Pnode is located or until no more candidates are found.
       
              A candidate Pnode is not eligible as a price source if it is in the set of DEADPNODESpn, or if the source candidate Pnode is not in the same Electrical Island as the target Pnode unless the target Pnode is in Island 0,
              i.e., if the target of the price transfer is in Electrical Island 0 then it does not matter which Electrical Island the price source is in, provided the price source is not a dead Pnode.
       
              Note that a candidate Pnode with a shortfall is eligible.
       
              If an eligible price transfer source is found then the energy price of the dead Pnode and its associated ACNode are assigned the energy price of the transfer Pnode. If no eligible price is found then the dead Pnode
              and its associated ACNode are assigned a price of zero.
6704          if ( dtParameter(t,'priceTransfer') and [(studyMode(t) = 101) or (studyMode(t) = 201) or (studyMode(t) = 130) or (studyMode(t) = 131)],
6705  *           A node is dead if it is not associated through allocation factor with any live bus.
6706              o_nodeDead_TP(t,n) = 1 $ { ( sum[b $ {NodeBus(t,n,b) and (not busDisconnected(t,b)) }, NodeBusAllocationFactor(t,n,b) ] = 0 )} ;
6707  *           If a node is dead, it will be considered to price transfer.
6708              o_nodeDeadPrice_TP(t,n) $ o_nodeDead_TP(t,n) = 1;
6709  *           Define the live node n1 where the price is transfre to dead node n
6710              o_nodeDeadPriceFrom_TP(t,n,n1) = 1 $ { Sum[ isl $ { nodeIsland(t,n,isl) and nodeIsland(t,n1,isl) },1 ] and o_nodeDead_TP(t,n) and node2node(t,n,n1) and ( o_nodeDead_TP(t,n1) = 0) };
6711   
6712  *           Continue until no more price transfer is eligible
6713              while (sum[ n $ o_nodeDead_TP(t,n), o_nodeDeadPrice_TP(t,n) ],
6714  *               Transfre price from a live node to a dead node
6715                  o_nodePrice_TP(t,n) $ { o_nodeDead_TP(t,n) and o_nodeDeadPrice_TP(t,n) } = sum[n1 $ o_nodeDeadPriceFrom_TP(t,n,n1), o_nodePrice_TP(t,n1) ] ;
6716  *               If a dead node has price transferred to --> no longer dead in this while loop
6717                  o_nodeDead_TP(t,n) $ {o_nodeDead_TP(t,n) and sum[n1 $ {not o_nodeDead_TP(t,n1)}, o_nodeDeadPriceFrom_TP(t,n,n1) ]} = 0;
6718  *               Redefine the node from which price is transferred to remaining dead node
6719                  o_nodeDeadPriceFrom_TP(t,n,n1) = 1 $ { Sum[ isl $ { nodeIsland(t,n,isl) and nodeIsland(t,n1,isl) },1 ] and o_nodeDead_TP(t,n) and node2node(t,n,n1) and ( o_nodeDead_TP(t,n1) = 0) };
6720  *               Redefine the list of dead node to be considered for price transfer
6721                  o_nodeDeadPrice_TP(t,n) = 1 $ sum[n1 $ {not o_nodeDead_TP(t,n1)}, o_nodeDeadPriceFrom_TP(t,n,n1) ];
6722              ) ;
6723          ) ;
