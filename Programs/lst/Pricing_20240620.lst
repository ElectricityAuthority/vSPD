7190      else
7191           put 'ECE','MANUAL', 'MANUAL';
7192      );
7193      put riskParameter(ca,dt,isl,resC,ManualRisk,'minRisk') , 0, 0
7194          FreeReserve(ca,dt,isl,resC,ManualRisk)
7195          o_TotalIslandReserve(ca,dt,isl,resC,ManualRisk)
7196          o_ManualRiskShortfall_TP(ca,dt,isl,resC,ManualRisk)
7197          o_ResViolation_TP(ca,dt,isl,resC), o_ResPrice_TP(ca,dt,isl,resC)
7198          o_ManualRiskPrice_TP(ca,dt,isl,resC,ManualRisk)    / ;
7199  );
7200   
7201  loop( (ca,dt,tp,isl,rg,resC,GenRisk) $ { case2dt2tp(ca,dt,tp) and (o_GenRiskGroupPrice_TP(ca,dt,isl,rg,resC,GenRisk) <> 0) },
7202      put ca.tl, dt.tl, tp.tl, isl.tl, resC.tl ;
7203      if (ContingentEvents(GenRisk),
7204           put 'CE', 'RISKGROUP';
