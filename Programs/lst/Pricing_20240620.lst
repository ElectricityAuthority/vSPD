7180          o_TotalIslandReserve(ca,dt,isl,resC,HVDCrisk)
7181          o_HVDCRiskShortfall_TP(ca,dt,isl,resC,HVDCrisk)
7182          o_ResViolation_TP(ca,dt,isl,resC), o_ResPrice_TP(ca,dt,isl,resC)
7183          o_HVDCRiskPrice_TP(ca,dt,isl,resC,HVDCrisk)  / ;
7184  );
